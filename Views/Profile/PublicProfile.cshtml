@section Scripts {
    <script>
        // ============================================================
        //  TAKİP İSTEKLERİ (kendi profilinde zil ikonu)
        // ============================================================
        var ppReqModal;
        function openRequestsModal() {
            if (!ppReqModal) {
                ppReqModal = new bootstrap.Modal(document.getElementById('requestsModal'));
            }
            ppReqModal.show();
            loadRequests();
        }

        function loadRequests() {
            var body = $('#requestsModalBody');
            body.html('<div class="text-center"><i class="fa-solid fa-spinner fa-spin"></i> Yükleniyor...</div>');

            $.get('/Profile/GetFollowRequests', function (res) {
                if (res.success) {
                    if (res.data.length === 0) {
                        body.html('<div class="text-center text-muted" style="padding: 20px;">Bekleyen takip isteği yok.</div>');
                        return;
                    }
                    var html = '<div class="list-group list-group-flush">';
                    res.data.forEach(function (req) {
                        var avatarContent = req.profileImage
                            ? '<img src="' + req.profileImage + '" style="width:40px;height:40px;border-radius:10px;object-fit:cover;">'
                            : '<div style="width:40px;height:40px;border-radius:10px;background:#e6dac8;display:flex;align-items:center;justify-content:center;font-weight:bold;color:#8b6f47;">' + req.userName.charAt(0).toUpperCase() + '</div>';

                        var frameContent = req.activeFrame
                            ? '<img src="' + req.activeFrame + '" style="position: absolute; top: -15%; left: -15%; width: 130%; height: 130%; pointer-events: none; z-index: 10; object-fit: contain;">'
                            : '';

                        var avatarHtml = '<div style="position: relative; width: 40px; height: 40px; flex-shrink: 0;">' + avatarContent + frameContent + '</div>';

                        html += `
                        <div class="list-group-item d-flex justify-content-between align-items-center" style="background:transparent; border-color: rgba(139,111,71,0.1);" id="req-item-${req.followerId}">
                            <a href="/Profile/PublicProfile/${req.followerId}" class="d-flex align-items-center gap-3 text-decoration-none" style="flex-grow: 1;">
                                ${avatarHtml}
                                <span style="font-weight: 600; color: #4a3f35;">${req.userName}</span>
                            </a>
                            <div style="flex-shrink: 0;">
                                <button class="btn btn-sm btn-success me-1" onclick="handleReq(${req.followerId}, true)"><i class="fa-solid fa-check"></i></button>
                                <button class="btn btn-sm btn-danger" onclick="handleReq(${req.followerId}, false)"><i class="fa-solid fa-xmark"></i></button>
                            </div>
                        </div>`;
                    });
                    html += '</div>';
                    body.html(html);
                } else {
                    body.html('<div class="text-center text-danger">İstekler yüklenemedi.</div>');
                }
            }).fail(function () {
                body.html('<div class="text-center text-danger">İstekler yüklenemedi.</div>');
            });
        }

        function handleReq(followerId, isAccept) {
            var url = isAccept ? '/Profile/AcceptFollowRequest' : '/Profile/RejectFollowRequest';
            $.post(url, { followerId: followerId }, function (res) {
                if (res.success) {
                    $('#req-item-' + followerId).fadeOut(300, function () {
                        $(this).remove();

                        // Zil rozeti + mobil menü rozetlerini azalt
                        var decrementFn = function (selector) {
                            var b = $(selector);
                            if (b.length) {
                                var curr = parseInt(b.text()) || 0;
                                if (curr > 1) { b.text(curr - 1); }
                                else { b.text(0).addClass('d-none'); }
                            }
                        };

                        decrementFn('#ppRequestsBadge');
                        decrementFn('#toplulukBadge');

                        // Mobil menü noktası: takip isteği kalmadıysa ilgili işareti kaldır
                        var tBadge = $('#toplulukBadge');
                        if (tBadge.length && (parseInt(tBadge.text()) || 0) === 0) {
                            var md = $('#mobileMenuDot');
                            if (md.length) {
                                md.data('follow-requests', false);
                                md.attr('data-follow-requests', 'false');
                                if (md.attr('data-achievements') !== 'true') {
                                    md.addClass('d-none');
                                }
                            }
                        }

                        if ($('#requestsModalBody .list-group-item').length === 0) {
                            $('#requestsModalBody').html('<div class="text-center text-muted" style="padding: 20px;">Bekleyen takip isteği yok.</div>');
                        }
                    });
                } else {
                    alert((res && res.message) || "İşlem gerçekleştirilemedi.");
                }
            }).fail(function () {
                alert("Sunucu ile bağlantı kurulamadı.");
            });
        }

        // ============================================================
        //  BANNER TAKMA / KALDIRMA (PublicProfile)
        // ============================================================
        function equipBannerPP(id, btn) {
            btn.disabled = true;
            var original = btn.innerHTML;
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i>';

            fetch('/Profile/EquipBannerProfile', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: new URLSearchParams({ bannerId: id })
            })
            .then(r => r.json())
            .then(data => {
                if (data.success) {
                    location.reload();
                } else {
                    alert(data.message || 'Bir hata oluştu.');
                    btn.innerHTML = original;
                    btn.disabled = false;
                }
            })
            .catch(err => {
                console.error(err);
                alert('Bağlantı hatası.');
                btn.innerHTML = original;
                btn.disabled = false;
            });
        }

        // ============================================================
        //  SAYAÇ COUNT-UP ANİMASYONU
        // ============================================================
        function animateCounter(el) {
            var target = parseInt(el.getAttribute('data-target')) || 0;
            if (target === 0) { el.textContent = '0'; return; }

            var duration = 900;
            var start = performance.now();

            function tick(now) {
                var progress = Math.min((now - start) / duration, 1);
                // easeOutCubic
                var eased = 1 - Math.pow(1 - progress, 3);
                el.textContent = Math.round(target * eased);
                if (progress < 1) requestAnimationFrame(tick);
            }
            requestAnimationFrame(tick);
        }

        document.addEventListener('DOMContentLoaded', function () {
            // Sayaçları canlandır
            document.querySelectorAll('.pp-countup').forEach(animateCounter);

            // Ödül topladıktan sonra sayfa yenilenince Başarımlar sekmesini tekrar aç
            try {
                if (sessionStorage.getItem('ppReopenAch') === '1') {
                    sessionStorage.removeItem('ppReopenAch');
                    var achTab = document.getElementById('achievements-tab');
                    if (achTab) {
                        new bootstrap.Tab(achTab).show();
                        ppAnimateAchievements();
                    }
                }
            } catch (e) { }
        });

        // ============================================================
        //  BAŞARIMLAR SEKMESİ ANİMASYONLARI
        //  (sekme ilk kez görünür olduğunda halka ve çubuklar dolar)
        // ============================================================
        var ppAchAnimated = false;
        function ppAnimateAchievements() {
            if (ppAchAnimated) return;
            ppAchAnimated = true;

            document.querySelectorAll('#achievements-pane .pp-ach-fill').forEach(function (el) {
                el.style.width = el.getAttribute('data-width') + '%';
            });

            var ring = document.getElementById('ppAchRing');
            if (ring) {
                var percent = parseFloat(ring.getAttribute('data-percent')) || 0;
                var circumference = 2 * Math.PI * 52;
                ring.style.strokeDashoffset = circumference * (1 - percent / 100);
            }
        }

        var ppAchTabBtn = document.getElementById('achievements-tab');
        if (ppAchTabBtn) {
            ppAchTabBtn.addEventListener('shown.bs.tab', ppAnimateAchievements);
        }

        // Kitaplık kartındaki hızlı beğeni (kalp)
        function toggleBookLike(evt, bookId, btn) {
            evt.preventDefault();
            evt.stopPropagation();
            if (btn.dataset.busy === '1') return;
            btn.dataset.busy = '1';

            var icon = btn.querySelector('i');
            var countEl = btn.querySelector('.pp-book-like-count');

            $.post('/Profile/ToggleLikeBook', { bookId: bookId }, function (res) {
                btn.dataset.busy = '';
                if (!res.success) { alert(res.message || 'İşlem gerçekleştirilemedi.'); return; }

                if (res.isLiked) {
                    btn.classList.add('liked');
                    icon.classList.remove('far'); icon.classList.add('fas');
                } else {
                    btn.classList.remove('liked');
                    icon.classList.remove('fas'); icon.classList.add('far');
                }
                if (res.likeCount != null) { countEl.textContent = res.likeCount; }
            }).fail(function () {
                btn.dataset.busy = '';
                alert('Bir hata oluştu, tekrar deneyin.');
            });
        }

        // Başarım kategorisini aç/kapat (akordeon)
        function toggleAchCat(headBtn) {
            var cat = headBtn.closest('.pp-ach-cat');
            if (!cat) return;
            var collapsed = cat.classList.toggle('collapsed');
            headBtn.setAttribute('aria-expanded', collapsed ? 'false' : 'true');
        }

        // Tamamlanan başarımın ödülünü manuel topla

        // --- PROFİLDE GÖSTERİLECEK ETİKETİ SEÇ / KALDIR ---
        function toggleProfileTitle(achId, btn) {
            var wasEquipped = btn.classList.contains('equipped');
            // Takılıysa tekrar tıklamak etiketi kaldırır (0 = kaldır)
            var targetId = wasEquipped ? 0 : achId;

            btn.disabled = true;
            var original = btn.innerHTML;
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> <span>Kaydediliyor...</span>';

            fetch('/Profile/EquipTitle', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: 'achievementId=' + targetId
            })
            .then(function (r) { return r.json(); })
            .then(function (res) {
                if (!res.success) {
                    btn.innerHTML = original;
                    btn.disabled = false;
                    alert(res.message);
                    return;
                }

                // Aynı anda yalnızca tek etiket takılı olabilir: diğer düğmeleri sıfırla
                document.querySelectorAll('.pp-ach-title-btn.equipped').forEach(function (other) {
                    other.classList.remove('equipped');
                    other.innerHTML = '<i class="fa-regular fa-id-badge"></i> <span>Profilde göster</span>';
                });

                if (targetId === 0) {
                    btn.innerHTML = '<i class="fa-regular fa-id-badge"></i> <span>Profilde göster</span>';
                } else {
                    btn.classList.add('equipped');
                    btn.innerHTML = '<i class="fa-solid fa-id-badge"></i> <span>Profilde görünüyor</span>';
                }

                btn.disabled = false;
            })
            .catch(function (err) {
                console.error(err);
                btn.innerHTML = original;
                btn.disabled = false;
                alert('Etiket kaydedilirken bir hata oluştu.');
            });
        }

        function claimAchievement(achId, btn) {
            btn.disabled = true;
            var original = btn.innerHTML;
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Toplanıyor...';

            $.post('/Profile/ClaimAchievement', { achievementId: achId }, function (res) {
                if (res.success) {
                    try { sessionStorage.setItem('ppReopenAch', '1'); } catch (e) { }
                    var msg = res.reward > 0 ? ('Ödül toplandı! +' + res.reward + ' 💎') : 'Başarım toplandı!';
                    showToast(msg);
                    setTimeout(function () { location.reload(); }, 750);
                } else {
                    btn.disabled = false;
                    btn.innerHTML = original;
                    alert(res.message || 'İşlem gerçekleştirilemedi.');
                }
            }).fail(function () {
                btn.disabled = false;
                btn.innerHTML = original;
                alert('Bir hata oluştu, tekrar deneyin.');
            });
        }

        // ============================================================
        //  TAKİPÇİ / TAKİP EDİLEN LİSTESİ MODALI
        // ============================================================
        var ppProfileId = @Model.Id;
        var ppLoggedInId = @(ViewBag.LoggedInUserId ?? 0);
        var ppFlModal = null;

        function ppEscapeHtml(str) {
            if (!str) return '';
            return str.replace(/[&<>"']/g, function (c) {
                return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c];
            });
        }

        function openFollowList(type) {
            if (!ppFlModal) {
                ppFlModal = new bootstrap.Modal(document.getElementById('followListModal'));
            }
            switchFollowTab(type);
            ppFlModal.show();
        }

        function switchFollowTab(type) {
            document.getElementById('flTabFollowers').classList.toggle('active', type === 'followers');
            document.getElementById('flTabFollowing').classList.toggle('active', type === 'following');
            loadFollowList(type);
        }

        function loadFollowList(type) {
            var body = document.getElementById('flBody');
            body.innerHTML = '<div class="pp-fl-state"><div class="pp-fl-spinner"></div><p>Yükleniyor...</p></div>';

            fetch('/Profile/FollowList?id=' + ppProfileId + '&type=' + encodeURIComponent(type))
                .then(function (res) { return res.json(); })
                .then(function (data) {
                    if (!data.success) {
                        body.innerHTML = '<div class="pp-fl-state"><i class="fas fa-lock"></i><p>' + ppEscapeHtml(data.message || 'Liste görüntülenemiyor.') + '</p></div>';
                        return;
                    }
                    // Başlıktaki sayıyı gerçek liste uzunluğuyla senkronla
                    var countEl = document.querySelector('#flTab' + (type === 'following' ? 'Following' : 'Followers') + ' b');
                    if (countEl) { countEl.textContent = '(' + (data.count != null ? data.count : data.users.length) + ')'; }

                    if (!data.users || data.users.length === 0) {
                        var emptyMsg = type === 'followers' ? 'Henüz takipçi yok.' : 'Henüz kimseyi takip etmiyor.';
                        body.innerHTML = '<div class="pp-fl-state"><i class="fas fa-user-group"></i><p>' + emptyMsg + '</p></div>';
                        return;
                    }
                    body.innerHTML = data.users.map(renderFollowRow).join('');
                })
                .catch(function () {
                    body.innerHTML = '<div class="pp-fl-state"><i class="fas fa-triangle-exclamation"></i><p>Bir hata oluştu, tekrar deneyin.</p></div>';
                });
        }

        function renderFollowRow(u) {
            var avatarInner = u.profileImageUrl
                ? '<img src="' + ppEscapeHtml(u.profileImageUrl) + '" alt="">'
                : ppEscapeHtml(u.initial);

            var frame = u.frameImageUrl
                ? '<img src="' + ppEscapeHtml(u.frameImageUrl) + '" class="pp-fl-frame" alt="">'
                : '';

            var badge;
            if (u.isSelf) {
                badge = '<span class="pp-fl-badge self">Sen</span>';
            } else if (u.isFollowing) {
                badge = '<button type="button" class="pp-fl-badge following" onclick="toggleFollowFromModal(event, ' + u.id + ', this)">Takiptesin</button>';
            } else if (u.isPending) {
                badge = '<button type="button" class="pp-fl-badge" onclick="toggleFollowFromModal(event, ' + u.id + ', this)">İstek Gönderildi</button>';
            } else {
                badge = '<button type="button" class="pp-fl-badge" onclick="toggleFollowFromModal(event, ' + u.id + ', this)">Takip Et</button>';
            }

            var bio = u.bio ? '<div class="pp-fl-bio">' + ppEscapeHtml(u.bio) + '</div>' : '';

            return '<a href="/Profile/PublicProfile/' + u.id + '" class="pp-fl-row">' +
                       '<div class="pp-fl-avatar-zone">' +
                           '<div class="pp-fl-avatar">' + avatarInner + '</div>' +
                           frame +
                       '</div>' +
                       '<div class="pp-fl-info">' +
                           '<div class="pp-fl-name">' + ppEscapeHtml(u.userName) + '</div>' +
                           bio +
                       '</div>' +
                       badge +
                   '</a>';
        }

        // Modal içindeki rozetten takip et / bırak (satır navigasyonunu engelle)
        function toggleFollowFromModal(evt, targetId, btn) {
            evt.preventDefault();
            evt.stopPropagation();

            btn.disabled = true;
            $.post('/Profile/ToggleFollow', { targetId: targetId }, function (res) {
                btn.disabled = false;
                if (!res.success) { alert(res.message); return; }

                if (res.isFollowing) {
                    btn.textContent = 'Takiptesin';
                    btn.classList.add('following');
                } else if (res.isPending) {
                    btn.textContent = 'İstek Gönderildi';
                    btn.classList.remove('following');
                } else {
                    btn.textContent = 'Takip Et';
                    btn.classList.remove('following');
                }
            }).fail(function () {
                btn.disabled = false;
                alert('İşlem sırasında bir hata oluştu.');
            });
        }

        // ============================================================
        //  TAKİP ET / BIRAK (canlı sayaç güncellemeli)
        // ============================================================
        function toggleFollow(targetId) {
            var btn = $('#btnFollow');
            var icon = btn.find('i');
            var text = $('#followText');
            var counter = $('#followersCount');

            btn.addClass('disabled');

            $.post('/Profile/ToggleFollow', { targetId: targetId }, function (res) {
                btn.removeClass('disabled');
                if (res.success) {
                    var count = parseInt(counter.text()) || 0;

                    if (res.isFollowing) {
                        btn.addClass('following').removeClass('pending');
                        icon.removeClass('fa-user-plus fa-clock').addClass('fa-user-check');
                        text.text('Takiptesin');
                        counter.text(count + 1);
                    } else if (res.isPending) {
                        btn.addClass('pending').removeClass('following');
                        icon.removeClass('fa-user-plus fa-user-check').addClass('fa-clock');
                        text.text('İstek Gönderildi');
                    } else {
                        btn.removeClass('following pending');
                        icon.removeClass('fa-user-check fa-clock').addClass('fa-user-plus');
                        
                        // Önceki durum Takiptesin ise sayacı düşür
                        if (text.text() === 'Takiptesin') {
                            counter.text(Math.max(0, count - 1));
                        }
                        
                        text.text('Takip Et');
                    }
                } else {
                    alert(res.message);
                }
            }).fail(function () {
                btn.removeClass('disabled');
                alert("İşlem sırasında bir hata oluştu.");
            });
        }

        // ============================================================
        //  PROFİL BAĞLANTISINI KOPYALA
        // ============================================================
        function showToast(message) {
            if(message) document.getElementById('ppToastText').innerText = message;
            var toast = document.getElementById('ppToast');
            toast.classList.add('show');
            setTimeout(function () { toast.classList.remove('show'); }, 2200);
        }

        document.getElementById('btnShare').addEventListener('click', function () {
            var url = window.location.href;

            if (navigator.clipboard && navigator.clipboard.writeText) {
                navigator.clipboard.writeText(url).then(function() { showToast("Profil bağlantısı kopyalandı!"); });
            } else {
                // Eski tarayıcılar için geriye dönük yöntem
                var input = document.createElement('input');
                input.value = url;
                document.body.appendChild(input);
                input.select();
                document.execCommand('copy');
                document.body.removeChild(input);
                showToast("Profil bağlantısı kopyalandı!");
            }
        });

        // ============================================================
        //  AVATAR YÜKLEME (INLINE)
        // ============================================================
        let selectedAvatarUrl = "";
        let uploadedFile = null;

        function selectAvatar(imgElement) {
            document.querySelectorAll('.avatar-option').forEach(img => img.classList.remove('selected'));
            imgElement.classList.add('selected');
            selectedAvatarUrl = imgElement.src;
            uploadedFile = null;
        }

        const fileInput = document.getElementById('customAvatarFile');
        if(fileInput){
            fileInput.addEventListener('change', function(event) {
                const file = event.target.files[0];
                if (file) {
                    uploadedFile = file;
                    selectedAvatarUrl = "";
                    const reader = new FileReader();
                    reader.onload = function(e) {
                        document.getElementById('uploadPreview').innerHTML = `<img src="${e.target.result}" style="width:100%; height:100%; object-fit:cover;">`;
                    }
                    reader.readAsDataURL(file);
                }
            });
        }

        const saveAvatarBtn = document.getElementById('saveAvatarBtn');
        if(saveAvatarBtn){
            saveAvatarBtn.addEventListener('click', function() {
                const formData = new FormData();
                if (uploadedFile) {
                    formData.append('file', uploadedFile);
                } else if (selectedAvatarUrl) {
                    formData.append('avatarUrl', selectedAvatarUrl);
                } else {
                    alert("Lütfen bir avatar seçin veya fotoğraf yükleyin.");
                    return;
                }

                const btn = this;
                btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Kaydediliyor...';
                btn.disabled = true;

                fetch('/Profile/UpdateAvatar', {
                    method: 'POST',
                    body: formData
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        location.reload();
                    } else {
                        alert("Hata: " + data.message);
                        btn.innerHTML = 'Kaydet';
                        btn.disabled = false;
                    }
                })
                .catch(error => {
                    console.error('Hata:', error);
                    alert("Bir hata oluştu.");
                    btn.innerHTML = 'Kaydet';
                    btn.disabled = false;
                });
            });
        }

        function toggleBlockUser(userId) {
            fetch('/Profile/ToggleBlock', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: new URLSearchParams({ userId: userId })
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    location.reload();
                } else {
                    alert(data.message);
                }
            })
            .catch(err => {
                console.error(err);
                alert("Bir hata oluştu.");
            });
        }

        function submitReport() {
            var userId = document.getElementById('reportUserId').value;
            var reason = document.getElementById('reportReason').value;
            var details = document.getElementById('reportDetails').value;

            if (!reason) {
                alert("Lütfen bir sebep belirtin.");
                return;
            }

            fetch('/Profile/ReportUser', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: new URLSearchParams({ reportedUserId: userId, reason: reason, details: details })
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    var toast = document.getElementById('ppToast');
                    document.getElementById('ppToastText').innerText = "Şikayetiniz başarıyla gönderildi.";
                    toast.classList.add('show');
                    setTimeout(function () { toast.classList.remove('show'); }, 2200);

                    var reportModal = bootstrap.Modal.getInstance(document.getElementById('reportModal'));
                    reportModal.hide();
                    document.getElementById('reportReason').value = '';
                    document.getElementById('reportDetails').value = '';
                } else {
                    alert(data.message);
                }
            })
            .catch(err => {
                console.error(err);
                alert("Bir hata oluştu.");
            });
        }
    </script>

    <!-- Report Modal -->
    <div class="modal fade" id="reportModal" tabindex="-1" aria-labelledby="reportModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="reportModalLabel">Kullanıcıyı Şikayet Et</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Kapat"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="reportUserId" value="@Model.Id" />
                    <div class="mb-3">
                        <label class="form-label">Şikayet Sebebi</label>
                        <select class="form-select" id="reportReason">
                            <option value="">Lütfen bir sebep seçin</option>
                            <option value="Spam veya Dolandırıcılık">Spam veya Dolandırıcılık</option>
                            <option value="Hakaret, Nefret Söylemi veya Rahatsız Edici İçerik">Hakaret, Nefret Söylemi veya Rahatsız Edici İçerik</option>
                            <option value="Sahte Hesap">Sahte Hesap</option>
                            <option value="Uygunsuz İçerik">Uygunsuz İçerik</option>
                            <option value="Diğer">Diğer</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Açıklama (İsteğe bağlı)</label>
                        <textarea class="form-control" id="reportDetails" rows="3" placeholder="Daha fazla detay ekleyebilirsiniz..." maxlength="500"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                    <button type="button" class="btn btn-da--+-nger" onclick="submitReport()">Şikayet Et</button>
                </div>
            </div>
        </div>
    </div>
}

