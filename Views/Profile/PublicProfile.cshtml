                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="text-center py-4">
                                    <i class="fa-solid fa-image" style="font-size: 2.5rem; color: #e8dcc8; margin-bottom: 10px;"></i>
                                    <p style="color: #8b6f47; font-size: 0.9rem;">Henüz bir arka planın yok!</p>
                                    <a asp-controller="Store" asp-action="Index" asp-area="" class="btn btn-sm" style="background: linear-gradient(135deg, #8b6f47, #6b5541); color: #fff; border-radius: 20px; padding: 8px 20px; font-weight: 600;">Mağazaya Git</a>
                                </div>
                            }
                        </div>
                    </div>
                </div>
                <div class="modal-footer" style="border-top: none;">
                    <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">İptal</button>
                    <button type="button" class="btn btn-sm" id="saveAvatarBtn" style="background: linear-gradient(135deg, #8b6f47, #6b5541); color: #fff; border-radius: 20px; padding: 8px 25px; border: none;">Kaydet</button>
                </div>
            </div>
        </div>
    </div>
}

