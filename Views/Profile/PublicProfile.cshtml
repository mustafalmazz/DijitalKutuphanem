                            else
                            {
                                <div class="text-center py-4">
                                    <i class="fa-solid fa-store" style="font-size: 2.5rem; color: #e8dcc8; margin-bottom: 10px;"></i>
                                    <p style="color: #8b6f47; font-size: 0.9rem;">Henüz çerçeven yok!</p>
                                    <a asp-controller="Store" asp-action="Index" asp-area="" class="btn btn-sm" style="background: linear-gradient(135deg, #8b6f47, #6b5541); color: #fff; border-radius: 20px; padding: 8px 20px; font-weight: 600;">Mağazaya Git</a>
                                </div>
                            }
                        </div>

                        <div class="tab-pane fade" id="banner-pane" role="tabpanel">
                            @{
                                var ppOwnedBanners = ViewBag.Banners as List<BookManagementApp.Models.ProfileBanner>;
                                var ppActiveBannerId = Model.ActiveBannerId;
                            }
                            @if (ppOwnedBanners != null && ppOwnedBanners.Any())
                            {
                                <div class="text-center mb-2 text-muted small">Sahip olduğun arka planlardan birini seç:</div>
                                <div class="text-center mt-2 mb-3">
                                    <button type="button" class="btn btn-sm" onclick="equipBannerPP(0, this)" style="background: #e8dcc8; color: #6b5541; border-radius: 20px; font-size: 0.8rem; font-weight: 600;">Arka Planı Kaldır</button>
                                </div>
                                <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; padding: 10px 0; max-height: 250px; overflow-y: auto; overflow-x: hidden;">
                                    @foreach (var ppBanner in ppOwnedBanners)
                                    {
                                        bool ppIsEquipped = ppActiveBannerId == ppBanner.Id;
                                        <div style="border: 2px solid @(ppIsEquipped ? "#a0785a" : "#e8dcc8"); border-radius: 8px; overflow: hidden;">
                                            <img src="@ppBanner.ImageUrl" alt="@ppBanner.Name" style="width: 100%; height: 60px; object-fit: cover; display: block;" />
                                            <div style="padding: 5px; background: #fff8f0; text-align: center;">
                                                <div style="font-weight: 600; font-size: 0.78rem; color: #4a3f35;">@ppBanner.Name</div>
                                                <button type="button" class="btn btn-sm mt-1"
                                                        style="width: 100%; border-radius: 15px; font-size: 0.72rem; font-weight: 600; @(ppIsEquipped ? "background: #a0785a; color: white;" : "background: #e8dcc8; color: #6b5541;")"
