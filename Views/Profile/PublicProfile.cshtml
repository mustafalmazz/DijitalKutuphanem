        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="background: #fff9f0; border-radius: 20px; border: none;">
                <div class="modal-header" style="border-bottom: 1px solid rgba(139, 111, 71, 0.2);">
