                    .pp-book-title {
                        font-size: 0.8rem;
                        font-weight: 700;
                        color: #4a3f35;
                        white-space: nowrap;
                        overflow: hidden;
                        text-overflow: ellipsis;
                        margin-bottom: 3px;
