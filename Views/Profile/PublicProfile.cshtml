@model BookManagementApp.Areas.Admin.Models.User
@{
    ViewData["Title"] = Model.UserName + " - Profil";

    // ============================================================
    //  DİNAMİK HESAPLAMALAR (backend değişikliği gerektirmez)
    // ============================================================

    // Üyelik süresi
    int memberDays = (int)(DateTime.Now - Model.CreateDate).TotalDays;
    if (memberDays < 1) { memberDays = 1; }

    // Profilde gösterilen etiket: kullanıcının kendi seçtiği başarım.
    // (Eski taş bazlı seviye sistemi kaldırıldı; taş harcanabilir olduğu için seviye geri düşüyordu.)
    var activeTitle = Model.UserAchievements?
        .FirstOrDefault(ua => ua.AchievementId == Model.ActiveTitleAchievementId)?.Achievement;

    // Seri durumuna göre rozet
    string streakLabel = Model.CurrentStreak >= 30 ? "Demir Disiplin"
                       : Model.CurrentStreak >= 7 ? "İstikrarlı"
                       : Model.CurrentStreak >= 1 ? "Yolun Başında"
                       : "Seri Bekleniyor";
}

<style>
    /* ============================================================
                   GENEL SAYFA
                   ============================================================ */
    html, body {
        overflow-x: hidden;
        max-width: 100%;
    }

    body {
        background: linear-gradient(135deg, #f5f0e8 0%, #e8dcc8 100%);
        font-family: 'Georgia', serif;
        color: #4a3f35;
    }

    .pp-page {
        min-height: 100vh;
        padding: 30px 0 90px;
    }

    .pp-wrap {
        max-width: 820px;
        margin: 0 auto;
        padding: 0 20px;
    }

    /* Giriş animasyonları */
    @@keyframes ppFadeUp {
        from {
            opacity: 0;
            transform: translateY(24px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes ppFadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    .pp-anim-1 {
        animation: ppFadeUp 0.55s ease-out both;
    }

    .pp-anim-2 {
        animation: ppFadeUp 0.55s 0.12s ease-out both;
    }

    .pp-anim-3 {
        animation: ppFadeUp 0.55s 0.24s ease-out both;
    }

    @@media (prefers-reduced-motion: reduce) {
        .pp-anim-1, .pp-anim-2, .pp-anim-3 {
            animation: none;
        }
    }

    /* ============================================================
                   HERO (KAPAK)
                   ============================================================ */
    .pp-hero {
        background: linear-gradient(135deg, #3d3329 0%, #5c4936 35%, #8b6f47 75%, #a0785a 100%);
        background-size: cover;
        background-position: center;
        height: 190px;
        border-radius: 28px 28px 0 0;
        position: relative;
        overflow: hidden;
        box-shadow: 0 4px 20px rgba(0,0,0,0.15);
    }

        /* Banner takılıyken süsleme katmanları kapatılır, görsel temiz görünür */
        .pp-hero.has-banner::before,
        .pp-hero.has-banner::after,
        .pp-hero.has-banner .pp-hero-dust {
            display: none;
        }

        /* Altın ışık huzmeleri */
        .pp-hero::before {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(circle at 20% 65%, rgba(255,215,130,0.18) 0%, transparent 45%), radial-gradient(circle at 78% 30%, rgba(255,215,130,0.12) 0%, transparent 50%);
        }

        /* Kitap sırtı deseni hissi */
        .pp-hero::after {
            content: '';
            position: absolute;
            inset: 0;
            background: repeating-linear-gradient(90deg, transparent, transparent 70px, rgba(245,240,232,0.035) 70px, rgba(245,240,232,0.035) 73px);
        }

    /* Hero üzerinde süzülen parçacıklar */
    .pp-hero-dust {
        position: absolute;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(255,225,160,0.9), rgba(255,200,110,0.3));
        pointer-events: none;
        animation: ppDust 7s linear infinite;
        opacity: 0;
    }

        .pp-hero-dust:nth-child(1) {
            left: 12%;
            bottom: 10%;
            width: 6px;
            height: 6px;
            animation-delay: 0s;
        }

        .pp-hero-dust:nth-child(2) {
            left: 35%;
            bottom: 5%;
            width: 4px;
            height: 4px;
            animation-delay: 1.6s;
        }

        .pp-hero-dust:nth-child(3) {
            left: 58%;
            bottom: 12%;
            width: 5px;
            height: 5px;
            animation-delay: 3.2s;
        }

        .pp-hero-dust:nth-child(4) {
            left: 80%;
            bottom: 8%;
            width: 4px;
            height: 4px;
            animation-delay: 4.8s;
        }

    @@keyframes ppDust {
        0% {
            transform: translateY(0) scale(1);
            opacity: 0;
        }

        15% {
            opacity: 0.85;
        }

        100% {
            transform: translateY(-160px) scale(0.3);
            opacity: 0;
        }
    }

    /* ============================================================
                   ANA KART
                   ============================================================ */
    .pp-card {
        background: #fff9f0;
        border-radius: 0 0 28px 28px;
        box-shadow: 0 18px 55px rgba(107, 85, 65, 0.22);
        border: 1px solid rgba(139, 111, 71, 0.15);
        border-top: none;
    }

    .pp-card-top {
        padding: 0 34px 26px;
        text-align: center;
        position: relative;
        z-index: 20; /* Açılan 3 nokta menüsü alttaki sekme bölümünün üstünde kalsın */
    }

    /* ============================================================
                   AVATAR — KARE, ÇERÇEVEYE UYUMLU (daireye zorlanmaz)
                   ============================================================ */
    .pp-avatar-zone {
        position: relative;
        display: inline-block;
        margin-top: -78px;
        margin-bottom: 14px;
        z-index: 5;
    }

    .pp-avatar-box {
        width: 150px;
        height: 150px;
        border-radius: 18px; /* Mağazadaki önizlemeyle aynı form */
        background: linear-gradient(135deg, #fff9f0 0%, #e6dac8 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3.4rem;
        font-weight: 700;
        color: #5c4b3d;
        box-shadow: 0 12px 32px rgba(74, 63, 53, 0.35);
        border: 4px solid #fff9f0;
        overflow: hidden;
        position: relative;
    }

        .pp-avatar-box img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    /* Çerçeve overlay — orijinal oranında, kırpılmadan biner */
    .pp-frame-overlay {
        position: absolute;
        top: -15%;
        left: -15%;
        width: 130%;
        height: 130%;
        pointer-events: none;
        z-index: 10;
        object-fit: contain;
    }

    /* ============================================================
                   İSİM, SEVİYE ROZETİ, KATILIM
                   ============================================================ */
    .pp-name {
        font-size: 2rem;
        font-weight: 800;
        color: #4a3f35;
        margin-bottom: 8px;
        letter-spacing: 0.5px;
        /* Uzun kullanıcı adı sağa taşmasın, alta insin */
        overflow-wrap: anywhere;
        word-break: break-word;
        max-width: 100%;
    }

    .pp-title-badge {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        /* Kahverengiye geçiş etiketi söndürüyordu; artık rozet kendi renginin
           açık ve koyu tonu arasında kalıyor, böylece canlılığını koruyor. */
        background: linear-gradient(135deg,
            color-mix(in srgb, var(--title-color) 82%, #fff) 0%,
            var(--title-color) 45%,
            color-mix(in srgb, var(--title-color) 62%, #1d1712) 100%);
        color: #fff;
        text-shadow: 0 1px 3px rgba(0, 0, 0, 0.45);
        padding: 6px 18px;
        border-radius: 50px;
        font-size: 0.82rem;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        box-shadow: 0 6px 18px color-mix(in srgb, var(--title-color) 45%, transparent);
        margin-bottom: 12px;
        position: relative;
        overflow: hidden;
    }

        /* Rozet üzerinde kayan parlama */
        .pp-title-badge::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(115deg, transparent 35%, rgba(255,255,255,0.35) 50%, transparent 65%);
            background-size: 250% 250%;
            animation: ppBadgeShine 3.4s ease-in-out infinite;
        }

    @@keyframes ppBadgeShine {
        0% {
            background-position: 140% 140%;
        }

        55%, 100% {
            background-position: -60% -60%;
        }
    }

    .pp-join {
        color: #8b6f47;
        font-style: italic;
        font-size: 0.92rem;
        margin-bottom: 4px;
    }

    .pp-member-days {
        color: #a08b6d;
        font-size: 0.8rem;
        margin-bottom: 16px;
    }

        .pp-member-days b {
            color: #8b6f47;
        }

    /* ============================================================
                   SAYAÇLAR — kutusuz, tek satır, zarif ayraçlı
                   ============================================================ */
    .pp-counters {
        display: flex;
        justify-content: center;
        align-items: baseline;
        gap: 14px;
        margin-bottom: 18px;
        font-size: 0.86rem;
        color: #8b6f47;
        letter-spacing: 0.3px;
    }

    .pp-counter {
        display: inline-flex;
        align-items: baseline;
        gap: 6px;
    }

    /* Tıklanabilir sayaç (takipçi / takip edilen) */
    .pp-counter-btn {
        background: none;
        border: none;
        font-family: inherit;
        color: inherit;
        cursor: pointer;
        padding: 4px 8px;
        border-radius: 12px;
        transition: background 0.2s ease, transform 0.2s ease;
    }

        .pp-counter-btn:hover {
            background: rgba(139, 111, 71, 0.1);
            transform: translateY(-1px);
        }

        .pp-counter-btn.pp-counter-locked {
            cursor: default;
            opacity: 0.75;
        }

            .pp-counter-btn.pp-counter-locked:hover {
                background: none;
                transform: none;
            }

    .pp-counter-value {
        font-size: 1.2rem;
        font-weight: 800;
        color: #6b5541;
        line-height: 1;
    }

    .pp-counter-label {
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 1.2px;
        font-weight: 600;
    }

    .pp-counter-sep {
        width: 4px;
        height: 4px;
        border-radius: 50%;
        background: rgba(139, 111, 71, 0.35);
        align-self: center;
    }

    /* ============================================================
                   AKSİYON BUTONLARI — her ekranda tek satır
                   ============================================================ */
    .pp-actions {
        display: flex;
        justify-content: center;
        align-items: stretch;
        gap: 10px;
        max-width: 480px;
        margin: 0 auto;
    }

        /* 3 nokta menüsü: Popper'ın sayfayı yana taşırmasını engelle,
           menü her zaman butonun sağ kenarına hizalı ve sola doğru açılır */
        .pp-actions .dropdown-menu {
            position: absolute !important;
            inset: auto !important;
            top: 100% !important;
            right: 0 !important;
            left: auto !important;
            transform: none !important;
            margin-top: 6px !important;
            z-index: 3000 !important; /* Menü her zaman en üstte görünsün */
        }

    .pp-btn {
        border-radius: 50px;
        padding: 11px 26px;
        font-family: 'Georgia', serif;
        font-weight: 700;
        font-size: 0.9rem;
        letter-spacing: 0.4px;
        cursor: pointer;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        text-decoration: none;
        border: 2px solid transparent;
        white-space: nowrap;
    }

    .pp-btn-follow {
        background: linear-gradient(135deg, #8b6f47 0%, #6b5541 100%);
        color: #f5f0e8;
        box-shadow: 0 6px 18px rgba(107, 85, 65, 0.32);
    }

        .pp-btn-follow:hover {
            background: linear-gradient(135deg, #a0785a 0%, #8b6f47 100%);
            transform: translateY(-2px);
            box-shadow: 0 10px 24px rgba(107, 85, 65, 0.42);
        }

        .pp-btn-follow.following {
            background: transparent;
            color: #8b6f47;
            border-color: #8b6f47;
            box-shadow: none;
        }

            .pp-btn-follow.following:hover {
                background: rgba(139, 111, 71, 0.08);
            }

        .pp-btn-follow.disabled {
            opacity: 0.6;
            pointer-events: none;
        }

    .pp-btn-message {
        background: transparent;
        color: #8b6f47;
        border-color: #cda45e;
    }

        .pp-btn-message:hover {
            background: linear-gradient(135deg, #cda45e, #b8935a);
            color: #fff;
            border-color: transparent;
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(205, 164, 94, 0.35);
        }

    /* Paylaş: her zaman kompakt daire ikon */
    .pp-share-wrapper {
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .pp-btn-share {
        background: transparent;
        color: #a08b6d;
        border-color: rgba(139, 111, 71, 0.35);
        width: 46px;
        height: 46px;
        padding: 0;
        border-radius: 50%;
        flex: 0 0 46px;
    }

        .pp-btn-share:hover {
            color: #6b5541;
            border-color: #8b6f47;
            transform: translateY(-2px);
        }

    /* ============================================================
                   SEVİYE İLERLEME BÖLÜMÜ
                   ============================================================ */
    .pp-level-section {
        margin: 26px auto 0;
        max-width: 520px;
        background: #fff;
        border: 1px solid rgba(139, 111, 71, 0.14);
        border-radius: 18px;
        padding: 18px 22px;
        box-shadow: 0 4px 16px rgba(107, 85, 65, 0.08);
        text-align: left;
    }

    .pp-level-head {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 10px;
        gap: 10px;
        flex-wrap: wrap;
    }

    .pp-level-name {
        font-weight: 700;
        color: #4a3f35;
        font-size: 0.95rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .pp-level-name i {
            color: #cda45e;
        }

    .pp-level-next {
        font-size: 0.75rem;
        color: #8b6f47;
        font-style: italic;
    }

    .pp-progress-track {
        background: #efe6d6;
        border-radius: 12px;
        height: 14px;
        overflow: hidden;
        box-shadow: inset 0 2px 4px rgba(107, 85, 65, 0.12);
    }

    .pp-progress-fill {
        height: 100%;
        width: 0%; /* JS animasyonla dolar */
        border-radius: 12px;
        background: linear-gradient(90deg, #cda45e, #ffd782, #cda45e);
        background-size: 200% 100%;
        transition: width 1.2s cubic-bezier(0.25, 0.8, 0.35, 1);
        animation: ppProgressFlow 3s linear infinite;
        position: relative;
    }

    @@keyframes ppProgressFlow {
        from {
            background-position: 0% 0;
        }

        to {
            background-position: 200% 0;
        }
    }

    .pp-progress-percent {
        text-align: right;
        font-size: 0.72rem;
        color: #a08b6d;
        margin-top: 6px;
        font-weight: 600;
    }

    /* ============================================================
                   İSTATİSTİK KAROLARI
                   ============================================================ */
    .pp-stats {
        background: linear-gradient(180deg, #f5ede0 0%, #efe4d1 100%);
        border-top: 1px solid rgba(139, 111, 71, 0.12);
        border-radius: 0 0 28px 28px;
        padding: 24px 34px 30px;
    }

    .pp-stats-title {
        color: #4a3f35;
        font-weight: 700;
        font-size: 1.1rem;
        margin-bottom: 16px;
        display: flex;
        align-items: center;
        gap: 9px;
    }

        .pp-stats-title i {
            color: #cda45e;
        }

    .pp-stats-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 14px;
    }

    .pp-tile {
        background: #fff9f0;
        border-radius: 18px;
        padding: 18px 12px 16px;
        text-align: center;
        border: 1px solid rgba(139, 111, 71, 0.12);
        box-shadow: 0 4px 14px rgba(107, 85, 65, 0.08);
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }

        .pp-tile::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: linear-gradient(90deg, transparent, #ffd782, transparent);
        }

        .pp-tile:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 26px rgba(107, 85, 65, 0.16);
            border-color: rgba(205, 164, 94, 0.4);
        }

    .pp-tile-icon {
        width: 46px;
        height: 46px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        margin: 0 auto 10px;
        color: #fff;
        box-shadow: 0 5px 12px rgba(0,0,0,0.14);
        flex-shrink: 0;
    }

    .pp-tile-fire .pp-tile-icon {
        background: linear-gradient(135deg, #ff9a56, #e2643b);
    }

    .pp-tile-gem .pp-tile-icon {
        background: linear-gradient(135deg, #56c4d8, #2e93a8);
    }

    .pp-tile-cal .pp-tile-icon {
        background: linear-gradient(135deg, #a0785a, #7a5c3e);
    }

    .pp-tile-level .pp-tile-icon {
        background: linear-gradient(135deg, #ffd782, #d9a441);
        color: #6b4a12;
    }

    .pp-tile-value {
        font-size: 1.3rem;
        font-weight: 800;
        color: #4a3f35;
        margin-bottom: 2px;
        line-height: 1.2;
    }

    .pp-tile-label {
        font-size: 0.76rem;
        color: #8b6f47;
        font-style: italic;
    }

    .pp-tile-sub {
        display: inline-block;
        margin-top: 8px;
        font-size: 0.64rem;
        font-weight: 700;
        letter-spacing: 0.5px;
        color: #8b6f47;
        background: rgba(139, 111, 71, 0.1);
        padding: 3px 10px;
        border-radius: 20px;
        text-transform: uppercase;
        white-space: nowrap;
    }

    /* ============================================================
                   KOPYALAMA TOAST'I
                   ============================================================ */
    .pp-toast {
        position: fixed;
        bottom: 28px;
        left: 50%;
        transform: translateX(-50%) translateY(80px);
        background: linear-gradient(135deg, #6b5541, #4a3f35);
        color: #f5f0e8;
        padding: 12px 26px;
        border-radius: 50px;
        font-family: 'Georgia', serif;
        font-size: 0.88rem;
        font-weight: 600;
        box-shadow: 0 10px 30px rgba(0,0,0,0.3);
        opacity: 0;
        pointer-events: none;
        transition: all 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
        z-index: 9999;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .pp-toast.show {
            transform: translateX(-50%) translateY(0);
            opacity: 1;
        }

        .pp-toast i {
            color: #ffd782;
        }

    /* ============================================================
                   RESPONSIVE — MOBİL
                   ============================================================ */
    @@media (max-width: 768px) {
        .pp-page {
            padding: 14px 0 60px;
        }

        .pp-wrap {
            padding: 0 12px;
        }

        .pp-hero {
            height: 140px;
            border-radius: 20px 20px 0 0;
        }

        .pp-card {
            border-radius: 0 0 20px 20px;
        }

        .pp-card-top {
            padding: 0 16px 20px;
        }

        .pp-avatar-zone {
            margin-top: -64px;
        }

        .pp-avatar-box {
            width: 126px;
            height: 126px;
            border-radius: 15px;
            font-size: 2.8rem;
        }

        .pp-name {
            font-size: 1.55rem;
        }

        .pp-title-badge {
            font-size: 0.72rem;
            padding: 5px 14px;
        }

        .pp-join {
            font-size: 0.84rem;
        }

        .pp-member-days {
            font-size: 0.74rem;
            margin-bottom: 14px;
        }

        .pp-counters {
            gap: 12px;
            margin-bottom: 16px;
        }

        .pp-counter-value {
            font-size: 1.1rem;
        }

        .pp-counter-label {
            font-size: 0.66rem;
            letter-spacing: 1px;
        }
        /* Butonlar tek satırda kalır: ikisi alanı paylaşır, paylaş ikon olarak sabit */
        .pp-actions {
            gap: 8px;
        }

        .pp-btn-follow,
        .pp-btn-message {
            flex: 1 1 0;
            min-width: 0;
            padding: 11px 8px;
            font-size: 0.82rem;
        }

        .pp-btn-share {
            width: 42px;
            height: 42px;
            flex: 0 0 42px;
            align-self: center;
        }

        .pp-level-section {
            padding: 15px 16px;
            border-radius: 15px;
        }

        .pp-level-name {
            font-size: 0.86rem;
        }

        .pp-level-next {
            font-size: 0.68rem;
        }

        .pp-stats {
            padding: 18px 14px 20px;
            border-radius: 0 0 20px 20px;
        }

        .pp-stats-title {
            font-size: 1rem;
            margin-bottom: 12px;
        }
        /* Karolar mobilde zarif yatay satırlara dönüşür */
        .pp-stats-grid {
            grid-template-columns: 1fr;
            gap: 10px;
        }

        .pp-tile {
            display: flex;
            align-items: center;
            gap: 14px;
            text-align: left;
            padding: 12px 14px;
            border-radius: 14px;
        }

            .pp-tile:hover {
                transform: none; /* Dokunmatikte kayma yok */
            }

            .pp-tile::before {
                width: 3px;
                height: auto;
                bottom: 0;
                right: auto;
                background: linear-gradient(180deg, transparent, #ffd782, transparent);
            }

        .pp-tile-icon {
            width: 40px;
            height: 40px;
            font-size: 1rem;
            margin: 0;
            border-radius: 12px;
        }

        .pp-tile-body {
            flex: 1;
            min-width: 0;
        }

        .pp-tile-value {
            font-size: 1.05rem;
            margin-bottom: 0;
        }

        .pp-tile-label {
            font-size: 0.72rem;
        }

        .pp-tile-sub {
            margin-top: 0;
            font-size: 0.6rem;
        }
    }

    /* ============================================================
                   RESPONSIVE — ÇOK KÜÇÜK EKRANLAR
                   ============================================================ */
    @@media (max-width: 380px) {
        .pp-avatar-box {
            width: 112px;
            height: 112px;
        }

        .pp-avatar-zone {
            margin-top: -58px;
        }

        .pp-name {
            font-size: 1.35rem;
        }

        .pp-btn-follow,
        .pp-btn-message {
            font-size: 0.76rem;
            padding: 10px 6px;
        }

            .pp-btn-follow i,
            .pp-btn-message i {
                display: none; /* Çok dar ekranda metin öncelikli */
            }

        .pp-btn-share {
            width: 40px;
            height: 40px;
            flex: 0 0 40px;
        }
    }

    /* Basarimlar (pp-ach-*) stilleri _ProfileAchievements.cshtml partial'ina tasindi. */

    /* ============================================================
                   TAKİPÇİ / TAKİP LİSTESİ MODALI
                   ============================================================ */
    .pp-fl-modal .modal-content {
        background: #fff9f0;
        border: none;
        border-radius: 22px;
        box-shadow: 0 20px 60px rgba(74, 63, 53, 0.3);
        overflow: hidden;
    }

    .pp-fl-header {
        display: flex;
        align-items: center;
        gap: 4px;
        padding: 8px 14px 0;
        border-bottom: 1px solid rgba(139, 111, 71, 0.12);
        position: relative;
    }

    .pp-fl-tab {
        flex: 1;
        background: none;
        border: none;
        font-family: 'Georgia', serif;
        font-weight: 700;
        font-size: 0.9rem;
        color: #a08b6d;
        padding: 14px 8px;
        cursor: pointer;
        position: relative;
        transition: color 0.2s ease;
    }

        .pp-fl-tab:hover {
            color: #6b5541;
        }

        .pp-fl-tab.active {
            color: #4a3f35;
        }

            .pp-fl-tab.active::after {
                content: '';
                position: absolute;
                left: 18%;
                right: 18%;
                bottom: -1px;
                height: 3px;
                border-radius: 3px;
                background: linear-gradient(90deg, #cda45e, #8b6f47);
            }

    .pp-fl-tab b {
        color: #8b6f47;
    }

    .pp-fl-close {
        position: absolute;
        top: 10px;
        right: 12px;
        background: none;
        border: none;
        color: #a08b6d;
        font-size: 1.1rem;
        cursor: pointer;
        width: 32px;
        height: 32px;
        border-radius: 50%;
        transition: background 0.2s ease;
        z-index: 2;
    }

        .pp-fl-close:hover {
            background: rgba(139, 111, 71, 0.12);
            color: #4a3f35;
        }

    .pp-fl-body {
        max-height: 60vh;
        overflow-y: auto;
        padding: 8px 10px 14px;
    }

    /* Kaydırma çubuğu — zarif */
    .pp-fl-body::-webkit-scrollbar {
        width: 6px;
    }

    .pp-fl-body::-webkit-scrollbar-thumb {
        background: rgba(139, 111, 71, 0.3);
        border-radius: 6px;
    }

    /* Kullanıcı satırı */
    .pp-fl-row {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 9px 12px;
        border-radius: 15px;
        text-decoration: none;
        color: inherit;
        transition: background 0.18s ease;
    }

        .pp-fl-row:hover {
            background: rgba(139, 111, 71, 0.07);
        }

    .pp-fl-avatar-zone {
        position: relative;
        width: 52px;
        height: 52px;
        flex-shrink: 0;
    }

    .pp-fl-avatar {
        width: 52px;
        height: 52px;
        border-radius: 14px;
        background: linear-gradient(135deg, #fff9f0 0%, #e6dac8 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.3rem;
        font-weight: 700;
        color: #5c4b3d;
        overflow: hidden;
        box-shadow: 0 3px 10px rgba(74, 63, 53, 0.18);
    }

        .pp-fl-avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .pp-fl-frame {
        position: absolute;
        top: -16%;
        left: -16%;
        width: 132%;
        height: 132%;
        pointer-events: none;
        object-fit: contain;
        z-index: 2;
    }

    .pp-fl-info {
        flex: 1;
        min-width: 0;
    }

    .pp-fl-name {
        font-weight: 700;
        color: #4a3f35;
        font-size: 0.92rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .pp-fl-bio {
        font-size: 0.76rem;
        color: #a08b6d;
        font-style: italic;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .pp-fl-badge {
        flex-shrink: 0;
        font-family: 'Georgia', serif;
        font-size: 0.7rem;
        font-weight: 700;
        padding: 6px 14px;
        border-radius: 50px;
        border: 1.5px solid #8b6f47;
        color: #8b6f47;
        background: transparent;
        white-space: nowrap;
        cursor: pointer;
        transition: background 0.2s ease, color 0.2s ease;
    }

        button.pp-fl-badge:hover {
            background: #8b6f47;
            color: #fff9f0;
        }

        .pp-fl-badge.following {
            background: rgba(139, 111, 71, 0.1);
            border-style: solid;
        }

        .pp-fl-badge.self {
            border: none;
            color: #a08b6d;
            background: transparent;
            cursor: default;
        }

    /* Durum ekranları (yükleniyor / boş / hata) */
    .pp-fl-state {
        text-align: center;
        padding: 46px 20px;
        color: #a08b6d;
    }

        .pp-fl-state i {
            font-size: 2.4rem;
            color: #d4c5b0;
            margin-bottom: 12px;
        }

        .pp-fl-state p {
            font-size: 0.9rem;
            margin: 0;
        }

    .pp-fl-spinner {
        width: 34px;
        height: 34px;
        border: 3px solid rgba(139, 111, 71, 0.2);
        border-top-color: #8b6f47;
        border-radius: 50%;
        margin: 0 auto 14px;
        animation: ppFlSpin 0.8s linear infinite;
    }

    @@keyframes ppFlSpin {
        to {
            transform: rotate(360deg);
        }
    }

    @@media (max-width: 768px) {
        .pp-fl-modal .modal-content {
            border-radius: 18px;
        }

        .pp-fl-body {
            max-height: 65vh;
        }

        .pp-fl-avatar-zone,
        .pp-fl-avatar {
            width: 46px;
            height: 46px;
        }
    }
</style>

<div class="pp-page">
    <div class="pp-wrap">

        <!-- ============ HERO (KAPAK) ============ -->
        @{
            // Takılı banner varsa kapak onunla değişir; ışık huzmesi/toz animasyonları
            // görseli gölgelememek için yalnızca varsayılan gradyanda gösterilir.
            var heroBannerUrl = Model.ActiveBanner?.ImageUrl;
        }
        <div class="pp-hero pp-anim-1 @(heroBannerUrl != null ? "has-banner" : "")"
             style="@(heroBannerUrl != null ? $"background-image: url('{heroBannerUrl}');" : "")">
            <span class="pp-hero-dust"></span>
            <span class="pp-hero-dust"></span>
            <span class="pp-hero-dust"></span>
            <span class="pp-hero-dust"></span>
        </div>

        <!-- ============ ANA KART ============ -->
        <div class="pp-card">

            <div class="pp-card-top pp-anim-2">

                <!-- AVATAR (kare, çerçeve orijinal formuyla üstünde) -->
                <div class="pp-avatar-zone" @(ViewBag.LoggedInUserId == Model.Id ? Html.Raw("style=\"cursor:pointer;\" data-bs-toggle=\"modal\" data-bs-target=\"#avatarModal\"") : Html.Raw(""))>
                    <div class="pp-avatar-box">
                        @if (!string.IsNullOrEmpty(Model.ProfileImageUrl))
                        {
                            <img src="@Model.ProfileImageUrl" alt="@Model.UserName" />
                        }
                        else
                        {
                            @(Model.UserName?.Substring(0, 1).ToUpper())
                        }
                        @if (ViewBag.LoggedInUserId == Model.Id)
                        {
                            <div style="position: absolute; bottom: -5px; right: -5px; background: #8b6f47; color: #fff; width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; border: 3px solid #fff9f0; z-index: 15; box-shadow: 0 4px 10px rgba(0,0,0,0.1);">
                                <i class="fa-solid fa-camera" style="font-size: 0.9rem;"></i>
                            </div>
                        }
                    </div>

                    @if (!string.IsNullOrEmpty(Model.ActiveFrameImageUrl))
                    {
                        <img src="@Model.ActiveFrameImageUrl" class="pp-frame-overlay" alt="" />
                    }
                </div>

                <!-- İSİM & ETİKET -->
                <h1 class="pp-name">@Model.UserName</h1>
                @if (activeTitle != null)
                {
                    string[] tierNames = { "", "Bronz", "Gümüş", "Altın", "Platin", "Elmas", "Efsane" };
                    var tierLabel = tierNames[Math.Clamp(activeTitle.Tier, 1, 6)];

                    <div class="pp-title-badge js-title-badge"
                         style="--title-color: @(activeTitle.ColorHex ?? "#8b6f47");"
                         role="button" tabindex="0"
                         data-title-name="@activeTitle.Name"
                         data-title-desc="@activeTitle.Description"
                         data-title-icon="@activeTitle.IconClass"
                         data-title-color="@(activeTitle.ColorHex ?? "#8b6f47")"
                         data-title-tier="@tierLabel">
                        <i class="fa-solid @activeTitle.IconClass"></i>
                        <span>@activeTitle.Name</span>
                    </div>
                }

                <!-- SAYACLAR (kompakt, tek satır) -->
                @{
                    // Takipçi/takip listesi yalnızca liste görülebilir olduğunda tıklanabilir olur
                    bool ppCanSeeLists = ViewBag.LoggedInUserId == Model.Id || ViewBag.IsPrivate != true || ViewBag.IsFollowing == true;
                }
                <div class="pp-counters">
                    <button type="button" class="pp-counter pp-counter-btn @(ppCanSeeLists ? "" : "pp-counter-locked")"
                    @(ppCanSeeLists ? Html.Raw($"onclick=\"openFollowList('followers')\"") : Html.Raw("disabled"))>
                        <span class="pp-counter-value pp-countup" id="followersCount" data-target="@ViewBag.FollowersCount">0</span>
                        <span class="pp-counter-label">Takipçi</span>
                    </button>
                    <span class="pp-counter-sep"></span>
                    <button type="button" class="pp-counter pp-counter-btn @(ppCanSeeLists ? "" : "pp-counter-locked")"
                    @(ppCanSeeLists ? Html.Raw($"onclick=\"openFollowList('following')\"") : Html.Raw("disabled"))>
                        <span class="pp-counter-value pp-countup" id="followingCount" data-target="@ViewBag.FollowingCount">0</span>
                        <span class="pp-counter-label">Takip Edilen</span>
                    </button>
                    <span class="pp-counter-sep"></span>
                    <span class="pp-counter">
                        <span class="pp-counter-value pp-countup" data-target="@ViewBag.BookCount">0</span>
                        <span class="pp-counter-label">Kitap</span>
                    </span>
                </div>

              

                @if (!string.IsNullOrEmpty(Model.Bio))
                {
                    <p class="pp-bio text-muted mt-2 mb-3 px-3" style="font-style: italic; max-width: 600px; margin-left: auto; margin-right: auto; line-height: 1.5; font-size: 0.95rem;">
                        "@Model.Bio"
                    </p>
                }

               

                <!-- AKSİYONLAR -->
                <div class="pp-actions">
                    @if (ViewBag.LoggedInUserId == Model.Id)
                    {
                        <button type="button" class="pp-btn pp-btn-follow" data-bs-toggle="modal" data-bs-target="#editProfileModalInline" style="background: linear-gradient(135deg, #8b6f47, #6b5541); color: #fff; flex: 1 1 auto;">
                            <i class="fas fa-user-pen"></i> Profili Düzenle
                        </button>
                        <button type="button" class="pp-btn pp-btn-share position-relative" onclick="openRequestsModal()" title="Takip İstekleri">
                            <i class="fa-solid fa-bell"></i>
                            <span id="ppRequestsBadge" class="badge bg-danger rounded-pill position-absolute @(ViewBag.IncomingRequestCount != null && ViewBag.IncomingRequestCount > 0 ? "" : "d-none")" style="top: -2px; right: -2px; font-size: 0.6rem; border: 2px solid #f5f0e8;">
                                @(ViewBag.IncomingRequestCount ?? 0)
                            </span>
                        </button>
                    }
                    else
                    {
                        @if (ViewBag.IsPending == true)
                        {
                            <button id="btnFollow" class="pp-btn pp-btn-follow pending" onclick="toggleFollow(@Model.Id)">
                                <i class="fas fa-clock"></i>
                                <span id="followText">İstek Gönderildi</span>
                            </button>
                        }
                        else
                        {
                            <button id="btnFollow"
                                    class="pp-btn pp-btn-follow @(ViewBag.IsFollowing ? "following" : "")"
                                    onclick="toggleFollow(@Model.Id)">
                                <i class="fas @(ViewBag.IsFollowing ? "fa-user-check" : "fa-user-plus")"></i>
                                <span id="followText">@(ViewBag.IsFollowing ? "Takiptesin" : "Takip Et")</span>
                            </button>
                        }

                        @* Mesajlaşma yalnızca takip ettiğin ya da seni takip eden kişilerle *@
                        @if (ViewBag.IsFollowing == true || ViewBag.IsFollower == true)
                        {
                            <a href="/Message/Chat?userId=@Model.Id" class="pp-btn pp-btn-message">
                                <i class="fas fa-comment-dots"></i> Mesaj Gönder
                            </a>
                        }
                    }

                    <div class="dropdown d-inline-block pp-share-wrapper">
                        <button class="pp-btn pp-btn-share d-flex align-items-center justify-content-center" type="button" id="profileOptions" data-bs-toggle="dropdown" aria-expanded="false" style="padding: 0;">
                            <i class="fas fa-ellipsis-v"></i>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end shadow-sm" aria-labelledby="profileOptions">
                            <li>
                                <button class="dropdown-item" id="btnShare">
                                    <i class="fas fa-share-nodes me-2 text-primary"></i> Profili Paylaş
                                </button>
                            </li>
                            @if (ViewBag.LoggedInUserId != Model.Id)
                            {
                                <li>
                                    <button class="dropdown-item" onclick="toggleBlockUser(@Model.Id)">
                                        <i class="fas fa-ban me-2 text-danger"></i>
                                        <span id="blockMenuText" class="text-danger">
                                            @(ViewBag.IsBlockedByMe == true ? "Engeli Kaldır" : "Kullanıcıyı Engelle")
                                        </span>
                                    </button>
                                </li>
                                <li>
                                    <button class="dropdown-item" data-bs-toggle="modal" data-bs-target="#reportModal">
                                        <i class="fas fa-flag me-2 text-warning"></i> Şikayet Et
                                    </button>
                                </li>
                            }
                        </ul>
                    </div>
                </div>

            </div>

            <!-- ============ SEKMELER (TABS) ============ -->
            @if (ViewBag.IsBlockedByMe == true)
            {
                <div class="pp-stats pp-anim-3" style="padding: 40px 15px; text-align: center;">
                    <i class="fas fa-user-slash text-danger" style="font-size: 3rem; margin-bottom: 15px;"></i>
                    <h4 class="text-danger">Bu Kullanıcıyı Engellediniz</h4>
                    <p class="text-muted">Bu kullanıcının kitaplarını ve etkinliklerini göremiyorsunuz.</p>
                    <button class="btn btn-outline-danger mt-3" onclick="toggleBlockUser(@Model.Id)">
                        Engeli Kaldır
                    </button>
                </div>
            }
            else if (ViewBag.IsBlockingMe == true)
            {
                <div class="pp-stats pp-anim-3" style="padding: 40px 15px; text-align: center;">
                    <i class="fas fa-lock text-muted" style="font-size: 3rem; margin-bottom: 15px;"></i>
                    <h4 class="text-muted">Bu Profile Erişilemiyor</h4>
                </div>
            }
            else if (ViewBag.IsPrivate == true && ViewBag.IsFollowing != true && ViewBag.LoggedInUserId != Model.Id)
            {
                <div class="pp-stats pp-anim-3" style="padding: 40px 15px; text-align: center;">
                    <i class="fas fa-lock text-muted" style="font-size: 3rem; margin-bottom: 15px;"></i>
                    <h4 class="text-muted" style="font-family: 'Georgia', serif; font-weight: 700; color: #4a3f35 !important;">Bu Hesap Gizli</h4>
                    <p class="text-muted">Kullanıcının kitaplarını ve istatistiklerini görmek için takip etmelisiniz.</p>
                </div>
            }
            else
            {
                <div class="pp-stats pp-anim-3" style="padding: 15px;">
                    <ul class="nav nav-pills mb-4 justify-content-center pp-profile-tabs" id="profileTabs" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active" id="library-tab" data-bs-toggle="tab" data-bs-target="#library-pane" type="button" role="tab">
                                <i class="fas fa-book"></i> Kitaplık
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="stats-tab" data-bs-toggle="tab" data-bs-target="#stats-pane" type="button" role="tab">
                                <i class="fas fa-chart-line"></i> İstatistikler
                            </button>
                        </li>

                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="achievements-tab" data-bs-toggle="tab" data-bs-target="#achievements-pane" type="button" role="tab">
                                <i class="fas fa-medal"></i> Başarımlar
                            </button>
                        </li>
                    </ul>

                    <style>
                        .pp-profile-tabs {
                            display: flex;
                            flex-wrap: nowrap;
                            gap: 6px;
                            overflow-x: auto;
                            -ms-overflow-style: none;
                            scrollbar-width: none;
                        }

                            .pp-profile-tabs::-webkit-scrollbar {
                                display: none;
                            }

                            .pp-profile-tabs .nav-link {
                                border-radius: 20px;
                                font-weight: 600;
                                padding: 6px 12px;
                                font-size: 0.8rem;
                                color: #8b6f47;
                                background: rgba(139, 111, 71, 0.1);
                                white-space: nowrap;
                            }

                        #profileTabs .nav-link.active {
                            background: linear-gradient(135deg, #8b6f47, #6b5541) !important;
                            color: #fff !important;
                            box-shadow: 0 4px 10px rgba(107, 85, 65, 0.3);
                        }

                        .pp-book-grid {
                            display: grid;
                            grid-template-columns: repeat(auto-fill, minmax(110px, 1fr));
                            gap: 15px;
                            padding-top: 10px;
                            /* En az 3 satır kitap rahat görünsün (kaydırma devam eder) */
                            max-height: 1000px;
                            overflow-y: auto;
                            padding-right: 5px;
                        }

                        /* Kart + kalp butonunu bir arada tutan hücre (kalp, link'in içine gömülmez) */
                        .pp-book-cell {
                            position: relative;
                            display: flex;
                        }

                        /* Kapak üzerindeki kompakt hızlı beğeni butonu */
                        .pp-book-like {
                            position: absolute;
                            top: 8px;
                            right: 8px;
                            z-index: 3;
                            display: inline-flex;
                            align-items: center;
                            gap: 5px;
                            padding: 6px 12px;
                            border: none;
                            border-radius: 22px;
                            background: rgba(30, 20, 12, 0.5);
                            color: #fff;
                            font-family: 'Georgia', serif;
                            font-size: 0.92rem;
                            font-weight: 700;
                            line-height: 1;
                            cursor: pointer;
                            transition: background 0.2s ease, transform 0.12s ease;
                        }

                            .pp-book-like i {
                                font-size: 1.05rem;
                                color: #fff;
                                transition: color 0.2s ease;
                            }

                            .pp-book-like.liked i {
                                color: #ff5a7a;
                            }

                            .pp-book-like:hover {
                                background: rgba(30, 20, 12, 0.68);
                            }

                            .pp-book-like:active {
                                transform: scale(0.88);
                            }

                        .pp-book-card {
                            background: #fff9f0;
                            border-radius: 12px;
                            box-shadow: 0 4px 10px rgba(107, 85, 65, 0.1);
                            overflow: hidden;
                            transition: transform 0.2s ease, box-shadow 0.2s ease;
                            text-align: center;
                            text-decoration: none;
                            color: inherit;
                            display: flex;
                            flex-direction: column;
                            flex: 1;
                            min-width: 0;
                        }

                            .pp-book-card:hover {
                                transform: translateY(-5px);
                                box-shadow: 0 8px 15px rgba(107, 85, 65, 0.2);
                            }

                        .pp-book-cover {
                            width: 100%;
                            aspect-ratio: 2 / 3;
                            object-fit: cover;
                            border-bottom: 2px solid rgba(139, 111, 71, 0.1);
                        }

                        .pp-book-cover-placeholder {
                            width: 100%;
                            aspect-ratio: 2 / 3;
                            background: linear-gradient(135deg, #e8dcc8, #d4c5b0);
                            display: flex;
                            align-items: center;
                            justify-content: center;
                            font-size: 2rem;
                            color: #8b6f47;
                            border-bottom: 2px solid rgba(139, 111, 71, 0.1);
                        }

                        .pp-book-info {
                            padding: 10px 8px;
                            flex-grow: 1;
                            display: flex;
                            flex-direction: column;
                            justify-content: space-between;
                        }

                        .pp-book-title {
                            font-size: 0.8rem;
                            font-weight: 700;
                            color: #4a3f35;
                            white-space: nowrap;
                            overflow: hidden;
                            text-overflow: ellipsis;
                            margin-bottom: 3px;
                        }

                        .pp-book-author {
                            font-size: 0.7rem;
                            color: #8b6f47;
                            white-space: nowrap;
                            overflow: hidden;
                            text-overflow: ellipsis;
                            margin-bottom: 5px;
                        }

                        .pp-book-rating {
                            font-size: 0.7rem;
                            color: #f39c12;
                        }
                    </style>

                    <div class="tab-content" id="profileTabsContent">
                        <!-- İSTATİSTİKLER TAB -->
                        <div class="tab-pane fade" id="stats-pane" role="tabpanel">
                            <div class="pp-stats-grid">
                                <div class="pp-tile pp-tile-fire">
                                    <div class="pp-tile-icon"><i class="fas fa-fire"></i></div>
                                    <div class="pp-tile-body">
                                        <div class="pp-tile-value">@Model.CurrentStreak Gün</div>
                                        <div class="pp-tile-label">Mevcut Seri</div>
                                    </div>
                                    <span class="pp-tile-sub">@streakLabel</span>
                                </div>

                                <div class="pp-tile pp-tile-gem">
                                    <div class="pp-tile-icon"><i class="fas fa-gem"></i></div>
                                    <div class="pp-tile-body">
                                        <div class="pp-tile-value">@Model.WisdomStones.ToString("N0")</div>
                                        <div class="pp-tile-label">Bilgelik Taşı</div>
                                    </div>
                                    <span class="pp-tile-sub">Hazine</span>
                                </div>

                                <div class="pp-tile">
                                    <div class="pp-tile-icon"><i class="fas fa-clock"></i></div>
                                    <div class="pp-tile-body">
                                        <div class="pp-tile-value">@ViewBag.TotalFocusHours Saat</div>
                                        <div class="pp-tile-label">Odaklanma Süresi</div>
                                    </div>
                                    <span class="pp-tile-sub">YOLCULUK</span>
                                </div>
                            </div>
                        </div>

                        <!-- KİTAPLIK TAB -->
                        <div class="tab-pane fade show active" id="library-pane" role="tabpanel">
                            @if (Model.Books != null && Model.Books.Any())
                            {
                                <div class="pp-book-grid">
                                    @{
                                        var ppLikeCounts = ViewBag.BookLikeCounts as Dictionary<int, int> ?? new Dictionary<int, int>();
                                        var ppMyLikes = ViewBag.MyLikedBookIds as HashSet<int> ?? new HashSet<int>();

                                        // Kitaplar beğeni sayısına göre azalan sıralanır; eşitlikte son eklenen kitap önce
                                        var ppSortedBooks = Model.Books
                                            .OrderByDescending(b => ppLikeCounts.TryGetValue(b.Id, out int c) ? c : 0)
                                            .ThenByDescending(b => b.CreateDate)
                                            .ThenByDescending(b => b.Id)
                                            .ToList();
                                    }
                                    @foreach (var book in ppSortedBooks)
                                    {
                                        int ppLikeCount = ppLikeCounts.TryGetValue(book.Id, out int lc) ? lc : 0;
                                        bool ppLiked = ppMyLikes.Contains(book.Id);
                                        <div class="pp-book-cell">
                                        <button type="button" class="pp-book-like @(ppLiked ? "liked" : "")" onclick="toggleBookLike(event, @book.Id, this)" title="Beğen" aria-label="Beğen">
                                            <i class="@(ppLiked ? "fas" : "far") fa-heart"></i>
                                            <span class="pp-book-like-count">@ppLikeCount</span>
                                        </button>
                                        <a href="/Profile/BookDetails/@book.Id" class="pp-book-card">
                                            @if (!string.IsNullOrEmpty(book.Image))
                                            {
                                                <img src="@book.Image" class="pp-book-cover" alt="@book.Name" />
                                            }
                                            else
                                            {
                                                <div class="pp-book-cover-placeholder">
                                                    <i class="fas fa-book"></i>
                                                </div>
                                            }
                                            <div class="pp-book-info">
                                                <div>
                                                    <div class="pp-book-title" title="@book.Name">@book.Name</div>
                                                    <div class="pp-book-author" title="@book.Author">@book.Author</div>
                                                </div>
                                                <div class="pp-book-rating">
                                                    @for (int i = 1; i <= 5; i++)
                                                    {
                                                        if (i <= (book.Rate ?? 0))
                                                        {
                                                            <i class="fas fa-star"></i>
                                                        }
                                                        else if (i - 0.5m <= (book.Rate ?? 0))
                                                        {
                                                            <i class="fas fa-star-half-alt"></i>
                                                        }
                                                        else
                                                        {
                                                            <i class="far fa-star"></i>
                                                        }
                                                    }
                                                </div>
                                            </div>
                                        </a>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="text-center py-4">
                                    <i class="fas fa-book-open" style="font-size: 3rem; color: #d4c5b0; margin-bottom: 15px;"></i>
                                    <h5 style="color: #6b5541; font-weight: 700; font-family: 'Georgia', serif;">Henüz Kitap Yok</h5>
                                    <p class="text-muted" style="font-size: 0.9rem;">Bu kullanıcının kitaplığı şu an boş.</p>
                                </div>
                            }
                        </div>

                        <!-- BAŞARIMLAR TAB -->
                        <div class="tab-pane fade" id="achievements-pane" role="tabpanel">
                            <partial name="_ProfileAchievements" model="Model" />
                        </div>
                    </div>
                </div>
            }

        </div>
    </div>
</div>

<!-- Bildirim Toast'u -->
<div class="pp-toast" id="ppToast">
    <i class="fas fa-check-circle"></i> <span id="ppToastText">Profil bağlantısı kopyalandı!</span>
</div>

