                                <label for="customAvatarFile" class="form-label text-muted">Bilgisayarından bir fotoğraf seç</label>
                                <input class="form-control" type="file" id="customAvatarFile" accept="image/*">
                            </div>
                            <div class="text-center mt-3">
                                <div id="uploadPreview" style="width: 100px; height: 100px; border-radius: 50%; background: #e8dcc8; margin: 0 auto; display: flex; align-items: center; justify-content: center; overflow: hidden;">
                                    <span class="text-muted small">Önizleme</span>
                                </div>
                            </div>
                        </div>

                        <div class="tab-pane fade" id="frame-pane" role="tabpanel">
                            @{
                                var ownedFrames = ViewBag.OwnedFrames as List<BookManagementApp.Areas.Admin.Models.ProfileFrame>;
                                var activeFrame = ViewBag.ActiveFrameImageUrl as string;
                            }
                            @if (ownedFrames != null && ownedFrames.Any())
                            {
                                <div class="text-center mb-2 text-muted small">Sahip olduğun çerçevelerden birini seç:</div>
                                <div class="text-center mt-2">
                                    <form asp-action="EquipFrame" asp-controller="Store" asp-area="" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="0" />
                                        <input type="hidden" name="returnUrl" value="/Profile/PublicProfile/@Model.Id" />
                                        <button type="submit" class="btn btn-sm" style="background: #e8dcc8; color: #6b5541; border-radius: 20px; font-size: 0.8rem; font-weight: 600;">Çerçeveyi Kaldır</button>
                                    </form>
                                </div>
                                <div style="max-height: 250px; overflow-y: auto; overflow-x: hidden; padding-right: 10px; display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; padding-top: 10px;">
                                    @foreach (var frame in ownedFrames)
                                    {
                                        bool isActive = activeFrame == frame.ImageUrl;
                                        <form asp-action="EquipFrame" asp-controller="Store" asp-area="" method="post" style="text-align: center;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@frame.Id" />
                                            <input type="hidden" name="returnUrl" value="/Profile/PublicProfile/@Model.Id" />
                                            <button type="submit" style="background: none; border: none; cursor: pointer; padding: 0; transition: transform 0.2s;" title="@frame.Name">
                                                <div style="position: relative; width: 70px; height: 70px; border-radius: 15px; display: flex; align-items: center; justify-content: center; font-size: 1.8rem; background: linear-gradient(135deg, #fff9f0 0%, #e6dac8 100%); color: #5c4b3d; font-weight: 700; margin: 0 auto;">
                                                    <div style="width: 100%; height: 100%; border-radius: 15px; overflow: hidden; display: flex; align-items: center; justify-content: center;">
                                                        @if (!string.IsNullOrEmpty(Model.ProfileImageUrl))
                                                        {
                                                            <img src="@Model.ProfileImageUrl" style="width:100%; height:100%; object-fit:cover;" />
                                                        }
                                                        else
                                                        {
                                                            @(string.IsNullOrEmpty(Model.UserName) ? "U" : Model.UserName.Substring(0, 1).ToUpper())
                                                        }
                                                    </div>
                                                    @if (!string.IsNullOrEmpty(frame.ImageUrl))
                                                    {
                                                        <img src="@frame.ImageUrl" style="position: absolute; top: -15%; left: -15%; width: 130%; height: 130%; pointer-events: none; z-index: 10; object-fit: contain;" />
                                                    }
                                                </div>
                                                <div style="font-size: 0.7rem; margin-top: 5px; color: @(isActive ? "#27ae60" : "#8b6f47"); font-weight: 700;">@frame.IconEmoji @frame.Name</div>
                                                @if (isActive)
                                                {
                                                    <div style="font-size: 0.65rem; color: #27ae60;">✓ Aktif</div>
                                                }
                                            </button>
                                        </form>
                                    }
                                </div>
