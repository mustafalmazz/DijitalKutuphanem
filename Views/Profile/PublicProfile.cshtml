                        overflow-y: auto;
                        padding-right: 5px;
                    }
                    .pp-book-card {
                        background: #fff9f0;
                        border-radius: 12px;
                        box-shadow: 0 4px 10px rgba(107, 85, 65, 0.1);
                        overflow: hidden;
                        transition: transform 0.2s ease, box-shadow 0.2s ease;
                        text-align: center;
                        text-decoration: none;
                        color: inherit;
                        display: flex;
                        flex-direction: column;
                    }
                    .pp-book-card:hover {
                        transform: translateY(-5px);
                        box-shadow: 0 8px 15px rgba(107, 85, 65, 0.2);
                    }
                    .pp-book-cover {
                        width: 100%;
                        aspect-ratio: 2 / 3;
                        object-fit: cover;
                        border-bottom: 2px solid rgba(139, 111, 71, 0.1);
                    }
                    .pp-book-cover-placeholder {
                        width: 100%;
                        aspect-ratio: 2 / 3;
                        background: linear-gradient(135deg, #e8dcc8, #d4c5b0);
                        display: flex;
                        align-items: center;
                        justify-content: center;
                        font-size: 2rem;
                        color: #8b6f47;
                        border-bottom: 2px solid rgba(139, 111, 71, 0.1);
                    }
                    .pp-book-info {
                        padding: 10px 8px;
                        flex-grow: 1;
                        display: flex;
                        flex-direction: column;
                        justify-content: space-between;
