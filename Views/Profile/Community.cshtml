@model IEnumerable<BookManagementApp.Areas.Admin.Models.User>
@{
    ViewData["Title"] = "Topluluk";
    var acceptedFollowings = ViewBag.AcceptedFollowings as List<int> ?? new List<int>();
    var requestedFollowings = ViewBag.RequestedFollowings as List<int> ?? new List<int>();
    var currentUserId = ViewBag.CurrentUserId as int?;
}

<style>
    body {
        background: linear-gradient(135deg, #f5f0e8 0%, #e8dcc8 100%);
    }

    .community-page {
        padding: 30px 15px 80px;
        max-width: 800px;
        margin: 0 auto;
    }

    .community-header {
        text-align: center;
        margin-bottom: 30px;
    }

    .community-title {
        color: #4a3f35;
        font-weight: 800;
        font-size: 1.7rem;
        margin-bottom: 10px;
    }

    .community-subtitle {
        color: #8b6f47;
        font-size: 1.1rem;
        font-style: italic;
    }

    /* Arama Kutusu ve Butonlar */
    .community-search-form {
        position: relative;
        margin-bottom: 0;
        box-shadow: 0 8px 25px rgba(107, 85, 65, 0.15);
        border-radius: 50px;
    }

    .community-requests-btn {
        height: 60px;
        width: 60px;
        border-radius: 50%;
        background: #fff;
        color: #8b6f47;
        border: 2px solid rgba(139, 111, 71, 0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        position: relative;
        transition: all 0.3s ease;
        box-shadow: 0 8px 25px rgba(107, 85, 65, 0.15);
        flex-shrink: 0;
    }

    .community-requests-btn:hover {
        border-color: #cda45e;
        color: #cda45e;
        transform: translateY(-2px);
    }

    .community-requests-btn .badge {
        position: absolute;
        top: 8px;
        right: 8px;
        font-size: 0.65rem;
        border: 2px solid #fff;
        padding: 0.25em 0.4em;
    }

    .community-search-input {
        width: 100%;
        height: 60px;
        border: 2px solid rgba(139, 111, 71, 0.2);
        border-radius: 50px;
        padding: 0 60px 0 25px;
        font-size: 1.1rem;
        background: #fff9f0;
        color: #4a3f35;
        transition: all 0.3s ease;
    }

        .community-search-input:focus {
            outline: none;
            border-color: #cda45e;
            box-shadow: 0 0 0 4px rgba(205, 164, 94, 0.2);
        }

    .community-search-btn {
        position: absolute;
        right: 8px;
        top: 8px;
        height: 44px;
        width: 44px;
        border-radius: 50%;
        background: linear-gradient(135deg, #8b6f47, #6b5541);
        color: #fff;
        border: none;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        transition: all 0.3s ease;
    }

        .community-search-btn:hover {
            background: linear-gradient(135deg, #cda45e, #a0785a);
            transform: scale(1.05);
        }

    /* Kullanıcı Listesi */
    .community-list {
        display: flex;
        flex-direction: column;
        gap: 15px;
    }

    /* Kart artık <a> değil <div>; tıklama JS ile profile gider.
           (a içinde button geçersiz HTML olduğu için düzeltildi) */
    .user-card {
        background: #fff;
        border-radius: 20px;
        padding: 20px;
        display: flex;
        align-items: center;
        gap: 15px;
        box-shadow: 0 4px 15px rgba(107, 85, 65, 0.08);
        border: 1px solid rgba(139, 111, 71, 0.1);
        transition: all 0.3s ease;
        text-decoration: none;
        color: inherit;
        cursor: pointer;
    }

        .user-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 25px rgba(107, 85, 65, 0.15);
            border-color: rgba(205, 164, 94, 0.4);
        }

    .user-avatar-wrap {
        width: 60px;
        height: 60px;
        position: relative;
        flex-shrink: 0;
    }

    .user-avatar {
        width: 100%;
        height: 100%;
        border-radius: 16px;
        object-fit: cover;
        background: linear-gradient(135deg, #fff9f0, #e6dac8);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        font-weight: 700;
        color: #8b6f47;
        border: 2px solid #fff;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }

    .user-frame {
        position: absolute;
        top: -15%;
        left: -15%;
        width: 130%;
        height: 130%;
        pointer-events: none;
        z-index: 5;
        object-fit: contain;
    }

    .user-info {
        flex-grow: 1;
        min-width: 0;
    }

    .user-name {
        font-size: 1.15rem;
        font-weight: 700;
        color: #4a3f35;
        margin-bottom: 4px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .user-level {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: color-mix(in srgb, var(--title-color, #8b6f47) 14%, transparent);
        color: var(--title-color, #8b6f47);
        padding: 3px 10px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
    }

    .user-books {
        font-size: 0.8rem;
        color: #a08b6d;
        margin-left: 8px;
    }

    /* Takip Butonları */
    .btn-follow-toggle {
        padding: 8px 18px;
        border-radius: 50px;
        font-size: 0.85rem;
        font-weight: 700;
        border: none;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        gap: 6px;
        white-space: nowrap;
        z-index: 10;
        position: relative;
    }

        .btn-follow-toggle.not-following {
            background: linear-gradient(135deg, #8b6f47, #6b5541);
            color: #fff;
            box-shadow: 0 4px 12px rgba(107, 85, 65, 0.2);
        }

            .btn-follow-toggle.not-following:hover {
                background: linear-gradient(135deg, #a0785a, #8b6f47);
                transform: translateY(-2px);
            }

        .btn-follow-toggle.following {
            background: #efe6d6;
            color: #8b6f47;
            border: 1px solid rgba(139, 111, 71, 0.2);
        }

            .btn-follow-toggle.following:hover {
                background: #e6dac8;
                color: #dc3545;
                border-color: #dc3545;
            }

                .btn-follow-toggle.following:hover .follow-text::before {
                    content: 'Takipten Çık';
                }

                .btn-follow-toggle.following:hover .follow-text {
                    font-size: 0;
                }

                    .btn-follow-toggle.following:hover .follow-text::before {
                        font-size: 0.85rem;
                    }

                .btn-follow-toggle.following:hover i::before {
                    content: "\f503"; /* fa-user-minus */
                }

        .btn-follow-toggle.requested {
            background: transparent;
            color: #d9a441;
            border: 1px solid #d9a441;
        }

            .btn-follow-toggle.requested:hover {
                background: rgba(217, 164, 65, 0.08);
            }

    /* Boş Durum */
    .empty-state {
        text-align: center;
        padding: 50px 20px;
        background: #fff;
        border-radius: 20px;
        border: 1px dashed rgba(139, 111, 71, 0.3);
    }

        .empty-state i {
            font-size: 3rem;
            color: #d4c5b0;
            margin-bottom: 15px;
        }

        .empty-state h3 {
            color: #6b5541;
            font-size: 1.3rem;
            margin-bottom: 8px;
        }

        .empty-state p {
            color: #a08b6d;
        }

    @@media (max-width: 576px) {
        .user-card {
            padding: 15px;
            gap: 12px;
        }

        .user-avatar-wrap {
            width: 50px;
            height: 50px;
        }

        .user-name {
            font-size: 1rem;
        }

        .btn-follow-toggle {
            padding: 6px 14px;
            font-size: 0.8rem;
        }
    }
</style>

<div class="community-page">
    <div class="community-header">
        <h1 class="community-title">Topluluk</h1>
        <p class="community-subtitle">Diğer okurları keşfet ve kütüphanelerini incele</p>
    </div>

    <div class="d-flex align-items-center gap-2 mb-4">
        

        @if (currentUserId.HasValue)
        {
            <button type="button" class="community-requests-btn" onclick="openRequestsModal()" title="Takip İstekleri">
                <i class="fa-solid fa-bell"></i>
                <span id="communityRequestsBadge" class="badge bg-danger rounded-pill @(ViewBag.IncomingRequestCount != null && ViewBag.IncomingRequestCount > 0 ? "" : "d-none")">
                    @(ViewBag.IncomingRequestCount ?? 0)
                </span>
            </button>
        }
        <form class="community-search-form flex-grow-1" method="get" action="/Profile/Community">
            <input type="text" name="q" class="community-search-input" placeholder="Kullanıcı adı ile ara..." value="@ViewBag.SearchQuery" autocomplete="off" />
            <button type="submit" class="community-search-btn">
                <i class="fa-solid fa-magnifying-glass"></i>
            </button>
        </form>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <i class="fa-solid fa-users-slash"></i>
            <h3>Sonuç Bulunamadı</h3>
            <p>Aradığınız kritere uygun bir kullanıcı bulamadık. Lütfen farklı bir isim deneyin.</p>
            @if (!string.IsNullOrEmpty(ViewBag.SearchQuery))
            {
                <a href="/Profile/Community" class="btn btn-link" style="color:#8b6f47; font-weight:bold; text-decoration:none;">Tüm Kullanıcıları Gör</a>
            }
        </div>
    }
    else
    {
        <div class="community-list">
            @foreach (var user in Model)
            {
                // Kullanıcının profilinde göstermeyi seçtiği etiket (yoksa hiçbir şey gösterilmez)
                var listTitle = user.ActiveTitleAchievement;

                bool isFollowing = acceptedFollowings.Contains(user.Id);
                bool isRequested = requestedFollowings.Contains(user.Id);

                <div class="user-card" onclick="goToProfile(@user.Id)" role="link" tabindex="0" onkeydown="if(event.key==='Enter'){goToProfile(@user.Id);}">
                    <div class="user-avatar-wrap">
                        @if (!string.IsNullOrEmpty(user.ProfileImageUrl))
                        {
                            <img src="@user.ProfileImageUrl" class="user-avatar" alt="@user.UserName" />
                        }
                        else
                        {
                            <div class="user-avatar">@(user.UserName?.Substring(0, 1).ToUpper())</div>
                        }

                        @if (!string.IsNullOrEmpty(user.ActiveFrameImageUrl))
                        {
                            <img src="@user.ActiveFrameImageUrl" class="user-frame" alt="" />
                        }
                    </div>

                    <div class="user-info">
                        <div class="user-name">@user.UserName</div>
                        @if (listTitle != null)
                        {
                            string[] tierNames = { "", "Bronz", "Gümüş", "Altın", "Platin", "Elmas", "Efsane" };

                            <div class="user-level js-title-badge"
                                 style="--title-color: @(listTitle.ColorHex ?? "#8b6f47");"
                                 role="button" tabindex="0"
                                 data-title-name="@listTitle.Name"
                                 data-title-desc="@listTitle.Description"
                                 data-title-icon="@listTitle.IconClass"
                                 data-title-color="@(listTitle.ColorHex ?? "#8b6f47")"
                                 data-title-tier="@tierNames[Math.Clamp(listTitle.Tier, 1, 6)]">
                                <i class="fa-solid @listTitle.IconClass"></i> @listTitle.Name
                            </div>
                        }
                        <span class="user-books" title="Kitap Sayısı"><i class="fa-solid fa-book" style="color:#cda45e;"></i> @(user.Books?.Count ?? 0)</span>
                    </div>

                    <button type="button"
                            class="btn-follow-toggle @(isFollowing ? "following" : (isRequested ? "requested" : "not-following"))"
                            onclick="toggleFollowList(event, @user.Id, this)">
                        <i class="fa-solid @(isFollowing ? "fa-user-check" : (isRequested ? "fa-clock" : "fa-user-plus"))"></i>
                        <span class="follow-text">@(isFollowing ? "Takiptesin" : (isRequested ? "İstek Gönderildi" : "Takip Et"))</span>
                    </button>
                </div>
            }
        </div>
    }
</div>

<!-- Takip İstekleri Modalı -->
<div class="modal fade" id="requestsModal" tabindex="-1" aria-labelledby="requestsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="background: #fff9f0; border-radius: 20px; border: none; box-shadow: 0 15px 35px rgba(107, 85, 65, 0.2);">
            <div class="modal-header" style="border-bottom: 1px solid rgba(139, 111, 71, 0.2);">
                <h5 class="modal-title" id="requestsModalLabel" style="color: #4a3f35; font-weight: 700; font-family: 'Georgia', serif;">
                    <i class="fa-solid fa-bell"></i> Takip İstekleri
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Kapat"></button>
            </div>
            <div class="modal-body" id="requestsModalBody" style="padding: 15px; max-height: 400px; overflow-y: auto;">
                <div class="text-center"><i class="fa-solid fa-spinner fa-spin"></i> Yükleniyor...</div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Kart tıklaması ile profile git (a içinde button geçersiz olduğu için div + JS kullanıldı)
        function goToProfile(userId) {
            window.location.href = '/Profile/PublicProfile?id=' + userId;
        }

        function toggleFollowList(e, userId, btnElement) {
            e.preventDefault();
            e.stopPropagation();

            var $btn = $(btnElement);
            var $icon = $btn.find('i.fa-solid');
            var $text = $btn.find('.follow-text');

            $btn.prop('disabled', true);

            $.post('/Profile/ToggleFollow', { targetId: userId }, function (res) {
                if (res.success) {
                    if (res.isFollowing) {
                        $btn.removeClass('not-following requested').addClass('following');
                        $icon.removeClass('fa-user-plus fa-clock').addClass('fa-user-check');
                        $text.text('Takiptesin');
                    } else if (res.isPending) { // DÜZELTİLDİ: backend "isPending" dönüyor, "isRequested" değil
                        $btn.removeClass('not-following following').addClass('requested');
                        $icon.removeClass('fa-user-plus fa-user-check').addClass('fa-clock');
                        $text.text('İstek Gönderildi');
                    } else {
                        $btn.removeClass('following requested').addClass('not-following');
                        $icon.removeClass('fa-user-check fa-clock').addClass('fa-user-plus');
                        $text.text('Takip Et');
                    }
                } else {
                    alert(res.message || "Bir hata oluştu.");
                }
                $btn.prop('disabled', false);
            }).fail(function () {
                alert("Sunucu ile bağlantı kurulamadı.");
                $btn.prop('disabled', false);
            });
        }

        var reqModal;
        function openRequestsModal() {
            if (!reqModal) {
                reqModal = new bootstrap.Modal(document.getElementById('requestsModal'));
            }
            reqModal.show();
            loadRequests();
        }

        function loadRequests() {
            var body = $('#requestsModalBody');
            body.html('<div class="text-center"><i class="fa-solid fa-spinner fa-spin"></i> Yükleniyor...</div>');

            $.get('/Profile/GetFollowRequests', function (res) {
                if (res.success) {
                    if (res.data.length === 0) {
                        body.html('<div class="text-center text-muted" style="padding: 20px;">Bekleyen takip isteği yok.</div>');
                        return;
                    }
                    var html = '<div class="list-group list-group-flush">';
                    res.data.forEach(function (req) {
                        var avatarContent = req.profileImage
                            ? '<img src="' + req.profileImage + '" style="width:40px;height:40px;border-radius:10px;object-fit:cover;">'
                            : '<div style="width:40px;height:40px;border-radius:10px;background:#e6dac8;display:flex;align-items:center;justify-content:center;font-weight:bold;color:#8b6f47;">' + req.userName.charAt(0).toUpperCase() + '</div>';

                        var frameContent = req.activeFrame
                            ? '<img src="' + req.activeFrame + '" style="position: absolute; top: -15%; left: -15%; width: 130%; height: 130%; pointer-events: none; z-index: 10; object-fit: contain;">'
                            : '';

                        var avatarHtml = '<div style="position: relative; width: 40px; height: 40px; flex-shrink: 0;">' + avatarContent + frameContent + '</div>';

                        html += `
                        <div class="list-group-item d-flex justify-content-between align-items-center" style="background:transparent; border-color: rgba(139,111,71,0.1);" id="req-item-${req.followerId}">
                            <a href="/Profile/PublicProfile/${req.followerId}" class="d-flex align-items-center gap-3 text-decoration-none" style="flex-grow: 1;">
                                ${avatarHtml}
                                <span style="font-weight: 600; color: #4a3f35; transition: color 0.2s;" onmouseover="this.style.color='#8b6f47'" onmouseout="this.style.color='#4a3f35'">${req.userName}</span>
                            </a>
                            <div style="flex-shrink: 0;">
                                <button class="btn btn-sm btn-success me-1" onclick="handleReq(${req.followerId}, true)"><i class="fa-solid fa-check"></i></button>
                                <button class="btn btn-sm btn-danger" onclick="handleReq(${req.followerId}, false)"><i class="fa-solid fa-xmark"></i></button>
                            </div>
                        </div>`;
                    });
                    html += '</div>';
                    body.html(html);
                } else {
                    body.html('<div class="text-center text-danger">İstekler yüklenemedi.</div>');
                }
            }).fail(function () {
                body.html('<div class="text-center text-danger">İstekler yüklenemedi.</div>');
            });
        }

        function handleReq(followerId, isAccept) {
            var url = isAccept ? '/Profile/AcceptFollowRequest' : '/Profile/RejectFollowRequest';
            $.post(url, { followerId: followerId }, function (res) {
                if (res.success) {
                    $('#req-item-' + followerId).fadeOut(300, function() {
                        $(this).remove();

                        var decrementFn = function(selector) {
                            var b = $(selector);
                            if (b.length) {
                                var curr = parseInt(b.text()) || 0;
                                if (curr > 1) {
                                    b.text(curr - 1);
                                } else {
                                    b.text(0).addClass('d-none');
                                }
                            }
                        };

                        decrementFn('#toplulukBadge');
                        decrementFn('#communityRequestsBadge');

                        // Mobil menü nokta kontrolü
                        var tBadge = $('#toplulukBadge');
                        if (tBadge.length && (parseInt(tBadge.text()) || 0) === 0) {
                            var md = $('#mobileMenuDot');
                            if (md.length) {
                                md.data('follow-requests', false);
                                var mb = $('#mobileUnreadBadge');
                                if (!mb.length || mb.hasClass('d-none')) {
                                    md.addClass('d-none');
                                }
                            }
                        }

                        if ($('#requestsModalBody .list-group-item').length === 0) {
                            $('#requestsModalBody').html('<div class="text-center text-muted" style="padding: 20px;">Bekleyen takip isteği yok.</div>');
                        }
                    });
                } else {
                    alert((res && res.message) || "İşlem gerçekleştirilemedi.");
                }
            }).fail(function () {
                alert("Sunucu ile bağlantı kurulamadı.");
            });
        }
    </script>
}

@await Html.PartialAsync("_TitlePopover")
