@model BookManagementApp.Areas.Admin.Models.User
@*
    BAŞARIMLAR PARTIAL
    ------------------
    PublicProfile'daki "Başarımlar" sekmesinin tamamı (stil + markup) buraya taşındı.
    Yönetimi kolaylaştırmak için ayrı dosyada tutulur.

    Gerekli veriler (PublicProfile action'ından ViewBag ile gelir):
      - Model                       : User (Model.UserAchievements toplanmış başarımlar)
      - ViewBag.AllAchievements     : List<Achievement>
      - ViewBag.AchievementStats    : Dictionary<string,int> (kategori bazlı metrikler)
      - ViewBag.LoggedInUserId      : giriş yapan kullanıcı (sahiplik kontrolü)

    İlgili JS fonksiyonları (toggleAchCat / claimAchievement / ppAnimateAchievements)
    kütüphane yükleme sırası nedeniyle PublicProfile'ın @@section Scripts bloğunda kalır.
*@

<style>
    /* ============================================================
                   BAŞARIMLAR — PREMIUM KOLEKSİYON
                   ============================================================ */

    /* --- Özet paneli (koyu, altın vurgulu) --- */
    .pp-ach-hero {
        background: linear-gradient(135deg, #3d3329 0%, #5c4936 55%, #6b5541 100%);
        border-radius: 20px;
        padding: 22px 24px;
        display: flex;
        align-items: center;
        gap: 22px;
        color: #f5f0e8;
        position: relative;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(61, 51, 41, 0.25);
        margin-bottom: 26px;
        text-align: left;
    }

        .pp-ach-hero::before {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(circle at 85% 15%, rgba(255,215,130,0.16), transparent 55%), radial-gradient(circle at 10% 90%, rgba(255,215,130,0.08), transparent 45%);
            pointer-events: none;
        }

    .pp-ach-ring-wrap {
        position: relative;
        width: 110px;
        height: 110px;
        flex-shrink: 0;
    }

    .pp-ach-ring {
        width: 100%;
        height: 100%;
        transform: rotate(-90deg);
    }

    .pp-ach-ring-bg {
        fill: none;
        stroke: rgba(245, 240, 232, 0.15);
        stroke-width: 9;
    }

    .pp-ach-ring-fill {
        fill: none;
        stroke: url(#ppAchGold);
        stroke-width: 9;
        stroke-linecap: round;
        stroke-dasharray: 326.73;
        stroke-dashoffset: 326.73;
        transition: stroke-dashoffset 1.4s cubic-bezier(0.25, 0.8, 0.35, 1);
    }

    .pp-ach-ring-label {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        pointer-events: none;
    }

        .pp-ach-ring-label b {
            font-size: 1.3rem;
            color: #ffd782;
            line-height: 1;
        }

        .pp-ach-ring-label span {
            font-size: 0.55rem;
            text-transform: uppercase;
            letter-spacing: 1.2px;
            color: rgba(245, 240, 232, 0.7);
            margin-top: 4px;
        }

    .pp-ach-hero-body {
        flex: 1;
        min-width: 0;
        position: relative;
    }

    .pp-ach-hero-title {
        font-size: 1.12rem;
        font-weight: 800;
        color: #ffe9b8;
        margin-bottom: 4px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .pp-ach-hero-sub {
        font-size: 0.79rem;
        color: rgba(245, 240, 232, 0.75);
        font-style: italic;
        margin-bottom: 13px;
    }

    .pp-ach-hero-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

    .pp-ach-chip {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: rgba(245, 240, 232, 0.09);
        border: 1px solid rgba(255, 215, 130, 0.25);
        padding: 5px 12px;
        border-radius: 50px;
        font-size: 0.71rem;
        font-weight: 600;
        color: #f5f0e8;
        white-space: nowrap;
    }

        .pp-ach-chip i {
            color: #ffd782;
            font-size: 0.7rem;
        }

        .pp-ach-chip b {
            color: #ffd782;
        }

    /* --- Kategori başlıkları (akordeon) --- */
    .pp-ach-cat {
        margin-bottom: 14px;
        text-align: left;
        background: #fff9f0;
        border: 1px solid rgba(139, 111, 71, 0.14);
        border-radius: 18px;
        box-shadow: 0 3px 12px rgba(107, 85, 65, 0.06);
        overflow: hidden;
    }

    /* Çapayla gelindiğinde ilgili seriyi kısa süre vurgular */
    .pp-ach-cat-focus {
        border-color: #ff9800 !important;
        box-shadow: 0 0 0 3px rgba(255, 152, 0, 0.22), 0 6px 20px rgba(255, 152, 0, 0.18) !important;
        transition: box-shadow 0.4s ease, border-color 0.4s ease;
    }

    .pp-ach-cat {
        scroll-margin-top: 90px;
    }

    .pp-ach-cat-head {
        display: flex;
        align-items: center;
        gap: 12px;
        width: 100%;
        padding: 14px 16px;
        background: none;
        border: none;
        font-family: inherit;
        text-align: left;
        cursor: pointer;
        transition: background 0.2s ease;
    }

        .pp-ach-cat-head:hover {
            background: rgba(139, 111, 71, 0.05);
        }

    .pp-ach-cat-chevron {
        flex-shrink: 0;
        color: #a08b6d;
        font-size: 0.85rem;
        transition: transform 0.35s ease;
        margin-left: 2px;
    }

    .pp-ach-cat.collapsed .pp-ach-cat-chevron {
        transform: rotate(-90deg);
    }

    /* Açılır gövde — grid-template-rows 1fr/0fr geçişiyle yumuşak açılıp kapanır */
    .pp-ach-cat-body {
        display: grid;
        grid-template-rows: 1fr;
        transition: grid-template-rows 0.35s ease;
    }

    .pp-ach-cat.collapsed .pp-ach-cat-body {
        grid-template-rows: 0fr;
    }

    .pp-ach-cat-inner {
        overflow: hidden;
        min-height: 0;
    }

    .pp-ach-cat-inner-pad {
        padding: 2px 16px 18px;
    }

    .pp-ach-cat-icon {
        width: 42px;
        height: 42px;
        border-radius: 13px;
        background: linear-gradient(135deg, #8b6f47, #6b5541);
        color: #ffe9b8;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        box-shadow: 0 4px 12px rgba(107, 85, 65, 0.25);
        flex-shrink: 0;
        position: relative;
    }

    /* Seride toplanmayı bekleyen ödül varsa ikonun köşesinde kırmızı sayı rozeti */
    .pp-ach-cat-badge {
        position: absolute;
        top: -6px;
        right: -6px;
        min-width: 19px;
        height: 19px;
        padding: 0 5px;
        border-radius: 10px;
        background: #dc3545;
        color: #fff;
        font-size: 0.63rem;
        font-weight: 800;
        display: flex;
        align-items: center;
        justify-content: center;
        line-height: 1;
        border: 2px solid #fff9f0;
        box-shadow: 0 2px 6px rgba(220, 53, 69, 0.45);
    }

    .pp-ach-cat-info {
        flex: 1;
        min-width: 0;
    }

    .pp-ach-cat-name {
        font-weight: 800;
        color: #4a3f35;
        font-size: 0.97rem;
        line-height: 1.2;
    }

    .pp-ach-cat-sub {
        font-size: 0.72rem;
        color: #a08b6d;
        font-style: italic;
    }

    .pp-ach-cat-right {
        text-align: right;
        flex-shrink: 0;
    }

    .pp-ach-cat-count {
        font-size: 0.76rem;
        font-weight: 800;
        color: #8b6f47;
        margin-bottom: 5px;
    }

    .pp-ach-cat-track {
        width: 90px;
        height: 6px;
        background: #efe6d6;
        border-radius: 6px;
        overflow: hidden;
        margin-left: auto;
    }

    /* Ortak animasyonlu dolgu (JS data-width ile doldurur) */
    .pp-ach-fill {
        height: 100%;
        width: 0%;
        border-radius: 6px;
        transition: width 1.1s cubic-bezier(0.25, 0.8, 0.35, 1);
    }

    .pp-ach-cat-track .pp-ach-fill {
        background: linear-gradient(90deg, #cda45e, #ffd782);
    }

    /* --- Kart ızgarası --- */
    .pp-ach-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(158px, 1fr));
        gap: 12px;
    }

    .pp-ach-card {
        --tg1: #e2a86b;
        --tg2: #9a5b23;
        --tb: #cd7f32;
        --ti: #fff;
        background: #fff9f0;
        border-radius: 16px;
        padding: 18px 12px 14px;
        text-align: center;
        border: 1px solid rgba(139, 111, 71, 0.14);
        position: relative;
        transition: transform 0.25s ease, box-shadow 0.25s ease;
        display: flex;
        flex-direction: column;
    }

        .pp-ach-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 10px 22px rgba(107, 85, 65, 0.14);
        }

        /* Seviye renk paletleri */
        .pp-ach-card.t1 { --tg1: #e2a86b; --tg2: #9a5b23; --tb: #cd7f32; --ti: #fff; }
        .pp-ach-card.t2 { --tg1: #ececef; --tg2: #9aa4b0; --tb: #9fa8b3; --ti: #5b6470; }
        .pp-ach-card.t3 { --tg1: #ffe084; --tg2: #d29a2f; --tb: #d9a441; --ti: #7a5a10; }
        /* Platin: gümüşle karışmasın diye nötr griden teal'e çekildi */
        .pp-ach-card.t4 { --tg1: #7fe6d0; --tg2: #1e9c85; --tb: #2fb8a0; --ti: #064137; }
        .pp-ach-card.t5 { --tg1: #c9f4ff; --tg2: #4fbede; --tb: #5bc8e8; --ti: #085e77; }
        .pp-ach-card.t6 { --tg1: #dcb5ff; --tg2: #8e44ad; --tb: #a55eea; --ti: #fff; }

        .pp-ach-card.earned {
            background: #fff;
            border-color: var(--tb);
            box-shadow: 0 6px 18px rgba(107, 85, 65, 0.10);
        }

        .pp-ach-card.t6.earned {
            box-shadow: 0 6px 20px rgba(165, 94, 234, 0.22);
        }

        /* Toplanabilir: tamamlanmış ama ödülü henüz alınmamış (yalnızca sahibi görür) */
        .pp-ach-card.claimable {
            border: 2px solid #cda45e;
            background: linear-gradient(180deg, #fffdf7 0%, #fff9f0 100%);
            box-shadow: 0 8px 22px rgba(205, 164, 94, 0.28);
        }

    /* "Profilde göster" düğmesi (kazanılmış başarımlarda) */
    .pp-ach-title-btn {
        margin-top: 8px;
        width: 100%;
        border: 1px solid rgba(139, 111, 71, 0.35);
        border-radius: 12px;
        padding: 7px 6px;
        font-family: 'Georgia', serif;
        font-weight: 700;
        font-size: 0.68rem;
        color: #6b5541;
        background: rgba(255, 255, 255, 0.65);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        transition: background 0.2s, color 0.2s, border-color 0.2s;
    }

        .pp-ach-title-btn:hover {
            background: #fff;
            border-color: #8b6f47;
            color: #4a3f35;
        }

        .pp-ach-title-btn.equipped {
            background: linear-gradient(135deg, #48bb78, #2f855a);
            border-color: transparent;
            color: #fff;
        }

            .pp-ach-title-btn.equipped:hover {
                background: linear-gradient(135deg, #38a169, #276749);
                color: #fff;
            }

    .pp-ach-claim {
        margin-top: auto;
        width: 100%;
        border: none;
        border-radius: 12px;
        padding: 9px 6px;
        font-family: 'Georgia', serif;
        font-weight: 800;
        font-size: 0.72rem;
        letter-spacing: 0.2px;
        color: #5a3d0e;
        background: linear-gradient(135deg, #ffd782, #cda45e);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        box-shadow: 0 4px 12px rgba(205, 164, 94, 0.4);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        animation: ppClaimGlow 2s ease-in-out infinite;
    }

        .pp-ach-claim:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 18px rgba(255, 215, 130, 0.6);
        }

        .pp-ach-claim:disabled {
            opacity: 0.65;
            cursor: default;
            transform: none;
            animation: none;
        }

    @@keyframes ppClaimGlow {
        0%, 100% {
            box-shadow: 0 4px 12px rgba(205, 164, 94, 0.4);
        }

        50% {
            box-shadow: 0 4px 18px rgba(255, 215, 130, 0.75);
        }
    }

    /* Kazanılan madalyon parıltısı — partial'ın kendi içinde çalışması için burada tanımlı */
    @@keyframes ppBadgeShine {
        0% {
            background-position: 140% 140%;
        }

        55%, 100% {
            background-position: -60% -60%;
        }
    }

    /* Özet panelindeki "ödül seni bekliyor" çipi */
    .pp-ach-chip.ready {
        background: linear-gradient(135deg, rgba(255, 215, 130, 0.28), rgba(205, 164, 94, 0.2));
        border-color: rgba(255, 215, 130, 0.65);
        animation: ppClaimGlow 2s ease-in-out infinite;
    }

    /* --- Madalyon --- */
    .pp-ach-medal-wrap {
        position: relative;
        width: 58px;
        height: 58px;
        margin: 2px auto 10px;
    }

    .pp-ach-medal {
        width: 100%;
        height: 100%;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.3rem;
        color: var(--ti);
        background: linear-gradient(135deg, var(--tg1), var(--tg2));
        box-shadow: 0 6px 14px rgba(0, 0, 0, 0.18), inset 0 -2px 4px rgba(0, 0, 0, 0.15), inset 0 2px 4px rgba(255, 255, 255, 0.35);
        position: relative;
        overflow: hidden;
    }

    .pp-ach-card.earned .pp-ach-medal::after {
        content: '';
        position: absolute;
        inset: 0;
        border-radius: 50%;
        background: linear-gradient(115deg, transparent 38%, rgba(255,255,255,0.5) 50%, transparent 62%);
        background-size: 250% 250%;
        animation: ppBadgeShine 3.8s ease-in-out infinite;
    }

    .pp-ach-card.locked .pp-ach-medal {
        background: linear-gradient(135deg, #ddd3c2, #b9ad99);
        color: #f8f4ec;
        box-shadow: none;
    }

    .pp-ach-lock {
        position: absolute;
        bottom: -3px;
        right: -3px;
        width: 21px;
        height: 21px;
        border-radius: 50%;
        background: #8b6f47;
        color: #f5f0e8;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.55rem;
        border: 2px solid #fff9f0;
    }

    .pp-ach-check {
        position: absolute;
        top: 10px;
        right: 10px;
        width: 22px;
        height: 22px;
        border-radius: 50%;
        background: linear-gradient(135deg, #7bc47f, #4e9a54);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.6rem;
        box-shadow: 0 3px 8px rgba(78, 154, 84, 0.35);
    }

    /* --- Kart içeriği --- */
    .pp-ach-tier {
        display: inline-block;
        font-size: 0.55rem;
        font-weight: 800;
        letter-spacing: 1.2px;
        text-transform: uppercase;
        color: #6b5541;
        background: rgba(139, 111, 71, 0.1);
        padding: 2px 9px;
        border-radius: 20px;
        margin: 0 auto 7px;
    }

    .pp-ach-card.earned .pp-ach-tier {
        background: transparent;
        border: 1px solid var(--tb);
    }

    .pp-ach-name {
        font-size: 0.85rem;
        font-weight: 800;
        color: #4a3f35;
        margin: 0 0 4px;
        font-family: 'Georgia', serif;
    }

    .pp-ach-desc {
        font-size: 0.67rem;
        color: #8b7a66;
        line-height: 1.35;
        margin: 0 0 10px;
        flex-grow: 1;
    }

    .pp-ach-progress {
        margin-top: auto;
    }

    .pp-ach-track {
        background: #efe6d6;
        border-radius: 6px;
        height: 6px;
        overflow: hidden;
    }

        .pp-ach-track .pp-ach-fill {
            background: linear-gradient(90deg, var(--tg1), var(--tg2));
        }

    .pp-ach-nums {
        display: flex;
        justify-content: space-between;
        font-size: 0.61rem;
        color: #a08b6d;
        margin-top: 5px;
        font-weight: 600;
    }

    .pp-ach-date {
        font-size: 0.64rem;
        color: #4e9a54;
        font-weight: 700;
        margin-top: auto;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 5px;
    }

    .pp-ach-reward {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        font-size: 0.6rem;
        font-weight: 800;
        color: #2e93a8;
        background: rgba(86, 196, 216, 0.12);
        padding: 2px 9px;
        border-radius: 20px;
        margin: 8px auto 0;
    }

    /* --- Başarımlar mobil --- */
    @@media (max-width: 768px) {
        .pp-ach-hero {
            padding: 16px;
            gap: 14px;
            border-radius: 16px;
            margin-bottom: 20px;
        }

        .pp-ach-ring-wrap {
            width: 90px;
            height: 90px;
        }

        .pp-ach-ring-label b {
            font-size: 1.05rem;
        }

        .pp-ach-hero-title {
            font-size: 0.98rem;
        }

        .pp-ach-hero-sub {
            font-size: 0.72rem;
            margin-bottom: 10px;
        }

        .pp-ach-chip {
            font-size: 0.64rem;
            padding: 4px 10px;
        }

        .pp-ach-grid {
            grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
            gap: 10px;
        }

        .pp-ach-card:hover {
            transform: none; /* Dokunmatikte kayma yok */
        }

        .pp-ach-cat-track {
            width: 64px;
        }

        /* ===== MOBİL PERFORMANS OPTİMİZASYONU (telefonda kasmayı önler) ===== */

        /* 1) Akordeon: grid-template-rows geçişi her karede layout reflow tetikleyip
              kasmaya yol açar. Mobilde yükseklik ANINDA açılır/kapanır; yerine
              yalnızca ucuz (compositor) opacity fade ile yumuşaklık korunur. */
        .pp-ach-cat-body {
            transition: none;
        }

        .pp-ach-cat-inner-pad {
            transition: opacity 0.22s ease;
        }

        .pp-ach-cat.collapsed .pp-ach-cat-inner-pad {
            opacity: 0;
        }

        /* 2) Sürekli tekrar eden pahalı animasyonlar (box-shadow / background-position
              repaint'i) mobilde kapatılır — asıl kasma kaynağı bunlar. */
        .pp-ach-card.earned .pp-ach-medal::after {
            animation: none;
        }

        .pp-ach-claim {
            animation: none;
        }

        .pp-ach-chip.ready {
            animation: none;
        }

        /* 3) Kart geçişleri mobilde gereksiz (hover yok) — kaldırılır. */
        .pp-ach-card {
            transition: none;
        }
    }

    @@media (prefers-reduced-motion: reduce) {
        .pp-ach-ring-fill,
        .pp-ach-fill {
            transition: none;
        }

        .pp-ach-card.earned .pp-ach-medal::after {
            animation: none;
        }
    }
</style>

@{
    var ppAllAch = ViewBag.AllAchievements as List<BookManagementApp.Models.Achievement> ?? new List<BookManagementApp.Models.Achievement>();
    var ppAchStats = ViewBag.AchievementStats as Dictionary<string, int> ?? new Dictionary<string, int>();
    var ppEarnedMap = (Model.UserAchievements ?? new List<BookManagementApp.Models.UserAchievement>())
        .GroupBy(ua => ua.AchievementId)
        .ToDictionary(g => g.Key, g => g.Min(x => x.EarnedDate));

    bool ppIsOwner = ViewBag.LoggedInUserId == Model.Id;

    // Kategori bazlı kullanıcı metriği yardımcı fonksiyonu
    Func<BookManagementApp.Models.Achievement, int> ppStatOf = a =>
        ppAchStats.TryGetValue(a.Category ?? "", out int sv) ? sv : 0;

    // Durum kuralları:
    //  - meets   : kullanıcı başarımın hedefini karşılıyor mu (ör. 100 kitap)
    //  - earned  : kayıt VAR *ve* hedef karşılanıyor (yalnızca kayıt olması yetmez).
    //    Bu, eski otomatik sistemden / başarım Id'lerinin yeniden kullanımından kalan
    //    geçersiz kayıtları düzeltir: 61 kitapla 500 kitaplık başarım "kazanıldı" görünmez.
    //  - claimable: sahibi, kaydı yok ama hedefi karşılıyor → ödülü manuel toplayabilir.
    Func<BookManagementApp.Models.Achievement, bool> ppMeets = a => ppStatOf(a) >= a.TargetValue;
    Func<BookManagementApp.Models.Achievement, bool> ppEarned = a => ppEarnedMap.ContainsKey(a.Id) && ppMeets(a);
    Func<BookManagementApp.Models.Achievement, bool> ppClaimable = a => ppIsOwner && !ppEarnedMap.ContainsKey(a.Id) && ppMeets(a);

    int ppAchTotal = ppAllAch.Count;
    int ppAchEarnedCount = ppAllAch.Count(ppEarned);
    int ppAchPercent = ppAchTotal > 0 ? (int)Math.Round(ppAchEarnedCount * 100.0 / ppAchTotal) : 0;
    int ppAchStones = ppAllAch.Where(ppEarned).Sum(a => a.RewardStones);

    // Sahibi için: tamamlanmış ama henüz toplanmamış (toplanabilir) başarımlar
    int ppClaimableCount = ppAllAch.Count(ppClaimable);

    var ppLastEarned = ppAllAch
        .Where(ppEarned)
        .OrderByDescending(a => ppEarnedMap[a.Id])
        .FirstOrDefault();

    var ppTr = new System.Globalization.CultureInfo("tr-TR");
    string[] ppTierNames = { "", "Bronz", "Gümüş", "Altın", "Platin", "Elmas", "Efsane" };

    var ppCatOrder = new List<string> { "Okuma", "Odaklanma", "İstikrar", "Sosyal", "Etkileşim", "Bilgelik" };
    var ppCatMeta = new Dictionary<string, (string Icon, string Slogan)>
    {
        ["Okuma"] = ("fa-book-open", "Sayfalar arasında bir yolculuk"),
        ["Odaklanma"] = ("fa-stopwatch", "Derin çalışmanın gücü"),
        ["İstikrar"] = ("fa-fire", "Her gün bir adım daha"),
        ["Sosyal"] = ("fa-users", "Okur topluluğunun bir parçası ol"),
        ["Etkileşim"] = ("fa-comments", "Düşüncelerini dünyayla paylaş"),
        ["Bilgelik"] = ("fa-gem", "Bilgelik taşı hazineni büyüt")
    };

    var ppAchGroups = ppAllAch
        .GroupBy(a => a.Category ?? "Diğer")
        .OrderBy(g => { int oi = ppCatOrder.IndexOf(g.Key); return oi < 0 ? 99 : oi; })
        .ToList();
}

<!-- ÖZET PANELİ -->
<div class="pp-ach-hero">
    <div class="pp-ach-ring-wrap">
        <svg class="pp-ach-ring" viewBox="0 0 120 120" aria-hidden="true">
            <defs>
                <linearGradient id="ppAchGold" x1="0%" y1="0%" x2="100%" y2="100%">
                    <stop offset="0%" stop-color="#ffd782" />
                    <stop offset="100%" stop-color="#cda45e" />
                </linearGradient>
            </defs>
            <circle class="pp-ach-ring-bg" cx="60" cy="60" r="52"></circle>
            <circle class="pp-ach-ring-fill" id="ppAchRing" cx="60" cy="60" r="52" data-percent="@ppAchPercent"></circle>
        </svg>
        <div class="pp-ach-ring-label">
            <b>%@ppAchPercent</b>
            <span>Tamamlandı</span>
        </div>
    </div>
    <div class="pp-ach-hero-body">
        <div class="pp-ach-hero-title"><i class="fa-solid fa-trophy" style="color:#ffd782;"></i> Başarım Koleksiyonu</div>
        <div class="pp-ach-hero-sub">Her başarım, okuma yolculuğunun bir nişanesi.</div>
        <div class="pp-ach-hero-chips">
            <span class="pp-ach-chip"><i class="fa-solid fa-medal"></i> <b>@ppAchEarnedCount</b>/@ppAchTotal başarım</span>
            <span class="pp-ach-chip"><i class="fa-solid fa-gem"></i> <b>@ppAchStones.ToString("N0", ppTr)</b> taş kazanıldı</span>
            @if (ppClaimableCount > 0)
            {
                <span class="pp-ach-chip ready"><i class="fa-solid fa-gift"></i> <b>@ppClaimableCount</b> ödül seni bekliyor</span>
            }
            else if (ppLastEarned != null)
            {
                <span class="pp-ach-chip"><i class="fa-solid fa-wand-magic-sparkles"></i> Son: <b>@ppLastEarned.Name</b></span>
            }
        </div>
    </div>
</div>

<!-- KATEGORİ SERİLERİ -->
@foreach (var achGroup in ppAchGroups)
{
    var catMeta = ppCatMeta.TryGetValue(achGroup.Key, out var cm) ? cm : ("fa-layer-group", "");
    var catItems = achGroup.OrderBy(a => a.Tier).ThenBy(a => a.TargetValue).ToList();
    int catEarned = catItems.Count(ppEarned);
    int catPct = catItems.Count > 0 ? (int)Math.Round(catEarned * 100.0 / catItems.Count) : 0;
    int catUserStat = ppAchStats.TryGetValue(achGroup.Key, out int sv) ? sv : 0;
    int catClaimable = catItems.Count(ppClaimable); // Bu seride toplanmayı bekleyen ödül sayısı
    bool catCollapsed = true; // Tüm seriler varsayılan olarak KAPALI başlar

    <div class="pp-ach-cat @(catCollapsed ? "collapsed" : "")"
         id="@BookManagementApp.Models.Achievement.CategoryAnchor(achGroup.Key)"
         data-ach-cat="@achGroup.Key">
        <button type="button" class="pp-ach-cat-head" onclick="toggleAchCat(this)" aria-expanded="@(catCollapsed ? "false" : "true")">
            <div class="pp-ach-cat-icon">
                <i class="fa-solid @catMeta.Item1"></i>
                @if (catClaimable > 0)
                {
                    <span class="pp-ach-cat-badge" title="@catClaimable ödül toplanmayı bekliyor">@catClaimable</span>
                }
            </div>
            <div class="pp-ach-cat-info">
                <div class="pp-ach-cat-name">@achGroup.Key Serisi</div>
                <div class="pp-ach-cat-sub">@catMeta.Item2</div>
            </div>
            <div class="pp-ach-cat-right">
                <div class="pp-ach-cat-count">@catEarned / @catItems.Count</div>
                <div class="pp-ach-cat-track"><div class="pp-ach-fill" data-width="@catPct"></div></div>
            </div>
            <i class="fa-solid fa-chevron-down pp-ach-cat-chevron"></i>
        </button>

        <div class="pp-ach-cat-body">
            <div class="pp-ach-cat-inner">
                <div class="pp-ach-cat-inner-pad">
                    <div class="pp-ach-grid">
                        @foreach (var ach in catItems)
                        {
                            // Kazanıldı = kayıt VAR ve hedef hâlâ karşılanıyor (geçersiz eski kayıtları eler)
                            bool hasRecord = ppEarnedMap.ContainsKey(ach.Id);
                            bool meetsTarget = catUserStat >= ach.TargetValue;
                            bool isEarned = hasRecord && meetsTarget;
                            // Toplanabilir: yalnızca profil sahibi, kaydı yok ve hedefe ulaşılmış
                            bool canClaim = ppIsOwner && !hasRecord && meetsTarget;
                            int achTier = Math.Clamp(ach.Tier, 1, 6);
                            double achPct = isEarned ? 100 : (ach.TargetValue > 0 ? Math.Min(100, catUserStat * 100.0 / ach.TargetValue) : 0);
                            string achPctStr = achPct.ToString("0.#", System.Globalization.CultureInfo.InvariantCulture);
                            string achState = isEarned ? "earned" : (canClaim ? "claimable" : "locked");

                            <div class="pp-ach-card t@(achTier) @achState"
                                 title="@ach.Name — @ach.Description">
                                @if (isEarned)
                                {
                                    <div class="pp-ach-check"><i class="fa-solid fa-check"></i></div>
                                }
                                <div class="pp-ach-medal-wrap">
                                    <div class="pp-ach-medal"><i class="fa-solid @ach.IconClass"></i></div>
                                    @if (!isEarned && !canClaim)
                                    {
                                        <div class="pp-ach-lock"><i class="fa-solid fa-lock"></i></div>
                                    }
                                </div>
                                <span class="pp-ach-tier">@ppTierNames[achTier]</span>
                                <h6 class="pp-ach-name">@ach.Name</h6>
                                <p class="pp-ach-desc">@ach.Description</p>

                                @if (isEarned)
                                {
                                    <div class="pp-ach-date">
                                        <i class="fa-solid fa-circle-check"></i>
                                        @ppEarnedMap[ach.Id].ToString("d MMMM yyyy", ppTr)
                                    </div>

                                    @* Etiketi profilde gösterme seçeneği yalnızca profil sahibine açık *@
                                    @if (ppIsOwner)
                                    {
                                        bool isTitleEquipped = Model.ActiveTitleAchievementId == ach.Id;

                                        <button type="button"
                                                class="pp-ach-title-btn @(isTitleEquipped ? "equipped" : "")"
                                                data-ach-id="@ach.Id"
                                                onclick="toggleProfileTitle(@ach.Id, this)">
                                            @if (isTitleEquipped)
                                            {
                                                <text><i class="fa-solid fa-id-badge"></i> <span>Profilde görünüyor</span></text>
                                            }
                                            else
                                            {
                                                <text><i class="fa-regular fa-id-badge"></i> <span>Profilde göster</span></text>
                                            }
                                        </button>
                                    }
                                }
                                else if (canClaim)
                                {
                                    <button type="button" class="pp-ach-claim" onclick="claimAchievement(@ach.Id, this)">
                                        <i class="fa-solid fa-gift"></i>
                                        @if (ach.RewardStones > 0)
                                        {
                                            <span>Ödülü Topla +@ach.RewardStones.ToString("N0", ppTr)</span>
                                        }
                                        else
                                        {
                                            <span>Başarımı Topla</span>
                                        }
                                    </button>
                                }
                                else
                                {
                                    <div class="pp-ach-progress">
                                        <div class="pp-ach-track"><div class="pp-ach-fill" data-width="@achPctStr"></div></div>
                                        <div class="pp-ach-nums">
                                            <span>@Math.Min(catUserStat, ach.TargetValue).ToString("N0", ppTr) / @ach.TargetValue.ToString("N0", ppTr)</span>
                                            <span>%@((int)achPct)</span>
                                        </div>
                                    </div>
                                    @if (ach.RewardStones > 0)
                                    {
                                        <span class="pp-ach-reward"><i class="fa-solid fa-gem"></i> +@ach.RewardStones.ToString("N0", ppTr) taş</span>
                                    }
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@* Modaldan "#ach-istikrar" gibi bir çapayla gelindiğinde ilgili seriyi açıp oraya kaydırır. *@
<script>
    (function () {
        function openFromHash() {
            var hash = window.location.hash;
            if (!hash || hash.indexOf('#ach-') !== 0) return;

            var target = document.getElementById(hash.substring(1));
            if (!target) return;

            target.classList.remove('collapsed');
            var head = target.querySelector('.pp-ach-cat-head');
            if (head) head.setAttribute('aria-expanded', 'true');

            // Sayfa yerleşimi otursun diye bir tık bekle
            setTimeout(function () {
                target.scrollIntoView({ behavior: 'smooth', block: 'start' });
                target.classList.add('pp-ach-cat-focus');
                setTimeout(function () { target.classList.remove('pp-ach-cat-focus'); }, 2200);
            }, 220);
        }

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', openFromHash);
        } else {
            openFromHash();
        }

        // Zaten açık sayfada çapa değişirse de çalışsın
        window.addEventListener('hashchange', openFromHash);
    })();
</script>
