        }

        .avatar-grid {
            grid-template-columns: repeat(3, 1fr);
            gap: 10px;
        }

        .avatar-option {
            width: 55px;
            height: 55px;
        }

        .d-flex.justify-content-between.mb-2 {
            flex-direction: column;
            align-items: flex-start !important;
            gap: 5px;
        }

            .d-flex.justify-content-between.mb-2 > div {
                width: 100%;
                display: flex;
                justify-content: flex-start; /* Sola yasla ve birleşik olsun */
                gap: 10px; /* Hedef yazısı, sayı ve ikon arasına boşluk koy */
                align-items: center;
            }
    }

    /* Landscape Mobile için ek düzenleme */
    @@media (max-width: 768px) and (orientation: landscape) {
        .stats-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .bottom-grid {
            grid-template-columns: 1fr 1fr;
        }

        .profile-header-card {
            flex-direction: row;
            text-align: left;
        }

            .profile-header-card::before {
                width: 6px;
                height: 100%;
                top: 0;
                bottom: 0;
                left: 0;
            }

        .avatar-wrapper {
            margin-bottom: 0;
        }
    }
</style>

<div class="profile-container">

    <div class="profile-header-card">
        <div class="profile-avatar" style="position: relative; width: 100px; height: 100px; border-radius: 15px; border: 4px solid #fff; box-shadow: 0 5px 15px rgba(107, 85, 65, 0.15); display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, #fff9f0 0%, #e6dac8 100%); color: #5c4b3d; font-size: 3rem; font-weight: 700; flex-shrink: 0;">
            <div style="width: 100%; height: 100%; border-radius: 11px; overflow: hidden; display: flex; align-items: center; justify-content: center;">
                @if (!string.IsNullOrEmpty(Model.ProfileImageUrl))
                {
                    <img src="@Model.ProfileImageUrl" alt="Profil Fotoğrafi" style="width: 100%; height: 100%; object-fit: cover;">
                }
                else
                {
                    @Model.UserName.Substring(0, 1).ToUpper()
                }
            </div>

            @if (!string.IsNullOrEmpty(ViewBag.ActiveFrameImageUrl as string))
            {
                <img src="@ViewBag.ActiveFrameImageUrl" style="position: absolute; top: -15%; left: -15%; width: 130%; height: 130%; pointer-events: none; z-index: 10; object-fit: contain;" />
            }
        </div>

        <div class="profile-info">
            <h1>Merhaba, @Model.UserName</h1>
            @if (Model.User != null && !string.IsNullOrEmpty(Model.User.Bio))
            {
                <p style="color: #4a3f35; font-size: 1rem; margin-bottom: 10px; font-weight: 500;">
                    "@Model.User.Bio"
                </p>
            }
            <p>
                <i class="fa-solid fa-calendar-check"></i>
                @Model.JoinDate.ToString("MMMM yyyy") tarihinden beri üyesiniz.
            </p>
        </div>

        <a href="/Profile/Edit" class="btn-edit-profile">
            <i class="fa-solid fa-user-pen"></i> Profili Düzenle
        </a>
    </div>

    <div class="stats-grid">
        <div class="stat-card card-book">
            <i class="fa-solid fa-book stat-icon-bg"></i>
            <div class="stat-icon"><i class="fa-solid fa-book-open"></i></div>
            <div class="stat-label">Toplam Kitap</div>
            <div class="stat-value">@Model.TotalBooks</div>
            <div class="stat-sub">Kütüphanendeki eserler</div>
        </div>
        <div class="stat-card card-cat">
            <i class="fa-solid fa-tags stat-icon-bg"></i>
            <div class="stat-icon"><i class="fa-solid fa-layer-group"></i></div>
            <div class="stat-label">Kategori</div>
            <div class="stat-value">@Model.TotalCategories</div>
            <div class="stat-sub">Farklı türde okumalar</div>
        </div>
        <div class="stat-card card-page">
            <i class="fa-solid fa-scroll stat-icon-bg"></i>
            <div class="stat-icon"><i class="fa-solid fa-file-lines"></i></div>
            <div class="stat-label">Toplam Sayfa</div>
            <div class="stat-value">@Model.TotalPagesRead.ToString("N0")</div>
            <div class="stat-sub">Kelime kelime bilgi</div>
        </div>
        <div class="stat-card card-money">
            <i class="fa-solid fa-coins stat-icon-bg"></i>
            <div class="stat-icon"><i class="fa-solid fa-turkish-lira-sign"></i></div>
            <div class="stat-label">Yatırım</div>
            <div class="stat-value">@Model.TotalMoneySpent.ToString("N0") ₺</div>
            <div class="stat-sub">Kitaplara yapılan yatırım</div>
        </div>
    </div>

    <div class="bottom-grid">
        <div class="feature-card">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div class="feature-title mb-0"><i class="fa-solid fa-bullseye" style="color: #a0785a;"></i> Okuma Hedefim</div>

                <div class="btn-group btn-group-sm" role="group">
                    <button type="button" class="btn btn-outline-secondary active" id="btnShowMonthly" onclick="switchGoal('monthly')">Aylık</button>
                    <button type="button" class="btn btn-outline-secondary " id="btnShowYearly" onclick="switchGoal('yearly')">Yıllık</button>
                </div>
            </div>

            <div id="yearlyGoalSection" style="display: none;">
                <div class="d-flex justify-content-between mb-2 align-items-center">
                    <span style="font-weight:bold; color:#4a3f35;">@Model.BooksReadThisYear Kitap (Yıllık)</span>
                    <div style="color:#8b6f47;">
                        Hedef:
                        @if (Model.YearlyReadingGoal == 0)
                        {
                            <text><i>Yok</i></text>
                        }
                        else
                        {
                            <b>@Model.YearlyReadingGoal</b>
                        }
                        <a href="javascript:void(0)" class="ms-2" style="color: #a0785a;" data-bs-toggle="modal" data-bs-target="#goalModal">
                            <i class="fa-solid fa-pen-to-square"></i>
                        </a>
                    </div>
                </div>

                <div class="progress-container">
                    <div class="progress-bar-custom" id="yearlyProgressBar" style="width: 0%" data-width="@yearlyProgress%">@yearlyProgress%</div>
                </div>

                <p style="font-size:0.9rem; color:#666; margin-top:10px;" id="yearlyMessage">
                    @if (yearlyProgress == 0)
                    {
                        <span>"Bin millik bir yolculuk tek bir adımla başlar." - Lao Tzu</span>
                    }
                    else if (yearlyProgress < 25)
                    {
                        <span>Başlangıç harika! Ritmi yakaladın, devam et. 🚀</span>
                    }
                    else if (yearlyProgress < 50)
                    {
                        <span>Yolu yarılamaya az kaldı! Kitapların dünyası seni bekliyor. 📖</span>
                    }
                    else if (yearlyProgress < 75)
                    {
                        <span>Yarıyı geçtin! Harika bir okuma disiplinin var. 🔥</span>
                    }
                    else if (yearlyProgress < 100)
                    {
                        <span>Çok az kaldı! Hedefine ulaşmak üzeresin, son düzlük! 🏁</span>
                    }
                    else
                    {
                        <span>🏆 TEBRİKLER! Yıllık hedefini tamamladın! Sen gerçek bir kitap kurdusun! 🥇</span>
                    }
                </p>
            </div>

            <div id="monthlyGoalSection">
                <div class="d-flex justify-content-between mb-2 align-items-center">
                    <span style="font-weight:bold; color:#4a3f35;">
                        @monthlyRead Sayfa <small class="text-muted">(Okunan)</small>
                    </span>

                    <div style="color:#8b6f47;">
                        Hedef:
                        @if (monthlyGoal == 0)
                        {
                            <text><i>Belirlenmedi</i></text>
                        }
                        else
                        {
                            <b>@monthlyGoal</b>
                        }
                        <a href="javascript:void(0)" class="ms-2" style="color: #a0785a;" data-bs-toggle="modal" data-bs-target="#monthlyGoalModal">
                            <i class="fa-solid fa-pen-to-square"></i>
                        </a>
                    </div>
                </div>

                <div class="progress-container">
                    <div class="progress-bar-custom" id="monthlyProgressBar" style="width: 0%; background: linear-gradient(90deg, #48bb78, #38a169);" data-width="@monthlyProgress%">@monthlyProgress%</div>
                </div>

                <p style="font-size:0.9rem; color:#666; margin-top:10px;" id="monthlyMessage">
                    @if (monthlyProgress == 0)
                    {
                        <span>"Henüz başlamadın mı? Hadi bir sayfa çevir! 📖"</span>
                    }
                    else if (monthlyProgress < 25)
                    {
                        <span>Sayfalar akmaya başladı. Harika gidiyorsun! 🚀</span>
                    }
                    else if (monthlyProgress < 75)
                    {
                        <span>Yarıyı geçtin! Kitapların dünyasında kaybolmak gibisi yok. 🔥</span>
                    }
                    else if (monthlyProgress < 100)
                    {
                        <span>Son sayfalar! Bu ayın şampiyonu olmak üzeresin. 🏁</span>
                    }
                    else
                    {
                        <span>🏆 TEBRİKLER! Aylık sayfa hedefini tamamladın! 🥇</span>
                    }
                </p>
            </div>

            <div class="motivation-quote-area mt-4" style="border-top: 1px dashed rgba(139, 111, 71, 0.2); padding-top: 15px; text-align: center;">
                <p id="dailyQuoteText" style="font-family: 'Georgia', serif; font-size: 0.95rem; color: #6b5541; font-style: italic; margin-bottom: 5px; line-height: 1.4;">
                </p>
                <small id="dailyQuoteAuthor" style="color: #8b6f47; font-weight: 600; font-size: 0.8rem; letter-spacing: 0.5px;">
                </small>
            </div>
        </div>

        <div class="feature-card">
            <div class="feature-title">
                <i class="fa-solid fa-stopwatch" style="color: #a0785a;"></i> Çalışma İstatistikleri
            </div>

            <ul class="study-stats-list">
                <li class="study-stat-item">
                    <div class="study-stat-label">
                        <i class="fa-solid fa-sun" style="color: #ff9800;"></i> Bugün
                    </div>
                    <div class="study-stat-value">
                        @if (todayHours > 0)
                        {
                            <text>@todayHours<span>sa</span></text>
                        }
                        @todayMins<span>dk</span>
                    </div>
                </li>

                <li class="study-stat-item">
                    <div class="study-stat-label">
                        <i class="fa-solid fa-calendar-days" style="color: #2196f3;"></i> Bu Ay
                    </div>
                    <div class="study-stat-value">
                        @if (monthHours > 0)
                        {
                            <text>@monthHours<span>sa</span></text>
                        }
                        @monthMins<span>dk</span>
                    </div>
                </li>

                <li class="study-stat-item">
                    <div class="study-stat-label">
                        <i class="fa-solid fa-fire" style="color: #f44336;"></i> Tamamlanan Pomodoro
                    </div>
                    <div class="study-stat-value">
                        @Model.TotalPomodoroCompleted <span>adet</span>
                    </div>
                </li>
            </ul>

            <div class="text-center mt-3">
                <a href="/Pomodoro/Index" class="btn btn-sm" style="background: #e8dcc8; color: #6b5541; font-weight: 600; border-radius: 20px; padding: 5px 15px;">
                    <i class="fa-solid fa-play"></i> Odaklanma Odasına Git
                </a>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="avatarModal" tabindex="-1" aria-labelledby="avatarModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content custom-modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="avatarModalLabel"><i class="fa-solid fa-user-pen"></i> Profil Fotoğrafı Seç</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <ul class="nav nav-tabs mb-3" id="avatarTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" id="select-tab" data-bs-toggle="tab" data-bs-target="#select-pane" type="button" role="tab">Hazır Avatar</button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="upload-tab" data-bs-toggle="tab" data-bs-target="#upload-pane" type="button" role="tab">Fotoğraf Yükle</button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="frame-tab" data-bs-toggle="tab" data-bs-target="#frame-pane" type="button" role="tab"><i class="fa-solid fa-gem" style="color: #00ffff; text-shadow: 0 0 5px rgba(0,255,255,0.4);"></i> Çerçeveler</button>
                    </li>
                </ul>

                <div class="tab-content" id="avatarTabsContent">
                    <div class="tab-pane fade show active" id="select-pane" role="tabpanel">
                        <div class="text-center mb-2 text-muted small">Koleksiyonundaki avatarlardan birini seç:</div>
                        <div class="avatar-grid" style="max-height: 250px; overflow-y: auto; padding-right: 10px; display: grid; grid-template-columns: repeat(4, 1fr); gap: 15px; justify-items: center;">
                            @if (ViewBag.Avatars != null)
                            {
                                foreach (var avatar in ViewBag.Avatars)
                                {
                                    <img src="@avatar.ImageUrl" class="avatar-option" onclick="selectAvatar(this)" title="@avatar.Name">
                                }
                            }
                        </div>
                    </div>

                    <div class="tab-pane fade" id="upload-pane" role="tabpanel">
                        <div class="mb-3 text-center">
                            <label for="customAvatarFile" class="form-label text-muted">Bilgisayarından bir fotoğraf seç</label>
                            <input class="form-control" type="file" id="customAvatarFile" accept="image/*">
                        </div>
                        <div class="text-center mt-3">
                            <div id="uploadPreview" style="width: 100px; height: 100px; border-radius: 50%; background: #e8dcc8; margin: 0 auto; display: flex; align-items: center; justify-content: center; overflow: hidden;">
                                <span class="text-muted small">Önizleme</span>
                            </div>
                        </div>
                    </div>

                    <div class="tab-pane fade" id="frame-pane" role="tabpanel">
                        @{
                            var ownedFrames = ViewBag.OwnedFrames as List<BookManagementApp.Areas.Admin.Models.ProfileFrame>;
                            var activeFrame = ViewBag.ActiveFrameImageUrl as string;
                        }
                        @if (ownedFrames != null && ownedFrames.Any())
                        {
                            <div class="text-center mb-2 text-muted small">Sahip olduğun çerçevelerden birini seç:</div>
                            <div class="text-center mt-2">
                                <form asp-action="EquipFrame" asp-controller="Store" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="0" />
                                    <input type="hidden" name="returnUrl" value="/Profile" />
                                    <button type="submit" class="btn btn-sm" style="background: #e8dcc8; color: #6b5541; border-radius: 20px; font-size: 0.8rem; font-weight: 600;">Çerçeveyi Kaldır</button>
                                </form>
                            </div>
                            <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; padding: 10px 0;">
                                @foreach (var frame in ownedFrames)
                                {
                                    bool isActive = activeFrame == frame.ImageUrl;
                                    <form asp-action="EquipFrame" asp-controller="Store" method="post" style="text-align: center;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@frame.Id" />
                                        <button type="submit" style="background: none; border: none; cursor: pointer; padding: 0; transition: transform 0.2s;" title="@frame.Name">
                                            <div style="position: relative; width: 70px; height: 70px; border-radius: 15px; display: flex; align-items: center; justify-content: center; font-size: 1.8rem; background: linear-gradient(135deg, #fff9f0 0%, #e6dac8 100%); color: #5c4b3d; font-weight: 700; margin: 0 auto;">
                                                <div style="width: 100%; height: 100%; border-radius: 15px; overflow: hidden; display: flex; align-items: center; justify-content: center;">
                                                    @if (!string.IsNullOrEmpty(Model.ProfileImageUrl))
                                                    {
                                                        <img src="@Model.ProfileImageUrl" style="width:100%; height:100%; object-fit:cover;" />
                                                    }
                                                    else
                                                    {
                                                        @Model.UserName.Substring(0, 1).ToUpper()
                                                    }
                                                </div>
                                                @if (!string.IsNullOrEmpty(frame.ImageUrl))
                                                {
                                                    <img src="@frame.ImageUrl" style="position: absolute; top: -15%; left: -15%; width: 130%; height: 130%; pointer-events: none; z-index: 10; object-fit: contain;" />
                                                }
                                            </div>
                                            <div style="font-size: 0.7rem; margin-top: 5px; color: @(isActive ? "#27ae60" : "#8b6f47"); font-weight: 700;">@frame.IconEmoji @frame.Name</div>
                                            @if (isActive)
                                            {
                                                <div style="font-size: 0.65rem; color: #27ae60;">✓ Aktif</div>
                                            }
                                        </button>
                                    </form>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="text-center py-4">
                                <i class="fa-solid fa-store" style="font-size: 2.5rem; color: #e8dcc8; margin-bottom: 10px;"></i>
                                <p style="color: #8b6f47; font-size: 0.9rem;">Henüz çerçeven yok!</p>
                                <a asp-controller="Store" asp-action="Index" class="btn btn-sm" style="background: linear-gradient(135deg, #8b6f47, #6b5541); color: #fff; border-radius: 20px; padding: 8px 20px; font-weight: 600;">Mağazaya Git</a>
                            </div>
                        }
                    </div>
                </div>
            </div>
            <div class="modal-footer" style="border-top: none;">
                <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">İptal</button>
                <button type="button" class="btn btn-sm btn-save-custom" id="saveAvatarBtn">Kaydet</button>
            </div>
        </div>
    </div>
</div>
<div class="modal fade" id="monthlyGoalModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content custom-modal-content">
            <div class="modal-header custom-header border-0 pb-3">
                <h5 class="modal-title fs-5">
                    <i class="fa-solid fa-chart-pie me-2" style="color:#8b6f47"></i> Aylık İlerleme
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body px-4 py-3">

                <label class="small fw-bold text-muted mb-2 text-uppercase" style="letter-spacing: 1px;">Okunan Sayfa</label>
                <div class="input-group goal-input-group mb-4">
                    <span class="input-group-text"><i class="fa-solid fa-book-open"></i></span>
                    <input type="number" id="manualReadInput" class="form-control" value="@monthlyRead" placeholder="Örn: 45">
                </div>

                <label class="small fw-bold text-muted mb-2 text-uppercase" style="letter-spacing: 1px;">Aylık Hedef</label>
                <div class="input-group goal-input-group">
                    <span class="input-group-text"><i class="fa-solid fa-flag-checkered"></i></span>
                    <input type="number" id="manualGoalInput" class="form-control" value="@monthlyGoal" placeholder="Örn: 1000">
                </div>

            </div>
            <div class="modal-footer border-0 px-4 pb-4 pt-0 d-flex flex-nowrap gap-2">
                <button type="button" class="modal-btn-cancel flex-fill" data-bs-dismiss="modal">İptal</button>
                <button type="button" class="btn-save-custom flex-fill" id="saveMonthlyGoalBtn">Kaydet</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="goalModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content custom-modal-content">
            <div class="modal-header custom-header border-0 pb-3">
                <h5 class="modal-title fs-5">
                    <i class="fa-solid fa-trophy me-2" style="color:#8b6f47"></i> Yıllık Hedef
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body px-4 py-4">

                <label class="small fw-bold text-muted mb-2 text-uppercase" style="letter-spacing: 1px;">Yıllık Kitap Hedefi</label>
                <div class="input-group goal-input-group">
                    <span class="input-group-text"><i class="fa-solid fa-book-bookmark"></i></span>
                    <input type="number" id="newGoalInput" class="form-control" value="@Model.YearlyReadingGoal" min="1" max="1000" placeholder="Örn: 60">
                </div>

            </div>
            <div class="modal-footer border-0 px-4 pb-4 pt-0 d-flex flex-nowrap gap-2">
                <button type="button" class="modal-btn-cancel flex-fill" data-bs-dismiss="modal">İptal</button>
                <button type="button" class="btn-save-custom flex-fill" id="saveGoalBtn">Güncelle</button>
            </div>
        </div>
    </div>
</div>

<script>
    const quotes = [
        { text: "Okumak, bir insanın zihnini seyahate çıkarmasıdır.", author: "Victor Hugo" },
        { text: "Bugün okuyan, yarın yönetir.", author: "Margaret Fuller" },
        { text: "Kitapsız bir oda, ruhsuz bir beden gibidir.", author: "Marcus Tullius Cicero" },
        { text: "İyi bir kitap, en iyi arkadaştır.", author: "Jacques-Bénigne Bossuet" },
        { text: "Okumak, iki ruh arasında gizli bir sohbettir.", author: "Alphonse de Lamartine" },
        { text: "Eğer bir kitap sizi dünyadan koparamıyorsa, o kitap okunmaya değmez.", author: "Carl Sagan" },
        { text: "Bir saatlik okuma, dünyadaki bütün dertleri unutturur.", author: "Charles de Montesquieu" },
        { text: "Kitaplar, zekanın çocuklarıdır.", author: "Jonathan Swift" },
        { text: "Okuduğumuz kitaplar sadece dünyamızı değil, kendimizi de değiştirir.", author: "Haruki Murakami" },
        { text: "İlim, insanı Allah'a götüren en aydınlık yoldur.", author: "İmam Gazali" },
        { text: "Beşikten mezara kadar ilim öğreniniz.", author: "Hz. Muhammed" },
        { text: "Bilmek yetmez, uygulamalıyız. İstemek yetmez, yapmalıyız.", author: "Goethe" },
        { text: "Öğrenmeyi bıraktığın an ölmeye başlarsın.", author: "Albert Einstein" },
        { text: "Bilgi güçtür.", author: "Francis Bacon" },
        { text: "Eğitim, hayata hazırlanmak değil, hayatın ta kendisidir.", author: "John Dewey" },
        { text: "İlim Çin'de de olsa gidip alınız.", author: "Hz. Muhammed" },
        { text: "Gerçek bilgi, kişinin cehaletinin farkına varmasıyla başlar.", author: "Konfüçyüs" },
        { text: "Dünkü halinden daha iyi olmaya çalış, başkalarıyla değil kendinle yarış.", author: "Mevlana" },
        { text: "Okumayı sevmek, hayatın sıkıcı saatlerini keyifli saatlerle takas etmektir.", author: "Montesquieu" },
        { text: "Zihin bir bardak değil, yakılacak bir ateştir.", author: "Plutarkhos" },
        { text: "Ne kadar bilirsen bil, söylediklerin karşındakinin anlayabileceği kadardır.", author: "Mevlana" },
        { text: "Bugün yapabileceğini yarına bırakma.", author: "Benjamin Franklin" },
