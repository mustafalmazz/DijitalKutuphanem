    document.addEventListener("DOMContentLoaded", function () {
            // Progress bar
    setTimeout(function () {
        const bar = document.getElementById('monthlyProgressBar');
        if (bar) bar.style.width = bar.getAttribute('data-width');
    }, 300);

        // Rastgele söz
        const randomIndex = Math.floor(Math.random() * quotes.length);
        const selectedQuote = quotes[randomIndex];
        const quoteTextElement = document.getElementById('dailyQuoteText');
        const quoteAuthorElement = document.getElementById('dailyQuoteAuthor');
        if (quoteTextElement && quoteAuthorElement) {
            quoteTextElement.innerHTML = `"${selectedQuote.text}"`;
            quoteAuthorElement.innerText = `- ${selectedQuote.author}`;
        }
    });

    // --- TAB GEÇİŞ İŞLEMİ ---
    function switchGoal(type) {
        const yearlySec = document.getElementById('yearlyGoalSection');
        const monthlySec = document.getElementById('monthlyGoalSection');
        const btnYearly = document.getElementById('btnShowYearly');
        const btnMonthly = document.getElementById('btnShowMonthly');

        if (type === 'yearly') {
            yearlySec.style.display = 'block';
            monthlySec.style.display = 'none';
            btnYearly.classList.add('active');
            btnMonthly.classList.remove('active');
            setTimeout(() => {
                const bar = document.getElementById('yearlyProgressBar');
                if (bar) bar.style.width = bar.getAttribute('data-width');
            }, 100);
        } else {
            yearlySec.style.display = 'none';
            monthlySec.style.display = 'block';
            btnYearly.classList.remove('active');
            btnMonthly.classList.add('active');
            setTimeout(() => {
                const bar = document.getElementById('monthlyProgressBar');
                if (bar) bar.style.width = bar.getAttribute('data-width');
            }, 100);
        }
    }

    // --- AVATAR İŞLEMLERİ ---
    let selectedAvatarUrl = "";
    let uploadedFile = null;

    function selectAvatar(imgElement) {
        document.querySelectorAll('.avatar-option').forEach(img => img.classList.remove('selected'));
        imgElement.classList.add('selected');
        selectedAvatarUrl = imgElement.src;
        uploadedFile = null;
    }

    const fileInput = document.getElementById('customAvatarFile');
    if (fileInput) {
        fileInput.addEventListener('change', function (event) {
            const file = event.target.files[0];
            if (file) {
                uploadedFile = file;
                selectedAvatarUrl = "";
                const reader = new FileReader();
                reader.onload = function (e) {
                    document.getElementById('uploadPreview').innerHTML = `<img src="${e.target.result}" style="width:100%; height:100%; object-fit:cover;">`;
                }
                reader.readAsDataURL(file);
            }
        });
    }

    const saveAvatarBtn = document.getElementById('saveAvatarBtn');
    if (saveAvatarBtn) {
        saveAvatarBtn.addEventListener('click', function () {
            const formData = new FormData();
            if (uploadedFile) {
                formData.append('file', uploadedFile);
            } else if (selectedAvatarUrl) {
                formData.append('avatarUrl', selectedAvatarUrl);
            } else {
                alert("Lütfen bir avatar seçin veya fotoğraf yükleyin.");
                return;
            }

            const btn = this;
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Kaydediliyor...';
            btn.disabled = true;

            fetch('/Profile/UpdateAvatar', { method: 'POST', body: formData })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        location.reload();
                    } else {
                        alert("Hata: " + data.message);
                        btn.innerHTML = 'Kaydet';
                        btn.disabled = false;
                    }
                })
                .catch(error => {
                    console.error('Hata:', error);
                    alert("Bir hata oluştu.");
                    btn.innerHTML = 'Kaydet';
                    btn.disabled = false;
                });
        });
    }

    // --- YILLIK HEDEF GÜNCELLEME ---
    const saveGoalBtn = document.getElementById('saveGoalBtn');
    if (saveGoalBtn) {
        saveGoalBtn.addEventListener('click', function () {
            const newGoal = document.getElementById('newGoalInput').value;
            updateReadingGoal(newGoal, this, '/Profile/UpdateYearlyGoal');
        });
    }

    // --- AYLIK HEDEF GÜNCELLEME ---
    const saveMonthlyBtn = document.getElementById('saveMonthlyGoalBtn');
    if (saveMonthlyBtn) {
        saveMonthlyBtn.addEventListener('click', function () {
            const readVal = document.getElementById('manualReadInput').value;
            const goalVal = document.getElementById('manualGoalInput').value;

            if (goalVal < 1 || readVal < 0) {
                alert("Lütfen geçerli değerler giriniz.");
                return;
            }

            const btnElement = this;
            const oldText = btnElement.innerHTML;
            btnElement.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> ...';
            btnElement.disabled = true;

            const formData = new URLSearchParams();
            formData.append('goal', goalVal);
            formData.append('readPages', readVal);

            fetch('/Profile/UpdateMonthlyGoal', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: formData
            })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        location.reload();
                    } else {
                        alert("Hata: " + data.message);
                        btnElement.innerHTML = oldText;
                        btnElement.disabled = false;
                    }
                })
                .catch(error => {
                    console.error('Hata:', error);
                    btnElement.innerHTML = oldText;
                    btnElement.disabled = false;
                });
        });
    }

    // --- ORTAK HEDEF GÜNCELLEME FONKSİYONU ---
    function updateReadingGoal(goalValue, btnElement, endpointUrl) {
        if (goalValue < 1) {
            alert("Lütfen geçerli bir hedef giriniz.");
            return;
        }

        const oldText = btnElement.innerHTML;
        btnElement.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> ...';
        btnElement.disabled = true;

        const formData = new URLSearchParams();
        formData.append('goal', goalValue);

        fetch(endpointUrl, {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: formData
        })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    location.reload();
                } else {
                    alert("Hata: " + data.message);
                    btnElement.innerHTML = oldText;
                    btnElement.disabled = false;
                }
            })
            .catch(error => {
                console.error('Hata:', error);
                alert("Bir bağlantı hatası oluştu.");
                btnElement.innerHTML = oldText;
                btnElement.disabled = false;
            });
    }
</script>