@using BookManagementApp.Models
@using BookManagementApp.Areas.Admin.Models
@model StoreViewModel
@{
    ViewData["Title"] = "Mağaza";
    var user = ViewBag.User as User;
    var ownedFrameIds = ViewBag.OwnedFrameIds as List<int> ?? new List<int>();
    var ownedAvatarIds = ViewBag.OwnedAvatarIds as List<int> ?? new List<int>();

    var avatarCount = Model.Avatars?.Count() ?? 0;
    var frameCount = Model.Frames?.Count() ?? 0;
    var packCount = Model.Packages?.Count() ?? 0;

    var ownedAvatarCount = Model.Avatars?.Count(a => ownedAvatarIds.Contains(a.Id)) ?? 0;
    var ownedFrameCount = Model.Frames?.Count(f => ownedFrameIds.Contains(f.Id)) ?? 0;

    // Kartların üstünde gösterilecek küçük önizleme görselleri
    var avatarPreviews = Model.Avatars?.Take(4).Select(a => a.ImageUrl).ToList() ?? new List<string>();
    var framePreviews = Model.Frames?.Where(f => !string.IsNullOrEmpty(f.ImageUrl)).Take(4).Select(f => f.ImageUrl).ToList() ?? new List<string>();
    var packPreviews = Model.PackAvatars?.Take(4).Select(a => a.ImageUrl).ToList() ?? new List<string>();
}

@await Html.PartialAsync("_StoreStyles")

<style>
    .shop-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: clamp(14px, 2vw, 26px);
    }

    .shop-card {
        position: relative;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        min-height: clamp(190px, 24vw, 260px);
        padding: clamp(18px, 2.4vw, 30px);
        border-radius: 22px;
        border: 2px solid rgba(139, 111, 71, 0.12);
        background: #fff;
        box-shadow: 0 10px 30px rgba(107, 85, 65, 0.10);
        color: inherit;
        text-decoration: none;
        transition: transform 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94), box-shadow 0.35s, border-color 0.35s;
    }

        .shop-card:hover,
        .shop-card:focus-visible {
            transform: translateY(-8px);
            border-color: var(--shop-accent);
            box-shadow: 0 22px 44px rgba(107, 85, 65, 0.22);
            color: inherit;
            text-decoration: none;
        }

    /* Karta hafif renk veren köşe parıltısı */
    .shop-card::after {
        content: '';
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at 100% 0%, var(--shop-glow) 0%, transparent 55%);
        pointer-events: none;
    }

    .shop-card-top {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: auto;
    }

    .shop-icon {
        display: grid;
        place-items: center;
        flex-shrink: 0;
        width: clamp(44px, 5.2vw, 60px);
        height: clamp(44px, 5.2vw, 60px);
        border-radius: 18px;
        background: var(--shop-accent);
        color: #fff;
        font-size: clamp(1.05rem, 2vw, 1.5rem);
        box-shadow: 0 8px 18px var(--shop-glow);
    }

    .shop-badge {
        flex-shrink: 0;
        background: rgba(139, 111, 71, 0.10);
        color: #6b5541;
        border-radius: 50px;
        padding: 5px 13px;
        font-size: clamp(0.66rem, 1.1vw, 0.8rem);
        font-weight: 700;
        white-space: nowrap;
    }

    .shop-card-body {
        position: relative;
        z-index: 1;
        margin-top: clamp(14px, 2vw, 22px);
    }

    .shop-name {
        margin: 0 0 5px;
        color: #4a3f35;
        font-size: clamp(1.02rem, 2.1vw, 1.5rem);
        font-weight: 800;
        line-height: 1.2;
    }

    .shop-desc {
        margin: 0;
        color: #8b6f47;
        font-size: clamp(0.75rem, 1.3vw, 0.92rem);
        font-style: italic;
        line-height: 1.45;
    }

    .shop-card-foot {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        margin-top: clamp(14px, 2vw, 22px);
    }

    /* Üst üste binen küçük önizleme avatarları */
    .shop-thumbs {
        display: flex;
        align-items: center;
    }

    .shop-thumb {
        width: clamp(28px, 3.4vw, 40px);
        height: clamp(28px, 3.4vw, 40px);
        border-radius: 12px;
        border: 2px solid #fff;
        background: #f5f0e8;
        object-fit: contain;
        box-shadow: 0 4px 10px rgba(107, 85, 65, 0.18);
    }

        .shop-thumb + .shop-thumb {
            margin-left: clamp(-12px, -1.2vw, -8px);
        }

    .shop-go {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        flex-shrink: 0;
        border-radius: 50px;
        padding: clamp(7px, 1vw, 10px) clamp(13px, 1.7vw, 20px);
        background: var(--shop-accent);
        color: #fff;
        font-size: clamp(0.72rem, 1.2vw, 0.88rem);
        font-weight: 700;
        white-space: nowrap;
        box-shadow: 0 6px 16px var(--shop-glow);
        transition: gap 0.25s;
    }

    .shop-card:hover .shop-go {
        gap: 12px;
    }

    @@media (max-width: 620px) {
        .shop-grid {
            grid-template-columns: minmax(0, 1fr);
        }

        .shop-card {
            min-height: 0;
        }

        .shop-desc {
            display: none;
        }
    }
</style>

<div class="store-page">
    @await Html.PartialAsync("_StoreHero")
    @await Html.PartialAsync("_StoreNotify")

    <div class="store-container">
        <div class="shop-grid">

            <a asp-controller="Store" asp-action="Avatars" class="shop-card" style="--shop-accent: #6b5541; --shop-glow: rgba(107,85,65,0.22);">
                <div class="shop-card-top">
                    <span class="shop-icon"><i class="fa-solid fa-user-astronaut"></i></span>
                    <span class="shop-badge">@ownedAvatarCount / @avatarCount sende</span>
                </div>
                <div class="shop-card-body">
                    <h2 class="shop-name">Avatar Dükkanı</h2>
                    <p class="shop-desc">Profilini yansıtan karakterleri keşfet.</p>
                </div>
                <div class="shop-card-foot">
                    <div class="shop-thumbs">
                        @foreach (var img in avatarPreviews)
                        {
                            <img src="@img" alt="" class="shop-thumb" loading="lazy" />
                        }
                    </div>
                    <span class="shop-go">Dükkana Git <i class="fa-solid fa-arrow-right"></i></span>
                </div>
            </a>

            <a asp-controller="Store" asp-action="Frames" class="shop-card" style="--shop-accent: #a0785a; --shop-glow: rgba(160,120,90,0.24);">
                <div class="shop-card-top">
                    <span class="shop-icon"><i class="fa-solid fa-crown"></i></span>
                    <span class="shop-badge">@ownedFrameCount / @frameCount sende</span>
                </div>
                <div class="shop-card-body">
                    <h2 class="shop-name">Çerçeve Dükkanı</h2>
                    <p class="shop-desc">Profil fotoğrafını süsleyen çerçeveler.</p>
                </div>
                <div class="shop-card-foot">
                    <div class="shop-thumbs">
                        @foreach (var img in framePreviews)
                        {
                            <img src="@img" alt="" class="shop-thumb" loading="lazy" />
                        }
                    </div>
                    <span class="shop-go">Dükkana Git <i class="fa-solid fa-arrow-right"></i></span>
                </div>
            </a>

            <a asp-controller="Store" asp-action="Packs" class="shop-card" style="--shop-accent: #e65100; --shop-glow: rgba(230,81,0,0.22);">
                <div class="shop-card-top">
                    <span class="shop-icon"><i class="fa-solid fa-gift"></i></span>
                    <span class="shop-badge">@packCount paket</span>
                </div>
                <div class="shop-card-body">
                    <h2 class="shop-name">Sürpriz Paketler</h2>
                    <p class="shop-desc">Koleksiyonunu tamamla, sürpriz avatarlar kap.</p>
                </div>
                <div class="shop-card-foot">
                    <div class="shop-thumbs">
                        @foreach (var img in packPreviews)
                        {
                            <img src="@img" alt="" class="shop-thumb" loading="lazy" />
                        }
                    </div>
                    <span class="shop-go">Dükkana Git <i class="fa-solid fa-arrow-right"></i></span>
                </div>
            </a>

            <a asp-controller="Store" asp-action="Specials" class="shop-card" style="--shop-accent: #00838f; --shop-glow: rgba(0,131,143,0.22);">
                <div class="shop-card-top">
                    <span class="shop-icon"><i class="fa-solid fa-wand-magic-sparkles"></i></span>
                    <span class="shop-badge">@(user?.StreakFreezes ?? 0) / 2 dondurma</span>
                </div>
                <div class="shop-card-body">
                    <h2 class="shop-name">Özel Eşyalar</h2>
                    <p class="shop-desc">Okuma serini koruyan yardımcı eşyalar.</p>
                </div>
                <div class="shop-card-foot">
                    <div class="shop-thumbs">
                        <span class="shop-thumb" style="display: grid; place-items: center; font-size: 1.1rem;">🧊</span>
                    </div>
                    <span class="shop-go">Dükkana Git <i class="fa-solid fa-arrow-right"></i></span>
                </div>
            </a>

        </div>
    </div>
</div>
