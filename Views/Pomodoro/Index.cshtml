<script>
    const POMODORO_MINUTES = 25;
    const SHORT_BREAK_MINUTES = 5;
    const LONG_BREAK_MINUTES = 15;

    let currentMode = 'Pomodoro';
    let tickInterval = null;
    // Zaman artık tik saymak yerine gerçek saat damgasıyla ölçülüyor (arka planda drift yok)
    let accumulatedMs = 0;   // duraklamalar arası biriken süre
    let runStartMs = 0;      // mevcut çalışma segmentinin başlangıç damgası
    let elapsedSeconds = 0;  // türetilmiş: geçen tam saniye
    let isRunning = false;
    let sessionPomodoroCount = 0;
    let wakeLock = null;

    // DOM
    const display     = document.getElementById('timeDisplay');
    const timeLabel   = document.getElementById('timeLabel');
    const timerWrapper = document.getElementById('timerWrapper');
    const btnPlay     = document.getElementById('btnPlay');
    const btnPause    = document.getElementById('btnPause');
    const btnSave     = document.getElementById('btnSave');
    const alertBox    = document.getElementById('statusAlert');
    const progressArc = document.getElementById('progressArc');
    const breakNotice = document.getElementById('breakNotice');
    const baseTitle   = document.title;

    const CIRCUMFERENCE = 2 * Math.PI * 122; // ~766.5

    // Halka artık kesintili adımlar yerine 250ms'de akıcı ilerlesin
    progressArc.style.transition = 'stroke-dashoffset 0.25s linear';

    // Tema halka renkleri — updateDisplay sıcak yolunda getComputedStyle çağırmamak için önbellek
    let ringFocusColor = '#4a7c59', ringBreakColor = '#c0622a';
    function refreshRingColors() {
        const cs = getComputedStyle(document.body);
        const f = cs.getPropertyValue('--ring-focus').trim();
        const b = cs.getPropertyValue('--ring-break').trim();
        if (f) ringFocusColor = f;
        if (b) ringBreakColor = b;
    }

    // ── TEMA (Kütüphane / Neon) ──
    const THEME_KEY = 'pomodoroTheme';
    function applyTheme(name) {
        if (name === 'neon' || name === 'forest') document.body.dataset.theme = name;
        else { delete document.body.dataset.theme; name = 'library'; }
        document.querySelectorAll('.theme-chip').forEach(function (c) {
            c.classList.toggle('active', c.dataset.theme === name);
        });
        try { localStorage.setItem(THEME_KEY, name); } catch (e) { }
        refreshRingColors();
        updateDisplay();
    }

    // ── AYARLAR MODALI (Tema & Ses) ──
    function openSettings() { document.getElementById('settingsModal').classList.add('show'); }
    function closeSettings() { document.getElementById('settingsModal').classList.remove('show'); }

    (function () {
        var ov = document.getElementById('settingsModal');
        if (ov) ov.addEventListener('click', function (e) { if (e.target === ov) closeSettings(); });
        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') closeSettings();
        });
    })();

    // ── Telefon hareketine göre maymunlar hafifçe eğilsin (basit) ──
    // Dış katmana (device tilt) cihaz eğimi, iç katmana (CSS) sürekli salınım uygulanır → birleşir.
    (function () {
        if (!window.DeviceOrientationEvent) return;
        var current = 0, target = 0, running = false;

        function onOrient(e) {
            if (e.gamma == null) return;
            target = Math.max(-16, Math.min(16, e.gamma * 0.4)); // sol-sağ eğim, sınırlı
            if (!running) { running = true; requestAnimationFrame(loop); }
        }
        function loop() {
            current += (target - current) * 0.08; // yumuşat
            var ms = document.querySelectorAll('.forest-monkey');
            for (var i = 0; i < ms.length; i++) {
                ms[i].style.transform = 'rotate(' + current.toFixed(2) + 'deg)';
            }
            requestAnimationFrame(loop);
        }

        window.addEventListener('deviceorientation', onOrient, { passive: true });

        // iOS 13+ hareket sensörü izni: ilk dokunuşta iste
        if (typeof DeviceOrientationEvent.requestPermission === 'function') {
            window.addEventListener('touchend', function askOnce() {
                window.removeEventListener('touchend', askOnce);
                DeviceOrientationEvent.requestPermission().catch(function () { });
            }, { once: true, passive: true });
        }
    })();

    function totalSecondsForMode() {
        if (currentMode === 'Pomodoro')   return POMODORO_MINUTES * 60;
        if (currentMode === 'ShortBreak') return SHORT_BREAK_MINUTES * 60;
        if (currentMode === 'LongBreak')  return LONG_BREAK_MINUTES * 60;
        return 0; // Serbest çalışma (kronometre) — dolma yok
    }

    function currentElapsedMs() {
        return accumulatedMs + (isRunning ? (Date.now() - runStartMs) : 0);
    }

    function updateDisplay() {
        const elapsedMs   = currentElapsedMs();
        elapsedSeconds    = Math.floor(elapsedMs / 1000);
        const totalSeconds = totalSecondsForMode();

        const displaySeconds = totalSeconds > 0
            ? Math.max(0, totalSeconds - elapsedSeconds)
            : elapsedSeconds;

        const minutes = Math.floor(displaySeconds / 60);
        const seconds = displaySeconds % 60;
        const txt = String(minutes).padStart(2, '0') + ':' + String(seconds).padStart(2, '0');
        display.textContent = txt;

        // İlerleme halkası — kesirli ilerleme (akıcı ve 25 dk'da tam dolar)
        if (totalSeconds > 0) {
            const progress = Math.min((elapsedMs / 1000) / totalSeconds, 1);
            progressArc.style.strokeDasharray  = CIRCUMFERENCE;
            progressArc.style.strokeDashoffset = CIRCUMFERENCE * (1 - progress);
            const isBreak = (currentMode === 'ShortBreak' || currentMode === 'LongBreak');
            progressArc.style.stroke = isBreak ? ringBreakColor : ringFocusColor;
        } else {
            progressArc.style.strokeDashoffset = CIRCUMFERENCE;
        }

        // Sekme başlığında geri sayım (arka plandayken de görünür)
        if (isRunning) {
            const tl = { Pomodoro: 'Odak', Stopwatch: 'Çalışma', ShortBreak: 'Mola', LongBreak: 'Mola' }[currentMode] || '';
            document.title = txt + ' · ' + tl;
        }

        updateDots();
    }

    function updateDots() {
        for (let i = 1; i <= 4; i++) {
            const dot = document.getElementById('dot' + i);
            dot.classList.remove('completed', 'active');
            if (i <= sessionPomodoroCount) {
                dot.classList.add('completed');
            } else if (i === sessionPomodoroCount + 1 && currentMode === 'Pomodoro') {
                dot.classList.add('active');
            }
        }
    }

    // ── EKRANI UYANIK TUT (Wake Lock) ──
    async function requestWakeLock() {
        try {
            if ('wakeLock' in navigator) wakeLock = await navigator.wakeLock.request('screen');
        } catch (e) { /* desteklenmiyor veya reddedildi */ }
    }
    function releaseWakeLock() {
        try { if (wakeLock) { wakeLock.release(); wakeLock = null; } } catch (e) { }
    }

    // ── BİTİŞ SESİ (Web Audio ile üretilir, dosya gerekmez) ──
    let audioCtx = null;
    function playChime() {
        try {
            audioCtx = audioCtx || new (window.AudioContext || window.webkitAudioContext)();
            const now = audioCtx.currentTime;
            [880, 1174.66, 1567.98].forEach(function (freq, i) {
                const o = audioCtx.createOscillator();
                const g = audioCtx.createGain();
                o.type = 'sine';
                o.frequency.value = freq;
                o.connect(g); g.connect(audioCtx.destination);
                const t = now + i * 0.16;
                g.gain.setValueAtTime(0.0001, t);
                g.gain.exponentialRampToValueAtTime(0.3, t + 0.02);
                g.gain.exponentialRampToValueAtTime(0.0001, t + 0.9);
                o.start(t); o.stop(t + 0.95);
            });
        } catch (e) { }
    }

    // ── TARAYICI BİLDİRİMİ ──
    function ensureNotifyPermission() {
        try {
            if ('Notification' in window && Notification.permission === 'default') Notification.requestPermission();
        } catch (e) { }
    }
    function notify(title, body) {
        try {
            if ('Notification' in window && Notification.permission === 'granted') new Notification(title, { body: body });
        } catch (e) { }
    }

    function setMode(mode) {
        if (isRunning) {
            if (!confirm("Çalışan bir sayacınız var. Modu değiştirirseniz sıfırlanacaktır. Emin misiniz?")) return;
        }

        currentMode = mode;

        if (mode === 'Pomodoro' || mode === 'Stopwatch') {
            document.getElementById('btnPomodoro').classList.toggle('active', mode === 'Pomodoro');
            document.getElementById('btnStopwatch').classList.toggle('active', mode === 'Stopwatch');
        }

        if (mode === 'ShortBreak' || mode === 'LongBreak') {
            btnSave.style.display = 'none';
            document.getElementById('btnPomodoro').classList.remove('active');
            document.getElementById('btnStopwatch').classList.remove('active');
        }

        // Etiket güncelle
        const labels = {
            'Pomodoro':   'Odak Seansı',
            'Stopwatch':  'Serbest Çalışma',
            'ShortBreak': 'Kısa Mola',
            'LongBreak':  'Uzun Mola'
        };
        timeLabel.textContent = labels[mode] || mode;

        // Mola bildirimi
        if (mode === 'ShortBreak' || mode === 'LongBreak') {
            breakNotice.classList.add('visible');
        } else {
            breakNotice.classList.remove('visible');
        }

        resetTimer();
    }

    function tick() {
        updateDisplay();
        const total = totalSecondsForMode();
        if (total > 0 && currentElapsedMs() / 1000 >= total) {
            // Süre doldu — tek sefer tetiklenir (finish* içinde pauseTimer çağrılıyor)
            if (currentMode === 'Pomodoro') finishAndSave(true);
            else finishBreak();
        }
    }

    function startTimer() {
        if (isRunning) return;

        isRunning = true;
        runStartMs = Date.now();
        timerWrapper.classList.add('running');
        btnPlay.style.display  = 'none';
        btnPause.style.display = 'flex';
        alertBox.style.display = 'none';

        if (currentMode === 'Pomodoro' || currentMode === 'Stopwatch') {
            btnSave.style.display = 'flex';
        }

        requestWakeLock();
        ensureNotifyPermission();
        resumeAmbientIfAny();

        tickInterval = setInterval(tick, 250);
        tick();
    }

    function pauseTimer() {
        if (!isRunning) return;
        accumulatedMs += Date.now() - runStartMs;
        clearInterval(tickInterval);
        isRunning = false;
        timerWrapper.classList.remove('running');
        btnPause.style.display = 'none';
        btnPlay.style.display  = 'flex';
        releaseWakeLock();
        document.title = baseTitle;
    }

    function resetTimer() {
        pauseTimer();
        accumulatedMs  = 0;
        elapsedSeconds = 0;
        btnSave.style.display  = 'none';
        alertBox.style.display = 'none';
        document.title = baseTitle;
        updateDisplay();
    }

    // Arka plandan dönünce süreyi anında gerçek saatle senkronla + kilidi geri al
    document.addEventListener('visibilitychange', function () {
        if (document.visibilityState === 'visible') {
            if (isRunning && !wakeLock) requestWakeLock();
            if (isRunning) tick();
        }
    });

    function finishBreak() {
        pauseTimer();
        playChime();
        notify('Mola bitti', 'Yeni bir odak seansına hazır mısın?');
        setMode('Pomodoro');
        showAlert("Mola süreniz doldu. Yeni bir odak seansına hazır mısınız?", true);
    }

    function finishAndSave(isAutoCompleted = false) {
        pauseTimer();

        if (currentMode === 'ShortBreak' || currentMode === 'LongBreak') {
            finishBreak();
            return;
        }

        if (isAutoCompleted) {
            playChime();
            notify('Odak tamamlandı 🎉', '25 dakikalık seansın bitti. Harika iş!');
        }

        // Otomatik tamamlanan pomodoro tam süre kaydedilir (arka plan taşmasını sınırla)
        const durationInMinutes = (currentMode === 'Pomodoro' && isAutoCompleted)
            ? POMODORO_MINUTES
            : Math.floor(currentElapsedMs() / 60000);

        if (durationInMinutes < 1) {
            showAlert("En az 1 dakikalık çalışmaları kaydedebilirsiniz.", false);
            return;
        }

        let isCompleted = true;
        if (currentMode === 'Pomodoro' && !isAutoCompleted) {
            isCompleted = false;
        }

        btnSave.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> &nbsp;Kaydediliyor...';
        btnSave.disabled  = true;

        const payload = {
            SessionType: currentMode,
            DurationInMinutes: durationInMinutes,
            IsCompleted: isCompleted
        };

        fetch('/Pomodoro/SaveSession', {
            method:  'POST',
            headers: { 'Content-Type': 'application/json' },
            body:    JSON.stringify(payload)
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                // Taş kazanıldıysa animasyonu göster
                if (data.earnedStones && data.earnedStones > 0 && typeof showFloatingRewardAnimation === 'function') {
                    showFloatingRewardAnimation(data.earnedStones);
                }

                accumulatedMs  = 0;
                elapsedSeconds = 0;
                btnSave.style.display = 'none';

                if (currentMode === 'Pomodoro' && isCompleted) {
                    sessionPomodoroCount++;

                    if (sessionPomodoroCount % 4 === 0) {
                        setMode('LongBreak');
                        showAlert("Harika! Dört seans tamamladınız. 15 dakikalık uzun molaya geçildi.", true);
                    } else {
                        setMode('ShortBreak');
                        showAlert(`Kayıt başarılı. (${sessionPomodoroCount}/4) 5 dakikalık kısa molaya geçildi.`, true);
                    }
                } else {
                    showAlert(data.message, true);
                    updateDisplay();
                }

            } else {
                showAlert(data.message, false);
            }
        })
        .catch(error => {
            console.error("Hata:", error);
            showAlert("Bağlantı hatası oluştu.", false);
        })
        .finally(() => {
            btnSave.innerHTML = '<i class="fa-solid fa-flag-checkered"></i>&nbsp; Kaydet';
            btnSave.disabled  = false;
        });
    }

    function showAlert(message, isSuccess) {
        alertBox.className = isSuccess ? 'alert-success-custom' : 'alert-error-custom';
        alertBox.innerHTML = isSuccess
            ? `<i class="fa-solid fa-circle-check"></i> ${message}`
            : `<i class="fa-solid fa-triangle-exclamation"></i> ${message}`;
        alertBox.style.display = 'block';

        setTimeout(() => {
            alertBox.style.display = 'none';
        }, 6000);
    }

    // ============================================================
    //  ORTAM SESLERİ MİKSERİ (yağmur, kuş, şömine, kafe, dalga…)
    //  Sesler yönetici panelinden eklenir (SuperAdmin › Ortam Sesleri),
    //  wwwroot/sounds/manifest.json içinde tutulur. Hiç ses yoksa bölüm gizlenir.
    // ============================================================
    const AMBIENT_DATA = @Html.Raw(ViewBag.AmbientSoundsJson ?? "[]");
    const SOUNDS = (Array.isArray(AMBIENT_DATA) ? AMBIENT_DATA : []).map(function (s) {
        return { key: s.file, name: s.name, icon: s.icon || 'fa-solid fa-music', file: s.file };
    });
    const AMB_KEY = 'pomodoroAmbient';
    let ambState = {};          // key -> { on, volume }
    const ambAudio = {};        // key -> Audio
    let ambResumed = false;

    function loadAmbState() {
        try { ambState = JSON.parse(localStorage.getItem(AMB_KEY)) || {}; } catch (e) { ambState = {}; }
    }
    function saveAmbState() {
        try { localStorage.setItem(AMB_KEY, JSON.stringify(ambState)); } catch (e) { }
    }

    function buildAmbient() {
        loadAmbState();
        const grid = document.getElementById('ambientGrid');
        const section = document.querySelector('.ambient-section');

        // Hiç ses eklenmemişse ses bölümünü gizle (ayarlar modalında)
        if (!SOUNDS.length) {
            if (section) section.style.display = 'none';
            return;
        }

        SOUNDS.forEach(function (sd) {
            const st = ambState[sd.key] || { on: false, volume: 0.6 };
            ambState[sd.key] = st;

            const chip = document.createElement('div');
            chip.className = 'ambient-chip' + (st.on ? ' active' : '');
            chip.dataset.key = sd.key;
            chip.innerHTML =
                '<i class="ac-icon ' + sd.icon + '"></i>' +
                '<span class="ac-name">' + sd.name + '</span>' +
                '<input type="range" class="ambient-vol" min="0" max="1" step="0.05" value="' + st.volume + '">';
            grid.appendChild(chip);

            const slider = chip.querySelector('.ambient-vol');
            slider.addEventListener('click', function (e) { e.stopPropagation(); });
            slider.addEventListener('input', function (e) {
                e.stopPropagation();
                st.volume = parseFloat(slider.value);
                if (ambAudio[sd.key]) ambAudio[sd.key].volume = st.volume;
                saveAmbState();
            });

            chip.addEventListener('click', function (e) {
                if (e.target.closest('.ambient-vol')) return;
                if (chip.classList.contains('unavailable')) return;
                toggleAmbient(sd, chip);
            });
        });
    }

    function playAmbient(sd, chip) {
        let a = ambAudio[sd.key];
        if (!a) {
            a = new Audio(sd.file);
            a.loop = true;
            a.addEventListener('error', function () {
                // Dosya eksik/oynatılamıyor → butonu kullanılamaz yap
                if (chip) { chip.classList.add('unavailable'); chip.classList.remove('active'); }
                ambState[sd.key].on = false;
                saveAmbState();
            });
            ambAudio[sd.key] = a;
        }
        a.volume = ambState[sd.key].volume;
        a.play().catch(function () { /* autoplay engeli ya da dosya yok */ });
    }

    function toggleAmbient(sd, chip) {
        const st = ambState[sd.key];
        if (st.on) {
            st.on = false;
            chip.classList.remove('active');
            if (ambAudio[sd.key]) ambAudio[sd.key].pause();
        } else {
            st.on = true;
            chip.classList.add('active');
            playAmbient(sd, chip);
        }
        saveAmbState();
    }

    // Önceden açık bırakılan sesleri ilk kullanıcı etkileşiminde sürdür
    function resumeAmbientIfAny() {
        if (ambResumed) return;
        ambResumed = true;
        SOUNDS.forEach(function (sd) {
            const st = ambState[sd.key];
            if (st && st.on) {
                const chip = document.querySelector('.ambient-chip[data-key="' + sd.key + '"]');
                playAmbient(sd, chip);
            }
        });
    }
    document.addEventListener('click', resumeAmbientIfAny, { once: true });

    // Başlangıç
    window.onload = function () {
        buildAmbient();
        applyTheme(localStorage.getItem(THEME_KEY) || 'library');
        updateDisplay();
        // İlerleme halkası başlangıç
        progressArc.style.strokeDasharray  = CIRCUMFERENCE;
        progressArc.style.strokeDashoffset = CIRCUMFERENCE;
    };
</script>
