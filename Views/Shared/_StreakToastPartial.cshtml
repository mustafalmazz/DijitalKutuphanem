@if (TempData["StreakMessage"] != null)
{
    <style>
        /* ===== ARKA PLAN (AYDINLIK BUĞU) ===== */
        .streak-overlay {
            position: fixed;
            inset: 0;
            background: linear-gradient(135deg, rgba(255, 251, 240, 0.75) 0%, rgba(255, 240, 214, 0.7) 100%);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            z-index: 99998;
            display: flex;
            align-items: center;
            justify-content: center;
            animation: streakFadeIn 0.4s ease-out;
            padding: 20px;
        }

            .streak-overlay.closing {
                animation: streakFadeOut 0.45s ease-in forwards;
            }

        @@keyframes streakFadeIn {
            from {
                opacity: 0;
            }

            to {
                opacity: 1;
            }
        }

        @@keyframes streakFadeOut {
            from {
                opacity: 1;
            }

            to {
                opacity: 0;
            }
        }

        /* ===== ÖDÜL KARTI (BEYAZ CAM) ===== */
        .streak-card {
            position: relative;
            max-width: 400px;
            width: 100%;
            background: linear-gradient(165deg, rgba(255, 255, 255, 0.95) 0%, rgba(255, 250, 240, 0.92) 100%);
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            border: 1px solid rgba(255, 255, 255, 0.9);
            border-radius: 30px;
            padding: 46px 34px 32px;
            text-align: center;
            box-shadow: 0 24px 55px rgba(196, 145, 60, 0.22), 0 4px 14px rgba(196, 145, 60, 0.1), 0 0 0 1px rgba(255, 215, 130, 0.25) inset;
            animation: streakBounceIn 0.65s cubic-bezier(0.34, 1.56, 0.64, 1);
            overflow: hidden;
            z-index: 2;
        }

        .streak-overlay.closing .streak-card {
            animation: streakZoomOut 0.45s ease-in forwards;
        }

        @@keyframes streakBounceIn {
            0% {
                transform: scale(0.3) translateY(80px);
                opacity: 0;
            }

            60% {
                transform: scale(1.06) translateY(-8px);
                opacity: 1;
            }

            80% {
                transform: scale(0.97) translateY(3px);
            }

            100% {
                transform: scale(1) translateY(0);
            }
        }

        @@keyframes streakZoomOut {
            to {
                transform: scale(0.6) translateY(40px);
                opacity: 0;
            }
        }

        /* Kart üzerinde kayan zarif altın parlama */
        .streak-card::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(115deg, transparent 32%, rgba(255, 226, 160, 0.4) 50%, transparent 68%);
            background-size: 250% 250%;
            animation: streakShine 3.2s ease-in-out infinite;
            pointer-events: none;
        }

        @@keyframes streakShine {
            0% {
                background-position: 140% 140%;
            }

            60%, 100% {
                background-position: -60% -60%;
            }
        }

        /* Kartın üst kısmında yumuşak altın ışık */
        .streak-card::after {
            content: '';
            position: absolute;
            top: -70px;
            left: 50%;
            transform: translateX(-50%);
            width: 240px;
            height: 150px;
            background: radial-gradient(ellipse, rgba(255, 200, 90, 0.28) 0%, transparent 70%);
            pointer-events: none;
        }

        /* ===== ATEŞ İKONU + IŞIK HALESİ ===== */
        .streak-flame-wrap {
            position: relative;
            width: 112px;
            height: 112px;
            margin: 0 auto 20px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

            /* Dönen zarif altın hale */
            .streak-flame-wrap::before {
                content: '';
                position: absolute;
                inset: -10px;
                border-radius: 50%;
                background: conic-gradient(from 0deg, transparent, rgba(255, 196, 80, 0.5), transparent 30%, transparent 50%, rgba(255, 160, 60, 0.4), transparent 80%);
                animation: streakHalo 3.2s linear infinite;
            }

        @@keyframes streakHalo {
            to {
                transform: rotate(360deg);
            }
        }

        /* Nabız gibi atan sıcak iç parlama */
        .streak-flame-wrap::after {
            content: '';
            position: absolute;
            inset: 10px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(255, 214, 120, 0.55) 0%, rgba(255, 176, 60, 0.2) 55%, transparent 75%);
            animation: streakPulse 1.4s ease-in-out infinite alternate;
        }

        @@keyframes streakPulse {
            from {
                transform: scale(0.85);
                opacity: 0.65;
            }

            to {
                transform: scale(1.12);
                opacity: 1;
            }
        }

        .streak-flame {
            font-size: 3.6rem;
            position: relative;
            z-index: 2;
            animation: streakFlameDance 1.1s ease-in-out infinite alternate;
            filter: drop-shadow(0 8px 20px rgba(255, 150, 40, 0.45));
        }

        @@keyframes streakFlameDance {
            from {
                transform: scale(1) rotate(-4deg) translateY(0);
            }

            to {
                transform: scale(1.1) rotate(4deg) translateY(-5px);
            }
        }

        /* ===== YÜKSELEN ALTIN KIVILCIMLAR ===== */
        .streak-spark {
            position: absolute;
            bottom: 22%;
            border-radius: 50%;
            background: radial-gradient(circle, #ffe9b0 0%, #ffb340 70%);
            box-shadow: 0 0 6px rgba(255, 190, 80, 0.7);
            opacity: 0;
            pointer-events: none;
            animation: streakSparkRise 2.6s ease-out infinite;
        }

            .streak-spark:nth-child(1) {
                left: 18%;
                width: 7px;
                height: 7px;
                animation-delay: 0s;
            }

            .streak-spark:nth-child(2) {
                left: 42%;
                width: 5px;
                height: 5px;
                animation-delay: 0.5s;
            }

            .streak-spark:nth-child(3) {
                left: 65%;
                width: 8px;
                height: 8px;
                animation-delay: 1s;
            }

            .streak-spark:nth-child(4) {
                left: 82%;
                width: 5px;
                height: 5px;
                animation-delay: 1.5s;
            }

            .streak-spark:nth-child(5) {
                left: 30%;
                width: 6px;
                height: 6px;
                animation-delay: 1.9s;
            }

        @@keyframes streakSparkRise {
            0% {
                transform: translateY(0) scale(1);
                opacity: 0;
            }

            15% {
                opacity: 1;
            }

            100% {
                transform: translateY(-190px) scale(0.2);
                opacity: 0;
            }
        }

        /* ===== METİNLER ===== */
        .streak-title {
            font-family: 'Georgia', serif;
            font-size: 1.5rem;
            font-weight: 800;
            background: linear-gradient(135deg, #d97706, #f59e0b, #b45309);
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 10px;
            position: relative;
            letter-spacing: 0.5px;
        }

        .streak-message {
            font-family: 'Georgia', serif;
            font-size: 1rem;
            color: #7a5c2e;
            line-height: 1.6;
            margin-bottom: 24px;
            position: relative;
            font-weight: 600;
        }

        /* ===== BUTON ===== */
        .streak-btn {
            background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 55%, #d97706 100%);
            color: #fff;
            border: none;
            border-radius: 50px;
            padding: 13px 46px;
            font-family: 'Georgia', serif;
            font-weight: 700;
            font-size: 0.95rem;
            letter-spacing: 1px;
            cursor: pointer;
            box-shadow: 0 8px 22px rgba(217, 119, 6, 0.35), 0 2px 6px rgba(217, 119, 6, 0.2);
            transition: all 0.25s ease;
            position: relative;
            text-shadow: 0 1px 2px rgba(146, 64, 14, 0.3);
        }

            .streak-btn:hover {
                transform: translateY(-3px) scale(1.04);
                box-shadow: 0 14px 30px rgba(217, 119, 6, 0.45);
            }

            .streak-btn:active {
                transform: scale(0.96);
            }

        /* ===== OTOMATİK KAPANMA SÜRE ÇUBUĞU ===== */
        .streak-timer {
            position: absolute;
            bottom: 0;
            left: 0;
            height: 5px;
            width: 100%;
            background: linear-gradient(90deg, #fcd34d, #f59e0b);
            border-radius: 0 0 30px 30px;
            transform-origin: left;
            animation: streakTimer 8s linear forwards;
        }

        @@keyframes streakTimer {
            from {
                transform: scaleX(1);
            }

            to {
                transform: scaleX(0);
            }
        }

        /* ===== MOBİL ===== */
        @@media (max-width: 480px) {
            .streak-card {
                padding: 38px 24px 28px;
                border-radius: 24px;
            }

            .streak-flame-wrap {
                width: 92px;
                height: 92px;
            }

            .streak-flame {
                font-size: 3rem;
            }

            .streak-title {
                font-size: 1.25rem;
            }

            .streak-message {
                font-size: 0.9rem;
            }

            .streak-btn {
                padding: 12px 36px;
                font-size: 0.85rem;
            }

            .streak-timer {
                border-radius: 0 0 24px 24px;
            }
        }
    </style>

    <div class="streak-overlay" id="streakOverlay">
        <div class="streak-card">
            <!-- Yükselen kıvılcımlar -->
            <span class="streak-spark"></span>
            <span class="streak-spark"></span>
            <span class="streak-spark"></span>
            <span class="streak-spark"></span>
            <span class="streak-spark"></span>

            <!-- Ateş ikonu + hale -->
            <div class="streak-flame-wrap">
                <span class="streak-flame">🔥</span>
            </div>

            <div class="streak-title">Günlük Ödülünüz Hazır!</div>
            <div class="streak-message">@TempData["StreakMessage"]</div>

            <button type="button" class="streak-btn" id="streakCloseBtn" data-bs-toggle="modal" data-bs-target="#streakModal" onclick="document.getElementById('streakOverlay').classList.add('closing'); setTimeout(() => document.getElementById('streakOverlay').remove(), 480);">
                <i class="fa-solid fa-gift me-1"></i> Hemen Topla!
            </button>

            <!-- Otomatik kapanma göstergesi -->
            <div class="streak-timer"></div>
        </div>
    </div>

    <script>
        (function () {
            var overlay = document.getElementById('streakOverlay');
            var closeBtn = document.getElementById('streakCloseBtn');
            var autoCloseTimer;

            function closeStreak() {
                if (!overlay || overlay.classList.contains('closing')) return;
                clearTimeout(autoCloseTimer);
                overlay.classList.add('closing');
                // Çıkış animasyonu bitince DOM'dan kaldır
                setTimeout(function () {
                    overlay.remove();
                }, 480);
            }

            // 8 saniye sonra otomatik kapan
            autoCloseTimer = setTimeout(closeStreak, 8000);

            // Butonla kapatma
            if (closeBtn) closeBtn.addEventListener('click', closeStreak);

            // Aydınlık alana tıklayınca kapatma (kartın kendisine değil)
            if (overlay) {
                overlay.addEventListener('click', function (e) {
                    if (e.target === overlay) closeStreak();
                });
            }

            // ESC tuşuyla kapatma
            document.addEventListener('keydown', function (e) {
                if (e.key === 'Escape') closeStreak();
            });
        })();
    </script>
}