@using BookManagementApp.Areas.Admin.Models
@using BookManagementApp.Models
@model StreakModalModel
@{
    var user = Model.User;
    bool isClaimedToday = user.LastRewardClaimDate.HasValue && user.LastRewardClaimDate.Value.Date == DateTime.Today;
    // Hesap User modelinde; sunucu ödülü de aynı yerden okur, böylece ayrışamazlar.
    int currentDayInWeek = user.DayInStreakWeek;
    int weekNumber = user.CurrentStreak <= 0 ? 1 : ((user.CurrentStreak - 1) / 7) + 1;
}

<style>
    /* Neon Yeşil - Toplandı */
    .streak-row.claimed {
        background: rgba(46, 204, 113, 0.08);
        border: 2px solid rgba(46, 204, 113, 0.6);
        box-shadow: 0 0 12px rgba(46, 204, 113, 0.2);
    }
    .streak-row.claimed .day-text { color: #27ae60; }
    
    /* Turuncu/Altın - Bekleyen (Pulsing) */
    .streak-row.ready {
        background: rgba(255, 152, 0, 0.08);
        border: 2px solid #ff9800;
        box-shadow: 0 0 15px rgba(255, 152, 0, 0.3);
        animation: pulseOrange 2s infinite;
    }
    .streak-row.ready .day-text { color: #d35400; font-weight: 800; }
    
    @@keyframes pulseOrange {
        0% { box-shadow: 0 0 8px rgba(255, 152, 0, 0.2); }
        50% { box-shadow: 0 0 20px rgba(255, 152, 0, 0.5); }
        100% { box-shadow: 0 0 8px rgba(255, 152, 0, 0.2); }
    }

    /* Gri - Kilitli */
    .streak-row.locked {
        background: #f8f9fa;
        border: 1px dashed #dee2e6;
        opacity: 0.7;
    }
    .streak-row.locked .day-text { color: #6c757d; }
    
    /* Seri Özeti */
    .streak-summary {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2px;
        padding: 14px 12px;
        margin-bottom: 18px;
        border-radius: 14px;
        background: linear-gradient(135deg, rgba(255,152,0,0.10), rgba(255,87,34,0.07));
        border: 1px solid rgba(255,152,0,0.28);
    }

    .streak-summary-main {
        display: flex;
        align-items: baseline;
        gap: 8px;
        color: #e65100;
    }

    .streak-summary-main i {
        font-size: 1.15rem;
        color: #ff5722;
    }

    .streak-summary-days {
        font-size: 2rem;
        font-weight: 800;
        line-height: 1;
    }

    .streak-summary-label {
        font-size: 0.9rem;
        font-weight: 700;
    }

    .streak-summary-sub {
        font-size: 0.78rem;
        color: #8b6f47;
    }

    @@media (max-width: 480px) {
        .streak-summary-days { font-size: 1.6rem; }
        .streak-summary-label { font-size: 0.82rem; }
        .streak-summary-sub { font-size: 0.72rem; }
    }

    /* Sıradaki kilometre taşı */
    .streak-next {
        display: block;
        margin-top: 16px;
        padding: 11px 14px;
        border-radius: 12px;
        background: rgba(139, 111, 71, 0.06);
        border: 1px solid rgba(139, 111, 71, 0.18);
        text-decoration: none;
        color: inherit;
        transition: background 0.2s, border-color 0.2s;
    }

        .streak-next:hover {
            background: rgba(139, 111, 71, 0.12);
            border-color: rgba(139, 111, 71, 0.35);
            color: inherit;
        }

    .streak-next-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        margin-bottom: 7px;
    }

    .streak-next-name {
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        color: #6b5541;
        font-size: 0.85rem;
        font-weight: 700;
    }

    .streak-next-reward {
        flex-shrink: 0;
        color: #00838f;
        font-size: 0.85rem;
        font-weight: 800;
    }

    .streak-next-track {
        height: 5px;
        border-radius: 5px;
        background: rgba(139, 111, 71, 0.15);
        overflow: hidden;
    }

    .streak-next-fill {
        height: 100%;
        border-radius: 5px;
        background: linear-gradient(90deg, #ff9800, #ff5722);
    }

    .streak-next-sub {
        margin-top: 5px;
        text-align: right;
        color: #a08a6d;
        font-size: 0.72rem;
    }

    /* Topla Butonu */
    .btn-claim {
        background: linear-gradient(135deg, #ff9800, #ff5722);
        color: white;
        border: none;
        border-radius: 20px;
        padding: 6px 18px;
        font-weight: bold;
        transition: transform 0.2s;
        box-shadow: 0 4px 10px rgba(255, 87, 34, 0.3);
    }
    .btn-claim:hover {
        transform: scale(1.05);
        color: white;
        box-shadow: 0 6px 15px rgba(255, 87, 34, 0.4);
    }
    .btn-claim:active {
        transform: scale(0.95);
    }
</style>

<div class="modal fade" id="streakModal" tabindex="-1" aria-labelledby="streakModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        @Html.AntiForgeryToken()
        <div class="modal-content" style="background: linear-gradient(135deg, #ffffff 0%, #fef8f0 100%); color: #4a3f35; border: 1px solid #ffcc80; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.1);">
            <div class="modal-header" style="border-bottom: 1px solid rgba(255, 152, 0, 0.2);">
                <h5 class="modal-title fw-bold" id="streakModalLabel" style="color: #e65100;">
                    <i class="fa-solid fa-gift" style="color: #ff5722;"></i> Haftalık Seri Ödülleri
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Kapat" style="z-index: 1055;"></button>
            </div>
            <div class="modal-body p-4">
                <div class="streak-summary">
                    <div class="streak-summary-main">
                        <i class="fa-solid fa-fire"></i>
                        <span class="streak-summary-days">@user.CurrentStreak</span>
                        <span class="streak-summary-label">günlük seri</span>
                    </div>
                    <div class="streak-summary-sub">
                        @weekNumber. hafta &middot; @currentDayInWeek / 7. gün
                        @if (user.LongestStreak > user.CurrentStreak)
                        {
                            <text>&middot; rekorun @user.LongestStreak</text>
                        }
                    </div>
                </div>
                
                <div class="d-flex flex-column gap-3">
                    @for (int i = 1; i <= 7; i++)
                    {
                        int reward = BookManagementApp.Areas.Admin.Models.User.DailyRewardForWeekDay(i);
                        bool isPast = i < currentDayInWeek || (i == currentDayInWeek && isClaimedToday);
                        bool isCurrent = i == currentDayInWeek && !isClaimedToday;
                        bool isFuture = i > currentDayInWeek;

                        string rowClass = isPast ? "claimed" : (isCurrent ? "ready" : "locked");
                        
                        <div class="d-flex justify-content-between align-items-center p-3 rounded streak-row @rowClass">
                            <div class="fw-bold day-text">
                                @if(isPast) { <i class="fa-solid fa-circle-check text-success me-1"></i> }
                                else if(isFuture) { <i class="fa-solid fa-lock me-1"></i> }
                                @i. Gün
                            </div>
                            
                            <div class="d-flex align-items-center gap-3">
                                <div style="color: #00838f; font-weight: bold; font-size: 1.1rem;">
                                    <i class="fa-solid fa-gem"></i> +@reward
                                </div>
                                
                                @if (isCurrent)
                                {
                                    <button class="btn btn-claim" onclick="claimReward(this)" id="claimBtn">Topla</button>
                                }
                                else if (isPast)
                                {
                                    <span class="badge bg-success"><i class="fa-solid fa-check"></i> Alındı</span>
                                }
                            </div>
                        </div>
                    }
                </div>

                @if (Model.NextMilestone != null)
                {
                    var ms = Model.NextMilestone;
                    int msPct = ms.TargetValue > 0
                        ? Math.Min(100, (int)(user.CurrentStreak * 100.0 / ms.TargetValue))
                        : 0;

                    <a class="streak-next" asp-area="" asp-controller="Profile" asp-action="Index" asp-fragment="@BookManagementApp.Models.Achievement.CategoryAnchor(ms.Category)">
                        <div class="streak-next-top">
                            <span class="streak-next-name">
                                <i class="fa-solid @ms.IconClass"></i> @ms.Name
                            </span>
                            <span class="streak-next-reward">
                                <i class="fa-solid fa-gem"></i> +@ms.RewardStones.ToString("N0")
                            </span>
                        </div>
                        <div class="streak-next-track">
                            <div class="streak-next-fill" style="width: @msPct%;"></div>
                        </div>
                        <div class="streak-next-sub">@user.CurrentStreak / @ms.TargetValue gün</div>
                    </a>
                }
            </div>
        </div>
    </div>
</div>

<script>
    function claimReward(btn) {
        // Butonu disable et, yükleniyor göster
        var originalText = btn.innerHTML;
        btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i>';
        btn.disabled = true;

        fetch('/Account/ClaimDailyReward', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
            }
        })
        .then(response => response.json())
        .then(data => {
            if(data.success) {
                // UI Güncelleme - Satırı Yeşil Yap
                var row = btn.closest('.streak-row');
                row.classList.remove('ready');
                row.classList.add('claimed');
                
                // Günü Checkmark yap
                var dayText = row.querySelector('.day-text');
                dayText.innerHTML = '<i class="fa-solid fa-circle-check text-success me-1"></i> ' + dayText.innerHTML.trim();
                dayText.style.color = '#00ff66';

                // Butonu "Alındı" badge'ine çevir
                var parent = btn.parentElement;
                btn.remove();
                parent.innerHTML += '<span class="badge bg-success"><i class="fa-solid fa-check"></i> Alındı</span>';

                // Profesyonel Yüzen Ödül Animasyonunu Tetikle
                showFloatingRewardAnimation(data.reward);
                
            } else {
                alert("Hata: " + data.message);
                btn.innerHTML = originalText;
                btn.disabled = false;
            }
        })
        .catch(err => {
            console.error(err);
            alert("Bir hata oluştu!");
            btn.innerHTML = originalText;
            btn.disabled = false;
        });
    }

    // Modal'ı body'nin en sonuna taşıyarak Navbar'ın Z-Index (kararma ve tıklanamama) bug'ını çözer
    document.addEventListener('DOMContentLoaded', function() {
        var streakModal = document.getElementById('streakModal');
        if (streakModal) {
            document.body.appendChild(streakModal);
        }
    });
</script>
