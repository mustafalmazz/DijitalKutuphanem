@using BookManagementApp.Areas.Admin.Models
@using BookManagementApp.Models
@model CategoryUserViewModel

@{
    var routeData = ViewContext.RouteData.Values;
    var currentController = routeData["controller"]?.ToString();
    var currentAction = routeData["action"]?.ToString();

    bool isGooglePage = currentController == "Home" && currentAction == "GoogleBooks";
    string targetAction = isGooglePage ? "GoogleBooks" : "Index";
    string placeholderText = isGooglePage ? "Google Kitaplarında Ara..." : "Kütüphanemde Ara...";
}

<style>
    /* --- NAVBAR ANA KAPLAYICI --- */
    .book-navbar {
        background: linear-gradient(135deg, #8b6f47 0%, #6b5541 100%) !important;
        border: none !important;
        box-shadow: 0 2px 10px rgba(107, 85, 65, 0.25);
        padding: 8px 0;
        margin-bottom: 0px !important;
        position: relative;
    }

        .book-navbar::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 1px;
            background: linear-gradient(90deg, transparent, #f5f0e8, transparent);
            opacity: 0.4;
        }

        /* --- LOGO --- */
        .book-navbar .navbar-brand {
            color: #f5f0e8 !important;
            font-family: 'Georgia', serif;
            font-size: 1.3rem;
            font-weight: 700;
            letter-spacing: 0.5px;
            text-shadow: 1px 1px 3px rgba(0,0,0,0.2);
            display: flex;
            align-items: center;
            gap: 8px;
            transition: all 0.3s ease;
            margin-right: 0;
        }

    /* --- NAVİGASYON LİNKLERİ (Eşit Dağılım Ayarı) --- */
    .navbar-nav {
        align-items: center;
        justify-content: space-evenly;
        width: 100%;
    }

    .book-navbar .nav-link {
        color: #f5f0e8 !important;
        font-family: 'Georgia', serif;
        font-size: 0.95rem;
        font-weight: 500;
        padding: 8px 12px !important;
        margin: 0;
        border-radius: 6px;
        transition: all 0.3s ease;
        position: relative;
        white-space: nowrap;
    }

        .book-navbar .nav-link::before {
            content: '';
            position: absolute;
            bottom: 3px;
            left: 50%;
            transform: translateX(-50%);
            width: 0;
            height: 2px;
            background: #ffd782;
            transition: width 0.3s ease;
        }

        .book-navbar .nav-link:hover {
            background: rgba(245, 240, 232, 0.1);
            color: #ffd782 !important;
            transform: translateY(-1px);
        }

            .book-navbar .nav-link:hover::before {
                width: 60%;
            }

        .book-navbar .nav-link.active {
            background: rgba(245, 240, 232, 0.15);
            color: #ffd782 !important;
        }

    /* --- ARAMA FORMU (MASAÜSTÜ) --- */
    .book-search-form {
        margin-left: auto;
        display: flex;
        gap: 8px;
        align-items: center;
    }

    .book-search-input {
        border: 1px solid rgba(245, 240, 232, 0.4);
        border-radius: 20px;
        padding: 6px 15px;
        background: rgba(255, 255, 255, 0.15);
        color: #f5f0e8;
        font-family: 'Georgia', serif;
        font-size: 0.9rem;
        min-width: 250px;
        transition: all 0.3s ease;
        backdrop-filter: blur(5px);
    }

        .book-search-input::placeholder {
            color: rgba(245, 240, 232, 0.7);
            font-style: italic;
            font-size: 0.85rem;
        }

        .book-search-input:focus {
            background: rgba(255, 255, 255, 0.25);
            border-color: #ffd782;
            color: #f5f0e8;
            box-shadow: 0 0 0 2px rgba(255, 215, 130, 0.2);
            outline: none;
        }

    .book-search-btn {
        background: linear-gradient(135deg, #a0785a 0%, #8b6f47 100%);
        border: 1px solid rgba(245, 240, 232, 0.4);
        color: #f5f0e8;
        padding: 6px 18px;
        border-radius: 20px;
        font-weight: 600;
        font-size: 0.9rem;
        font-family: 'Georgia', serif;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        gap: 6px;
    }

        .book-search-btn:hover {
            background: linear-gradient(135deg, #c89666 0%, #a0785a 100%);
            color: #f5f0e8;
            transform: scale(1.02);
            border-color: #ffd782;
        }

    /* --- DROPDOWN AYARLARI --- */
    @@media (min-width: 992px) {
        .book-navbar .dropdown-menu

    {
        left: 50% !important;
        right: auto !important;
        transform: translateX(-50%) !important;
        margin-top: 10px !important;
        border-radius: 10px !important;
        border: none !important;
        box-shadow: 0 8px 25px rgba(107, 85, 65, 0.15);
        text-align: center;
        min-width: 180px;
        font-size: 0.9rem;
        animation: fadeInDropdown 0.2s ease;
    }

    .book-navbar .dropdown-menu::before {
        content: '';
        position: absolute;
        top: -6px;
        left: 50%;
        transform: translateX(-50%);
        border-left: 6px solid transparent;
        border-right: 6px solid transparent;
        border-bottom: 6px solid #fff;
    }

    }

    @@keyframes fadeInDropdown {
        from

    {
        opacity: 0;
        transform: translate(-50%, 5px);
    }

    to {
        opacity: 1;
        transform: translate(-50%, 0);
    }

    }

    .dropdown-item {
        padding: 6px 15px;
    }

        .dropdown-item:active, .dropdown-item:hover {
            background-color: rgba(139, 111, 71, 0.1) !important;
            color: #8b6f47 !important;
            border-radius: 6px;
        }

    /* =========================================================
           MOBİL GÖRÜNÜM (991px ve ALTI) - SADECE ARAMA VE LOGO
           ========================================================= */
    @@media (max-width: 991.98px) {
        /* 1. Üstteki Hamburger İkonunu Gizle */
        .navbar-toggler

    {
        display: none !important;
    }

    /* 2. Açılır Linkleri Tamamen Gizle (Artık Alt Barda Var) */
    .navbar-collapse {
        display: none !important;
    }

    /* 3. Container'ı yeniden düzenle (Logo Solda, Arama Sağda) */
    .book-navbar .container-fluid {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: nowrap;
        padding: 0 15px; /* Mobilde kenar boşluğu eklendi */
    }

    .book-navbar .navbar-brand {
        font-size: 1.1rem;
        margin-right: 15px;
        padding: 0; /* Bootstrapin default paddingini sıfırladık */
    }

        /* Logodaki yazıyı mobilde gizleyelim ki arama kutusuna yer kalsın */
        .book-navbar .navbar-brand span {
            display: none !important;
        }

    /* --- 4. YENİ PROFESYONEL MOBİL ARAMA FORMU --- */
    .mobile-search-form {
        flex-grow: 1;
        position: relative;
        margin: 0;
        display: flex;
        align-items: center;
    }

    .mobile-search-input {
        width: 100%;
        height: 40px; /* Sabit ve dengeli yükseklik */
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 20px; /* Tam yuvarlak hap görünümü */
        padding: 0 40px 0 15px; /* Sağdan buton kadar (40px) boşluk bıraktık, buton üstüne binmesin */
        background: rgba(255, 255, 255, 0.12); /* Hafif transparan şık arka plan */
        color: #f5f0e8 !important;
        font-size: 0.9rem;
        outline: none;
        transition: all 0.3s ease;
        backdrop-filter: blur(5px);
    }

        /* Placeholder (İpucu Yazısı) Rengi */
        .mobile-search-input::placeholder,
        .mobile-search-input::-webkit-input-placeholder {
            color: rgba(245, 240, 232, 0.6) !important;
            font-style: normal;
        }

        /* Arama Kutusuna Tıklanınca */
        .mobile-search-input:focus {
            background: rgba(255, 255, 255, 0.2);
            border-color: rgba(255, 215, 130, 0.6); /* Açık sarımsı sınır */
            box-shadow: 0 0 10px rgba(255, 215, 130, 0.15); /* Hafif parlama efekti */
        }

    /* Kutu İçindeki Arama İkonu Butonu */
    .mobile-search-btn-icon {
        position: absolute;
        right: 2px; /* Kutunun içine sıfırladık */
        top: 50%;
        transform: translateY(-50%);
        width: 36px;
        height: 36px;
        background: transparent;
        border: none;
        color: rgba(245, 240, 232, 0.8);
        font-size: 1.1rem;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        cursor: pointer;
        transition: all 0.2s ease;
    }

        .mobile-search-btn-icon:hover,
        .mobile-search-btn-icon:active {
            color: #ffd782; /* Tıklanınca sararır */
            background: rgba(255, 255, 255, 0.1);
        }

    }
</style>

<header>
    <nav class="navbar navbar-expand-lg book-navbar">
        <div class="container-fluid">
            <!-- PC MASAÜSTÜ LOGO -->
            <a class="navbar-brand d-none d-lg-flex" asp-area="" asp-controller="Home" asp-action="Index">
                <img src="/images/library.png" style="width:35px;" />
                <span>DijitalKütüphanem</span>
            </a>

            <!-- MOBİL AVATAR LOGO -->
            @if(Model.User != null)
            {
                <a class="navbar-brand d-flex d-lg-none" asp-area="" asp-controller="Profile" asp-action="PublicProfile" asp-route-id="@Model.User.Id">
                    <div style="position: relative; width: 34px; height: 34px; border-radius: 8px; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, #fff9f0 0%, #e6dac8 100%); color: #5c4b3d; font-size: 1.1rem; font-weight: bold; flex-shrink: 0; box-shadow: 0 2px 5px rgba(0,0,0,0.2);">
                        <div style="width: 100%; height: 100%; border-radius: 6px; overflow: hidden; display: flex; align-items: center; justify-content: center;">
                            @if (!string.IsNullOrEmpty(Model.User.ProfileImageUrl))
                            {
                                <img src="@Model.User.ProfileImageUrl" alt="Profil" style="width: 100%; height: 100%; object-fit: cover;">
                            }
                            else
                            {
                                @Model.User.UserName.Substring(0, 1).ToUpper()
                            }
                        </div>
                        @if (!string.IsNullOrEmpty(Model.User.ActiveFrameImageUrl))
                        {
                            <img src="@Model.User.ActiveFrameImageUrl" style="position: absolute; top: -15%; left: -15%; width: 130%; height: 130%; pointer-events: none; z-index: 10; object-fit: contain;" />
                        }
                    </div>
                </a>
            }
            else
            {
                <a class="navbar-brand d-flex d-lg-none" asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="/images/library.png" style="width:32px;" />
                </a>
            }

            @if(Model.User != null)
            {
                <div class="d-flex d-lg-none align-items-center me-2 gap-3" style="font-weight: 700; font-size: 0.95rem; white-space: nowrap;">
                    <a href="javascript:void(0)" data-bs-toggle="modal" data-bs-target="#streakModal" style="color: #ff9800; text-decoration: none;" title="Seri Giriş (Detaylar için tıkla)">
                        <i class="fa-solid fa-fire" style="color: #ff5722; text-shadow: 0 0 8px rgba(255, 87, 34, 0.6);"></i> @(Model.User.CurrentStreak % 7 == 0 && Model.User.CurrentStreak > 0 ? 7 : Model.User.CurrentStreak % 7)/7
                    </a>
                    <a asp-area="" asp-controller="Store" asp-action="Index" style="color: #b2ebf2; text-decoration: none;" title="Seri Dondurma Hakları">
                        🧊 <span id="headerFreezeCountMobile">@Model.User.StreakFreezes/2</span>
                    </a>
                    <a asp-area="" asp-controller="Store" asp-action="Index" style="color: #ffd782; text-decoration: none;" title="Mağazaya Git">
                        <i class="fa-solid fa-gem" style="color: #00ffff; text-shadow: 0 0 8px rgba(0, 255, 255, 0.6);"></i> @Model.User.WisdomStones
                    </a>
                </div>
            }

            <form class="mobile-search-form d-flex d-lg-none" asp-controller="Home" asp-action="@targetAction" method="get">
                <input class="mobile-search-input" type="search" name="q" placeholder="Ara..." aria-label="Search" value="@ViewData["CurrentSearch"]" autocomplete="off">
                <button type="submit" class="mobile-search-btn-icon">
                    <i class="fa-solid fa-magnifying-glass"></i>
                </button>
            </form>

            <div class="navbar-collapse collapse d-none d-lg-flex" id="navbarContent">
                <ul class="navbar-nav flex-grow-1">

                    @if(Model.User != null)
                    {
                        <li class="nav-item d-flex align-items-center gap-3">
                            <a href="javascript:void(0)" data-bs-toggle="modal" data-bs-target="#streakModal" class="nav-link" style="color: #ff9800 !important; font-weight: 700; letter-spacing: 1px;" title="Seri Giriş Detayları">
                                <i class="fa-solid fa-fire" style="color: #ff5722; text-shadow: 0 0 8px rgba(255, 87, 34, 0.6);"></i> @(Model.User.CurrentStreak % 7 == 0 && Model.User.CurrentStreak > 0 ? 7 : Model.User.CurrentStreak % 7)/7
                            </a>
                            <a class="nav-link" asp-area="" asp-controller="Store" asp-action="Index" style="color: #b2ebf2 !important; font-weight: 700; letter-spacing: 1px;" title="Seri Dondurma Hakları">
                                🧊 <span id="headerFreezeCount">@Model.User.StreakFreezes/2</span>
                            </a>
                            <a class="nav-link" asp-area="" asp-controller="Store" asp-action="Index" style="color: #ffd782 !important; font-weight: 700; letter-spacing: 1px;" title="Mağazaya Git">
                                <i class="fa-solid fa-gem" style="color: #00ffff; text-shadow: 0 0 8px rgba(0, 255, 255, 0.6);"></i> @Model.User.WisdomStones
                            </a>
                        </li>
                    }

                    <li class="nav-item">
                        <a class="nav-link" asp-area="" asp-controller="Leaderboard" asp-action="Index">
                            <i class="fa-solid fa-trophy" style="color: #ffd782;"></i> Sıralama
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-area="" asp-controller="Excerpt" asp-action="Index">
                            <i class="fa-solid fa-camera-retro" style="color: #ffd782;"></i> Akış
                        </a>
                    </li>

                    @if(Model.User != null)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Message" asp-action="Index">
                                <i class="fa-solid fa-envelope" style="color: #ffd782;"></i> Mesajlar
                                <span id="unreadBadge" class="badge bg-danger rounded-pill d-none" style="position: absolute; top: -2px; right: -8px; font-size: 0.65rem;">0</span>
                            </a>
                        </li>
                    }

                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="categoryDropdown" role="button"
                           data-bs-toggle="dropdown" aria-expanded="false">
                            Kategoriler
                        </a>
                        <ul class="dropdown-menu" aria-labelledby="categoryDropdown">
                            @if (Model?.Categories?.Any() == true)
                            {
                                foreach (var cat in Model.Categories)
                                {
                                    <li>
                                        <a class="dropdown-item" asp-area="" asp-controller="Home" asp-action="Index" asp-route-categoryId="@cat.Id">
                                            @cat.CategoryName
                                        </a>
                                    </li>
                                }
                            }
                            else
                            {
                                <li><span class="dropdown-item text-muted">Kategori bulunamadı</span></li>
                            }
                        </ul>
                    </li>

                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle d-flex align-items-center gap-2" href="#" id="userDropdown" role="button"
                           data-bs-toggle="dropdown" aria-expanded="false">
                            @if (Model.User != null)
                            {
                                <div style="position: relative; width: 32px; height: 32px; border-radius: 8px; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, #fff9f0 0%, #e6dac8 100%); color: #5c4b3d; font-size: 1.1rem; font-weight: bold; flex-shrink: 0; box-shadow: 0 2px 5px rgba(0,0,0,0.2);">
                                    <div style="width: 100%; height: 100%; border-radius: 6px; overflow: hidden; display: flex; align-items: center; justify-content: center;">
                                        @if (!string.IsNullOrEmpty(Model.User.ProfileImageUrl))
                                        {
                                            <img src="@Model.User.ProfileImageUrl" alt="Profil" style="width: 100%; height: 100%; object-fit: cover;">
                                        }
                                        else
                                        {
                                            @Model.User.UserName.Substring(0, 1).ToUpper()
                                        }
                                    </div>
                                    @if (!string.IsNullOrEmpty(Model.User.ActiveFrameImageUrl))
                                    {
                                        <img src="@Model.User.ActiveFrameImageUrl" style="position: absolute; top: -15%; left: -15%; width: 130%; height: 130%; pointer-events: none; z-index: 10; object-fit: contain;" />
                                    }
                                </div>
                                <span>@Model.User.UserName</span>
                            }
                            else
                            {
                                <i class="fa-solid fa-user"></i>
                                <span>Hesabım</span>
                            }
                        </a>
                        <ul class="dropdown-menu" aria-labelledby="userDropdown">
                            @if (Model.User != null)
                            {
                                <li>
                                    <a class="dropdown-item logout-item" asp-area="" asp-controller="Profile" asp-action="PublicProfile" asp-route-id="@Model.User.Id">
                                        Profilim
                                    </a>
                                    <a class="dropdown-item logout-item" asp-area="" asp-controller="Profile" asp-action="Index">
                                        Özetim
                                    </a>
                                    <a class="dropdown-item logout-item" asp-area="" asp-controller="Profile" asp-action="Settings">
                                        Hesap Ayarları
                                    </a>
                                    @if (Model.User.Role == "SuperAdmin")
                                    {
                                        <a class="dropdown-item logout-item" asp-area="SuperAdmin" asp-controller="Dashboard" asp-action="Index">
                                            Sistemi Yönet
                                        </a>
                                    }
                                </li>
                                <li>
                                    <a class="dropdown-item logout-item text-danger" asp-area="" asp-controller="Account" asp-action="Logout">
                                        <i class="fa-solid fa-right-from-bracket text-danger"></i> Çıkış Yap
                                    </a>
                                </li>
                            }
                            else
                            {
                                <li>
                                    <a class="dropdown-item logout-item" asp-area="" asp-controller="Account" asp-action="Login">
                                        <i class="fa-solid fa-right-to-bracket"></i> Giriş Yap
                                    </a>
                                    <a class="dropdown-item logout-item" asp-area="" asp-controller="Account" asp-action="Register">
                                        <i class="fa-solid fa-user-plus"></i> Kayıt Ol
                                    </a>
                                </li>
                            }
                        </ul>
                    </li>

                    @* Kitaplık işlemleri yalnızca üyelere gösterilir *@
                    @if (Model.User != null)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-action="GoogleBooks" asp-controller="Home" style="white-space: nowrap;">
                                Hızlı Kitap Ekle
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-area="Admin" asp-controller="Books" asp-action="List" style="white-space: nowrap;">
                                Rafları Yönet
                            </a>
                        </li>
                    }

                    <li>
                        <a class="nav-link" asp-area="" asp-action="Community" asp-controller="Profile" role="button">
                            Topluluk
                        </a>
                    </li>
                </ul>

                <form class="book-search-form d-none d-lg-flex" asp-controller="Home" asp-action="@targetAction" method="get">
                    <input class="form-control book-search-input" type="search" name="q"
                           placeholder="@placeholderText" aria-label="Search" value="@ViewData["CurrentSearch"]">
                    <button class="btn book-search-btn" type="submit">
                        <i class="bi bi-search"></i>
                        Ara
                    </button>
                </form>
            </div>
        </div>
    </nav>
</header>

@if(Model.User != null)
{
    <partial name="_StreakModalPartial" model="Model.User" />
}

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const currentPath = window.location.pathname;
        const navLinks = document.querySelectorAll('.book-navbar .nav-link');

        navLinks.forEach(link => {
            if (link.getAttribute('href') === currentPath) {
                link.classList.add('active');
            }
        });
    });
</script>