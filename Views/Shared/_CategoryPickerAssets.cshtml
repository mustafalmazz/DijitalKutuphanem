@*
    Kategori seçicinin stil ve davranışı. Sayfada BİR KEZ eklenmesi yeterlidir
    (birden çok seçici olsa bile). _CategoryPicker ile birlikte kullanılır.
*@

<style>
    .catpick {
        position: relative;
    }

    /* --- TETİKLEYİCİ (form alanı görünümünde) --- */
    .catpick-trigger {
        width: 100%;
        display: flex;
        align-items: center;
        gap: 10px;
        min-height: 48px;
        padding: 11px 14px;
        border-radius: 12px;
        border: 2px solid rgba(139, 111, 71, 0.35);
        background: #fffdf9;
        color: #4a3f35;
        font-family: 'Georgia', serif;
        font-size: 0.95rem;
        text-align: left;
        cursor: pointer;
        transition: border-color 0.2s, box-shadow 0.2s;
    }

        .catpick-trigger:hover,
        .catpick-trigger:focus-visible {
            border-color: #8b6f47;
            box-shadow: 0 0 0 3px rgba(139, 111, 71, 0.13);
            outline: none;
        }

        .catpick-trigger.empty .catpick-trigger-text {
            color: #a89478;
        }

    .catpick-trigger-icon {
        flex-shrink: 0;
        color: #8b6f47;
    }

    .catpick-trigger-text {
        flex: 1 1 auto;
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        font-weight: 600;
    }

    .catpick-trigger-chevron {
        flex-shrink: 0;
        color: #a89478;
        font-size: 0.8rem;
    }

    .catpick-error {
        display: block;
        margin-top: 6px;
        color: #e74c3c;
        font-size: 0.8rem;
    }

    /* --- MODAL / ALT SAYFA --- */
    .catpick-sheet {
        position: fixed;
        inset: 0;
        z-index: 6000;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 16px;
        background: rgba(30, 22, 16, 0.55);
        backdrop-filter: blur(3px);
    }

        .catpick-sheet[hidden] {
            display: none;
        }

    .catpick-panel {
        width: 100%;
        max-width: 460px;
        max-height: min(78vh, 620px);
        display: flex;
        flex-direction: column;
        background: #fffdf9;
        border-radius: 18px;
        box-shadow: 0 24px 60px rgba(0, 0, 0, 0.35);
        overflow: hidden;
        animation: catpickIn 0.2s ease-out;
    }

    @@keyframes catpickIn {
        from {
            opacity: 0;
            transform: translateY(12px) scale(0.98);
        }

        to {
            opacity: 1;
            transform: none;
        }
    }

    .catpick-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        padding: 16px 18px 12px;
        border-bottom: 1px solid rgba(139, 111, 71, 0.15);
    }

    .catpick-title {
        margin: 0;
        font-family: 'Georgia', serif;
        font-size: 1.05rem;
        font-weight: 800;
        color: #4a3f35;
    }

    .catpick-close {
        flex-shrink: 0;
        width: 34px;
        height: 34px;
        border: none;
        border-radius: 50%;
        background: rgba(139, 111, 71, 0.1);
        color: #6b5541;
        font-size: 1rem;
        cursor: pointer;
    }

        .catpick-close:hover {
            background: rgba(139, 111, 71, 0.2);
        }

    .catpick-search-wrap {
        position: relative;
        padding: 12px 18px;
    }

        .catpick-search-wrap i {
            position: absolute;
            left: 30px;
            top: 50%;
            transform: translateY(-50%);
            color: #a89478;
            font-size: 0.85rem;
            pointer-events: none;
        }

    .catpick-search {
        width: 100%;
        padding: 10px 12px 10px 36px;
        border-radius: 10px;
        border: 1px solid rgba(139, 111, 71, 0.25);
        background: #fff;
        color: #4a3f35;
        font-family: 'Georgia', serif;
        font-size: 0.9rem;
    }

        .catpick-search:focus {
            outline: none;
            border-color: #8b6f47;
        }

    .catpick-list {
        flex: 1 1 auto;
        overflow-y: auto;
        padding: 4px 12px 14px;
        -webkit-overflow-scrolling: touch;
    }

    /* Dokunmatik için geniş satırlar */
    .catpick-option {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        min-height: 50px;
        padding: 12px 14px;
        margin-bottom: 6px;
        border: 1px solid transparent;
        border-radius: 12px;
        background: transparent;
        color: #4a3f35;
        font-family: 'Georgia', serif;
        font-size: 0.95rem;
        font-weight: 600;
        text-align: left;
        cursor: pointer;
        transition: background 0.15s, border-color 0.15s;
    }

        .catpick-option:hover {
            background: rgba(139, 111, 71, 0.08);
        }

        .catpick-option.selected {
            background: rgba(139, 111, 71, 0.12);
            border-color: #8b6f47;
        }

    .catpick-option-name {
        flex: 1 1 auto;
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .catpick-option-check {
        flex-shrink: 0;
        color: #48bb78;
        opacity: 0;
        transition: opacity 0.15s;
    }

    .catpick-option.selected .catpick-option-check {
        opacity: 1;
    }

    .catpick-empty {
        margin: 18px 0;
        text-align: center;
        color: #a89478;
        font-size: 0.87rem;
        font-style: italic;
    }

    /* --- MOBİL: alttan açılan sayfa --- */
    @@media (max-width: 575.98px) {
        .catpick-sheet {
            align-items: flex-end;
            padding: 0;
        }

        .catpick-panel {
            max-width: none;
            max-height: 85vh;
            border-radius: 20px 20px 0 0;
            animation: catpickUp 0.24s ease-out;
        }

        @@keyframes catpickUp {
            from {
                transform: translateY(100%);
            }

            to {
                transform: none;
            }
        }

        /* Parmakla kapatma ipucu */
        .catpick-head::before {
            content: '';
            position: absolute;
            top: 8px;
            left: 50%;
            transform: translateX(-50%);
            width: 42px;
            height: 4px;
            border-radius: 4px;
            background: rgba(139, 111, 71, 0.25);
        }

        .catpick-head {
            position: relative;
            padding-top: 22px;
        }

        .catpick-option {
            min-height: 54px;
        }
    }
</style>

<script>
    (function () {
        var openSheet = null;

        function labelFor(pickerId) {
            var wrap = document.querySelector('[data-catpick="' + CSS.escape(pickerId) + '"]');
            return wrap ? wrap.querySelector('[data-catpick-label]') : null;
        }

        function open(sheet) {
            sheet.hidden = false;
            openSheet = sheet;
            document.body.style.overflow = 'hidden';
            var search = sheet.querySelector('[data-catpick-search]');
            // Mobilde klavyenin hemen açılıp listeyi ezmemesi için sadece geniş ekranda odaklan
            if (search && window.innerWidth > 576) setTimeout(function () { search.focus(); }, 40);
        }

        function close() {
            if (!openSheet) return;
            openSheet.hidden = true;
            document.body.style.overflow = '';
            openSheet = null;
        }

        document.addEventListener('click', function (e) {
            var opener = e.target.closest('[data-catpick-open]');
            if (opener) {
                var sheet = document.getElementById(opener.getAttribute('data-catpick-open'));
                if (sheet) open(sheet);
                return;
            }

            if (e.target.closest('[data-catpick-close]')) {
                close();
                return;
            }

            var option = e.target.closest('.catpick-option');
            if (option) {
                var sheet = option.closest('.catpick-sheet');
                var pickerId = sheet.getAttribute('data-catpick-target');
                var input = document.getElementById(pickerId);
                var value = option.getAttribute('data-catpick-value');
                var name = option.getAttribute('data-catpick-name');

                if (input) {
                    input.value = value;
                    // Bu input'u dinleyen kodlar (ör. otomatik kaydetme) haberdar olsun
                    input.dispatchEvent(new Event('change', { bubbles: true }));
                }

                sheet.querySelectorAll('.catpick-option.selected')
                     .forEach(function (o) { o.classList.remove('selected'); });
                option.classList.add('selected');

                var label = labelFor(pickerId);
                if (label) {
                    label.textContent = name;
                    var trigger = label.closest('.catpick-trigger');
                    if (trigger) trigger.classList.remove('empty');
                }

                var wrap = document.querySelector('[data-catpick="' + CSS.escape(pickerId) + '"]');
                var err = wrap && wrap.querySelector('[data-catpick-error]');
                if (err) err.hidden = true;

                close();
                return;
            }

            // Panel dışına tıklayınca kapat
            if (openSheet && e.target === openSheet) close();
        });

        // Arama
        document.addEventListener('input', function (e) {
            var search = e.target.closest('[data-catpick-search]');
            if (!search) return;

            var sheet = search.closest('.catpick-sheet');
            var q = search.value.trim().toLocaleLowerCase('tr');
            var shown = 0;

            sheet.querySelectorAll('.catpick-option').forEach(function (o) {
                var name = (o.getAttribute('data-catpick-name') || '').toLocaleLowerCase('tr');
                var match = name.indexOf(q) > -1;
                o.style.display = match ? '' : 'none';
                if (match) shown++;
            });

            var empty = sheet.querySelector('[data-catpick-empty]');
            if (empty) empty.hidden = shown > 0;
        });

        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') close();
        });

        // Zorunlu seçicilerde boş gönderimi engelle
        document.addEventListener('submit', function (e) {
            var form = e.target;
            var blocked = false;

            form.querySelectorAll('.catpick').forEach(function (wrap) {
                var err = wrap.querySelector('[data-catpick-error]');
                if (!err) return; // zorunlu değil

                var input = document.getElementById(wrap.getAttribute('data-catpick'));
                if (input && !input.value) {
                    err.hidden = false;
                    blocked = true;
                }
            });

            if (blocked) {
                e.preventDefault();
                var first = form.querySelector('.catpick-error:not([hidden])');
                if (first) first.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }
        });
    })();
</script>
