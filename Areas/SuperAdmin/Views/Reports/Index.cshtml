@model IEnumerable<BookManagementApp.Models.Report>

@{
    ViewData["Title"] = "Kullanıcı Şikayetleri";
    Layout = "~/Areas/SuperAdmin/Views/Shared/_SuperAdminLayout.cshtml";
    var excerptReports = (ViewBag.ExcerptReports as List<BookManagementApp.Models.ExcerptReport>) ?? new();
    var liveExcerptIds = (ViewBag.LiveExcerptIds as List<int>) ?? new List<int>();
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="h3 mb-0 text-gray-800"><i class="fas fa-flag text-danger"></i> Kullanıcı Şikayetleri</h2>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Kapat"></button>
        </div>
    }

    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Gelen Şikayet Listesi</h6>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered table-hover" id="dataTable" width="100%" cellspacing="0">
                    <thead class="table-light">
                        <tr>
                            <th>Tarih</th>
                            <th>Şikayet Eden</th>
                            <th>Şikayet Edilen</th>
                            <th>Sebep</th>
                            <th>Detay</th>
                            <th>Durum</th>
                            <th>İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr class="@(item.IsResolved ? "table-secondary text-muted" : "")">
                                <td>@item.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                                <td>
                                    <span class="badge bg-info text-dark"><i class="fas fa-user"></i> @item.Reporter.UserName</span>
                                </td>
                                <td>
                                    <span class="badge bg-warning text-dark"><i class="fas fa-user-tag"></i> @item.ReportedUser.UserName</span>
                                    @if (item.ReportedUser.IsBanned)
                                    {
                                        <span class="badge bg-danger ms-1">Banlı</span>
                                    }
                                </td>
                                <td><strong>@item.Reason</strong></td>
                                <td style="max-width: 250px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" title="@item.Details">
                                    @item.Details
                                </td>
                                <td>
                                    @if (item.IsResolved)
                                    {
                                        <span class="badge bg-success"><i class="fas fa-check"></i> Çözüldü</span>
                                        @if (!string.IsNullOrEmpty(item.AdminNotes))
                                        {
                                            <div class="small mt-1 text-danger">@item.AdminNotes</div>
                                        }
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger"><i class="fas fa-exclamation-circle"></i> Bekliyor</span>
                                    }
                                </td>
                                <td>
                                    @if (!item.IsResolved)
                                    {
                                        <div class="d-flex gap-2">
                                            <form method="post" action="/SuperAdmin/Reports/MarkAsResolved">
                                                <input type="hidden" name="id" value="@item.Id" />
                                                <button type="submit" class="btn btn-sm btn-success" title="Çözüldü Olarak İşaretle">
                                                    <i class="fas fa-check"></i> Çöz
                                                </button>
                                            </form>

                                            @if (!item.ReportedUser.IsBanned)
                                            {
                                                <form method="post" action="/SuperAdmin/Reports/BanUser" onsubmit="return confirm('@item.ReportedUser.UserName adlı kullanıcıyı sistemden SÜRESİZ olarak uzaklaştırmak istediğinize emin misiniz?');">
                                                    <input type="hidden" name="id" value="@item.ReportedUser.Id" />
                                                    <input type="hidden" name="reportId" value="@item.Id" />
                                                    <button type="submit" class="btn btn-sm btn-danger" title="Kullanıcıyı Banla">
                                                        <i class="fas fa-gavel"></i> Banla
                                                    </button>
                                                </form>
                                            }
                                        </div>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary"><i class="fas fa-camera-retro"></i> Akış (Kesit) Şikayetleri</h6>
        </div>
        <div class="card-body">
            @if (!excerptReports.Any())
            {
                <div class="text-muted">Kesit şikayeti yok.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-bordered table-hover" width="100%" cellspacing="0">
                        <thead class="table-light">
                            <tr>
                                <th>Görsel</th>
                                <th>Tarih</th>
                                <th>Şikayet Eden</th>
                                <th>Paylaşan</th>
                                <th>Sebep</th>
                                <th>Durum</th>
                                <th>İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in excerptReports)
                            {
                                var live = liveExcerptIds.Contains(item.ExcerptId);
                                <tr class="@(item.IsResolved ? "table-secondary text-muted" : "")">
                                    <td>
                                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                                        {
                                            <a href="@item.ImageUrl" target="_blank" rel="noopener">
                                                <img src="@item.ImageUrl" alt="kesit" style="height:50px;object-fit:cover;border-radius:4px" />
                                            </a>
                                        }
                                        @if (!live)
                                        {
                                            <div class="small text-muted">(akıştan kalktı)</div>
                                        }
                                    </td>
                                    <td>@item.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                                    <td>
                                        <span class="badge bg-info text-dark"><i class="fas fa-user"></i> @item.Reporter?.UserName</span>
                                    </td>
                                    <td>
                                        <span class="badge bg-warning text-dark"><i class="fas fa-user-tag"></i> @item.ReportedUser?.UserName</span>
                                        @if (item.ReportedUser != null && item.ReportedUser.IsBanned)
                                        {
                                            <span class="badge bg-danger ms-1">Banlı</span>
                                        }
                                    </td>
                                    <td style="max-width: 220px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" title="@item.Reason">
                                        @(item.Reason ?? "-")
                                    </td>
                                    <td>
                                        @if (item.IsResolved)
                                        {
                                            <span class="badge bg-success"><i class="fas fa-check"></i> Çözüldü</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger"><i class="fas fa-exclamation-circle"></i> Bekliyor</span>
                                        }
                                    </td>
                                    <td>
                                        @if (!item.IsResolved)
                                        {
                                            <div class="d-flex gap-2">
                                                @if (live)
                                                {
                                                    <form method="post" action="/SuperAdmin/Reports/DeleteExcerpt"
                                                          onsubmit="return confirm('Kesit akıştan kaldırılsın mı? Görsel de silinecek.');">
                                                        <input type="hidden" name="id" value="@item.ExcerptId" />
                                                        <button type="submit" class="btn btn-sm btn-danger" title="Kesiti Kaldır">
                                                            <i class="fas fa-trash"></i> Kaldır
                                                        </button>
                                                    </form>
                                                }
                                                <form method="post" action="/SuperAdmin/Reports/ResolveExcerptReport">
                                                    <input type="hidden" name="id" value="@item.Id" />
                                                    <button type="submit" class="btn btn-sm btn-success" title="Çözüldü Olarak İşaretle">
                                                        <i class="fas fa-check"></i> Çöz
                                                    </button>
                                                </form>
                                            </div>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

