@using BookManagementApp.Areas.Admin.Models
@model List<User>

@{
    ViewData["Title"] = "Kullanıcı Listesi";
    Layout = "~/Areas/SuperAdmin/Views/Shared/_SuperAdminLayout.cshtml";
}

<style>
    .btn-sm {
        padding: 8px 15px !important;
        font-size: 0.9rem;
    }

    .btn-gold {
        background-color: #ffd700;
        color: #000;
        font-weight: 700;
        border: none;
        padding: 10px 25px;
        border-radius: 6px;
        transition: all 0.3s ease;
        box-shadow: 0 0 10px rgba(255, 215, 0, 0.3);
        text-decoration: none;
        display: inline-block;
        cursor: pointer;
    }

    @@keyframes slideIn {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .page-container {
        padding: 20px;
        max-width: 1400px;
        margin: 0 auto;
        animation: slideIn 0.6s ease-out;
    }

    /* Başlık Alanı */
    .header-wrapper {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
        border-bottom: 1px solid #333;
        padding-bottom: 20px;
    }

    .page-title {
        color: #ffd700; /* Gold */
        font-weight: 700;
        font-size: 2rem;
        text-shadow: 0 0 10px rgba(255, 215, 0, 0.3);
        margin: 0;
    }

    .page-subtitle {
        color: #888;
        font-size: 0.9rem;
        margin-top: 5px;
    }

    /* Yeni Ekle Butonu */
    .btn-gold {
        background-color: #ffd700;
        color: #000;
        font-weight: 700;
        border: none;
        padding: 10px 25px;
        border-radius: 6px;
        transition: all 0.3s ease;
        box-shadow: 0 0 10px rgba(255, 215, 0, 0.3);
        text-decoration: none;
        display: inline-block;
    }

        .btn-gold:hover {
            background-color: #ffed4a;
            box-shadow: 0 0 20px rgba(255, 215, 0, 0.6);
            transform: translateY(-2px);
            color: #000;
        }

    /* Arama Kartı */
    .search-card {
        background-color: #111;
        border: 1px solid #333;
        border-left: 4px solid #ffd700;
        padding: 20px;
        border-radius: 8px;
        margin-bottom: 30px;
        display: flex;
        gap: 15px;
        align-items: center;
    }

    .input-dark {
        background-color: #050505;
        border: 1px solid #333;
        color: #fff;
        padding: 10px 15px;
        border-radius: 5px;
        width: 100%;
        transition: border-color 0.3s;
    }

        .input-dark:focus {
            border-color: #ffd700;
            outline: none;
            box-shadow: 0 0 8px rgba(255, 215, 0, 0.2);
        }

    /* Tablo Kartı */
    .table-card {
        background: #111;
        border: 1px solid #333;
        border-radius: 12px;
        padding: 5px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    }

    /* Tablo Responsive Wrapper (Kaydırma için) */
    .table-responsive {
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
    }

    .custom-table {
        width: 100%;
        border-collapse: collapse;
        color: #ccc;
    }

        .custom-table thead {
            background-color: #1a1a1a;
        }

        .custom-table th {
            text-align: left;
            padding: 18px;
            color: #ffd700;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            border-bottom: 2px solid #333;
        }

        .custom-table td {
            padding: 18px;
            border-bottom: 1px solid #222;
            vertical-align: middle;
        }

        .custom-table tr:hover td {
            background-color: rgba(255, 215, 0, 0.03);
            color: #fff;
        }

    /* Avatar Stili */
    .user-avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background-color: #333;
        color: #ffd700;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        border: 1px solid #555;
        text-transform: uppercase;
        font-size: 1.1rem;
        flex-shrink: 0; /* Mobilde büzülmesin */
    }

    /* Rozetler */
    .badge-role {
        padding: 5px 10px;
        border-radius: 4px;
        font-size: 0.75rem;
        font-weight: 600;
        border: 1px solid;
        white-space: nowrap; /* Mobilde alt satıra geçmesin */
    }

    .badge-admin {
        background: rgba(255, 215, 0, 0.1);
        color: #ffd700;
        border-color: #ffd700;
    }

    .badge-user {
        background: rgba(255, 255, 255, 0.1);
        color: #ccc;
        border-color: #555;
    }

    /* Butonlar */
    .action-btn {
        width: 35px;
        height: 35px;
        border-radius: 5px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
        border: 1px solid transparent;
        color: #fff;
        margin-right: 5px;
        text-decoration: none;
    }

    .btn-edit {
        background: rgba(0, 123, 255, 0.2);
        color: #4dabf7;
        border-color: #004085;
    }

        .btn-edit:hover {
            background: #007bff;
            color: white;
            box-shadow: 0 0 10px #007bff;
        }

    .btn-delete {
        background: rgba(220, 53, 69, 0.2);
        color: #ff6b6b;
        border-color: #721c24;
    }

        .btn-delete:hover {
            background: #dc3545;
            color: white;
            box-shadow: 0 0 10px #dc3545;
        }

    /* --- MOBİL UYUMLULUK (MEDIA QUERY) --- */
    @@media (max-width: 768px) {
        .page-container {
            padding: 10px;
        }

        .header-wrapper {
            flex-direction: column;
            align-items: stretch; /* İçerikleri tam genişliğe yay */
            text-align: center;
            gap: 15px;
        }

            .header-wrapper > div {
                width: 100%;
            }

        .btn-gold {
            width: 100%; /* Buton mobilde tam genişlik */
            text-align: center;
        }

        .page-title {
            font-size: 1.6rem;
        }

        .search-card {
            padding: 15px;
        }
        /* Tablo hücrelerinin mobilde satır kırmasını engelle */
        .custom-table th, .custom-table td {
            white-space: nowrap;
            padding: 12px;
        }
    }

    /* --- BİLGELİK TAŞI HÜCRESİ --- */
    .stone-cell {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 3px;
    }

    .stone-balance {
        color: #ffd782;
        font-weight: 700;
        font-size: 0.92rem;
        white-space: nowrap;
    }

        .stone-balance i {
            color: #00e5ff;
        }

    .stone-earned {
        color: #777;
        font-size: 0.72rem;
        white-space: nowrap;
    }

    .stone-btn {
        margin-top: 3px;
        background: transparent;
        border: 1px solid rgba(255, 215, 130, 0.35);
        color: #ffd782;
        border-radius: 6px;
        padding: 3px 9px;
        font-size: 0.72rem;
        cursor: pointer;
        transition: background 0.2s, border-color 0.2s;
    }

        .stone-btn:hover {
            background: rgba(255, 215, 130, 0.12);
            border-color: #ffd782;
        }

    /* --- TAŞ MODALI --- */
    .stone-modal-backdrop {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.72);
        backdrop-filter: blur(4px);
        z-index: 5000;
        display: none;
        align-items: center;
        justify-content: center;
        padding: 16px;
    }

        .stone-modal-backdrop.show {
            display: flex;
        }

    .stone-modal {
        width: 100%;
        max-width: 420px;
        background: #17171c;
        border: 1px solid rgba(255, 215, 130, 0.22);
        border-radius: 14px;
        box-shadow: 0 24px 60px rgba(0, 0, 0, 0.6);
        overflow: hidden;
    }

    .stone-modal-head {
        padding: 18px 20px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.07);
    }

    .stone-modal-title {
        color: #fff;
        font-weight: 700;
        font-size: 1.05rem;
        margin: 0;
    }

    .stone-modal-sub {
        color: #888;
        font-size: 0.8rem;
        margin: 4px 0 0;
    }

    .stone-modal-body {
        padding: 20px;
    }

    .stone-modal-label {
        display: block;
        color: #aaa;
        font-size: 0.78rem;
        margin-bottom: 6px;
    }

    .stone-amount-input {
        width: 100%;
        background: #0f0f13;
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 8px;
        color: #fff;
        padding: 11px 13px;
        font-size: 1rem;
    }

        .stone-amount-input:focus {
            outline: none;
            border-color: #ffd782;
        }

    .stone-quick {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        margin-top: 10px;
    }

    .stone-quick-btn {
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: #bbb;
        border-radius: 6px;
        padding: 4px 10px;
        font-size: 0.76rem;
        cursor: pointer;
    }

        .stone-quick-btn:hover {
            background: rgba(255, 215, 130, 0.14);
            color: #ffd782;
        }

    .stone-modal-foot {
        display: flex;
        gap: 10px;
        padding: 0 20px 20px;
    }

    .stone-submit {
        flex: 1;
        border: none;
        border-radius: 8px;
        padding: 11px;
        font-weight: 700;
        font-size: 0.88rem;
        cursor: pointer;
        color: #17171c;
    }

    .stone-submit-add {
        background: linear-gradient(135deg, #6ee7a8, #34d399);
    }

    .stone-submit-sub {
        background: linear-gradient(135deg, #ff9b9b, #f87171);
    }

    .stone-cancel {
        width: 100%;
        margin: 0 20px 18px;
        background: transparent;
        border: 1px solid rgba(255, 255, 255, 0.13);
        color: #999;
        border-radius: 8px;
        padding: 9px;
        font-size: 0.82rem;
        cursor: pointer;
    }

    .stone-note {
        margin: 14px 0 0;
        padding: 10px 12px;
        background: rgba(255, 215, 130, 0.07);
        border-left: 2px solid rgba(255, 215, 130, 0.4);
        border-radius: 4px;
        color: #9a9a9a;
        font-size: 0.72rem;
        line-height: 1.5;
    }

    /* --- İŞLEM SONUCU BİLDİRİMİ --- */
    .stone-alert {
        margin-bottom: 18px;
        padding: 13px 16px;
        border-radius: 9px;
        font-size: 0.88rem;
    }

    .stone-alert-ok {
        background: rgba(52, 211, 153, 0.1);
        border-left: 3px solid #34d399;
        color: #6ee7a8;
    }

    .stone-alert-err {
        background: rgba(248, 113, 113, 0.1);
        border-left: 3px solid #f87171;
        color: #ff9b9b;
    }

    @@media (max-width: 640px) {
        .stone-modal-foot {
            flex-direction: column;
        }
    }
</style>

<div class="page-container">

    <div class="header-wrapper">
        <div>
            <h1 class="page-title"><i class="bi bi-people-fill"></i> Kullanıcılar</h1>
            <p class="page-subtitle">Sistemdeki kayıtlı @(Model?.Count ?? 0) adet üyeyi yönetin</p>
        </div>
        <div>
            <a asp-area="SuperAdmin" asp-action="Add" asp-controller="Users" class="btn-gold btn-sm">
                <i class="bi bi-person-plus-fill"></i> Yeni Kullanıcı
            </a>
        </div>
    </div>

    <div class="search-card">
        <div style="flex-grow: 1;">
            <form method="get" asp-action="Search" asp-controller="Users" style="display: flex; gap: 10px;">
                <input type="text" id="searchInput" name="q" class="input-dark" placeholder="Tabloda ara (Kullanıcı Adı, Email)...">
                <button class="btn-gold">  <i class="bi bi-search"></i></button>
            </form>
        </div>
    </div>

    @if (TempData["StoneMessage"] != null)
    {
        <div class="stone-alert stone-alert-ok">
            <i class="bi bi-check-circle"></i> @TempData["StoneMessage"]
        </div>
    }
    @if (TempData["StoneError"] != null)
    {
        <div class="stone-alert stone-alert-err">
            <i class="bi bi-exclamation-triangle"></i> @TempData["StoneError"]
        </div>
    }

    <div class="table-card">
        <div class="table-responsive">
            <table class="custom-table" id="usersTable">
                <thead>
                    <tr>
                        <th>Kullanıcı</th>
                        <th>Email</th>
                        <th>Rol</th>
                        <th>İlişkili Veriler</th>
                        <th>Bilgelik Taşı</th>
                        <th style="text-align:right;">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var user in Model)
                        {

                            var userName = !string.IsNullOrEmpty(user.UserName) ? user.UserName : "Bilinmiyor";
                            var initials = userName.Substring(0, 1).ToUpper();


                            var role = user.Role ?? "User";

                            var badgeClass = (role == "SuperAdmin") ? "badge-admin" : "badge-user";

                            var roleDisplayName = (role == "SuperAdmin") ? "Süper Yönetici" : "Kullanıcı";

                            var bookCount = user.Books?.Count ?? 0;

                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="user-avatar">@initials</div>
                                        <div class="ms-3">
                                            <div style="font-weight:bold; color:#fff;">@userName</div>
                                            <div style="font-size:0.8rem; color:#888;">ID: #@user.Id</div>
                                        </div>
                                    </div>
                                </td>
                                <td>@user.Email</td>
                                <td>
                                    <span class="badge-role @badgeClass">@roleDisplayName</span>
                                </td>
                                <td>
                                    <span style="color:#aaa; font-size:0.85rem;">
                                        @bookCount Kitap
                                    </span>
                                </td>
                                <td>
                                    <div class="stone-cell">
                                        <span class="stone-balance" title="Harcanabilir bakiye">
                                            <i class="bi bi-gem"></i> @user.WisdomStones.ToString("N0")
                                        </span>
                                        <span class="stone-earned" title="Bugüne kadar kazanılan toplam (başarımlar bunu kullanır)">
                                            toplam kazanç: @user.TotalStonesEarned.ToString("N0")
                                        </span>
                                        <button type="button" class="stone-btn"
                                                onclick="openStoneModal(@user.Id, '@userName', @user.WisdomStones, @user.TotalStonesEarned)">
                                            <i class="bi bi-sliders"></i> Düzenle
                                        </button>
                                    </div>
                                </td>
                                <td style="text-align:right;">
                                    <a asp-action="Edit" asp-route-id="@user.Id" class="action-btn btn-edit" title="Düzenle">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    @if (user.Role != "SuperAdmin")
                                    {
                                        <a asp-action="DeleteConfirm" asp-route-id="@user.Id" class="action-btn btn-delete" title="Sil">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    }

                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center p-4 text-muted">
                                <i class="bi bi-inbox" style="font-size: 2rem; display:block; margin-bottom:10px;"></i>
                                Sistemde kayıtlı kullanıcı bulunamadı.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    // JS Arama Filtresi
    document.getElementById('searchInput')?.addEventListener('keyup', function() {
        var value = this.value.toLowerCase();
        var rows = document.querySelectorAll('#usersTable tbody tr');

        rows.forEach(function(row) {
            var text = row.textContent.toLowerCase();
            row.style.display = text.indexOf(value) > -1 ? '' : 'none';
        });
    });
</script>

<!-- BİLGELİK TAŞI DÜZENLEME MODALI -->
<div class="stone-modal-backdrop" id="stoneModal">
    <div class="stone-modal">
        <form method="post" asp-action="AdjustStones" asp-controller="Users" id="stoneForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" id="stoneUserId" />
            <input type="hidden" name="operation" id="stoneOperation" />

            <div class="stone-modal-head">
                <p class="stone-modal-title" id="stoneModalTitle">Bilgelik Taşı</p>
                <p class="stone-modal-sub" id="stoneModalSub"></p>
            </div>

            <div class="stone-modal-body">
                <label class="stone-modal-label" for="stoneAmount">Miktar</label>
                <input type="number" name="amount" id="stoneAmount" class="stone-amount-input"
                       min="1" step="1" value="100" required />

                <div class="stone-quick">
                    <button type="button" class="stone-quick-btn" onclick="setStoneAmount(50)">50</button>
                    <button type="button" class="stone-quick-btn" onclick="setStoneAmount(100)">100</button>
                    <button type="button" class="stone-quick-btn" onclick="setStoneAmount(500)">500</button>
                    <button type="button" class="stone-quick-btn" onclick="setStoneAmount(1000)">1.000</button>
                    <button type="button" class="stone-quick-btn" onclick="setStoneAmount(5000)">5.000</button>
                </div>

                <p class="stone-note">
                    <b>Ekleme</b> hem bakiyeyi hem toplam kazancı artırır, yani Bilgelik başarımlarını da ilerletir.<br />
                    <b>Çıkarma</b> yalnızca bakiyeyi düşürür; kazanılmış ilerleme geri alınmaz. Bakiye eksiye düşmez.
                </p>
            </div>

            <div class="stone-modal-foot">
                <button type="submit" class="stone-submit stone-submit-add" onclick="document.getElementById('stoneOperation').value='add'">
                    <i class="bi bi-plus-lg"></i> Ekle
                </button>
                <button type="submit" class="stone-submit stone-submit-sub" onclick="document.getElementById('stoneOperation').value='subtract'">
                    <i class="bi bi-dash-lg"></i> Çıkar
                </button>
            </div>
            <button type="button" class="stone-cancel" onclick="closeStoneModal()">Vazgeç</button>
        </form>
    </div>
</div>

<script>
    function openStoneModal(userId, userName, balance, earned) {
        document.getElementById('stoneUserId').value = userId;
        document.getElementById('stoneModalTitle').textContent = userName + ' - Bilgelik Taşı';
        document.getElementById('stoneModalSub').textContent =
            'Bakiye: ' + balance.toLocaleString('tr-TR') + '  |  Toplam kazanç: ' + earned.toLocaleString('tr-TR');
        document.getElementById('stoneAmount').value = 100;
        document.getElementById('stoneModal').classList.add('show');
    }

    function setStoneAmount(v) {
        document.getElementById('stoneAmount').value = v;
    }

    function closeStoneModal() {
        document.getElementById('stoneModal').classList.remove('show');
    }

    // Arka plana tiklayinca kapat
    document.getElementById('stoneModal')?.addEventListener('click', function (e) {
        if (e.target === this) closeStoneModal();
    });

    document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') closeStoneModal();
    });
</script>
